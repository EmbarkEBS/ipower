<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="statement_report">

        <t t-call="web.html_container">

            <t t-call="web.external_layout">

                <div class="page">

                    <h2>
                        Partner Currency Statement
                    </h2>

                    <br/>

                    <table class="table table-sm">

                        <tr>
                            <td><strong>Partner</strong></td>
                            <td>
                                <span t-esc="docs.partner_id.name"/>
                            </td>
                        </tr>

                    </table>

                    <br/>

                    <h3>
                        Outstanding Summary
                    </h3>

                    <table class="table table-sm table-bordered">

                        <thead>
                            <tr>
                                <th>Currency</th>
                                <th class="text-end">
                                    Outstanding
                                </th>
                            </tr>
                        </thead>

                        <tbody>

                            <t t-foreach="currency_summary.values()" t-as="currency_data">


                                <tr>                                   
                                    
                                   <td>
                                      <span t-esc="currency_data['currency'].name"/>
                                   </td>

                                   <td class="text-end">
                                      <span t-esc="currency_data['total']"/>
                                   </td>

                                </tr>

                            </t>

                        </tbody>

                    </table>

                    <br/>

                    <h3>
                        Open Transactions
                    </h3>

                    <table class="table table-sm table-bordered">

                        <thead>

                            <tr>
                                <th>Date</th>
                                <th>Document</th>
                                <th>Due Date</th>
                                <th>Currency</th>
                                <th class="text-end">
                                    Outstanding
                                </th>
                            </tr>

                        </thead>

                        <tbody>

                            <t t-foreach="lines"
                               t-as="line">

                                <tr>

                                    <td>
                                        <span t-esc="line.date"/>
                                    </td>

                                    <td>
                                        <span t-esc="line.move_id.name"/>
                                    </td>

                                    <td>
                                        <span t-esc="line.date_maturity"/>
                                    </td>

                                    <td>
                                        <span t-esc="line.currency_id.name"/>
                                    </td>

                                    <td class="text-end">
                                        <span t-esc="line.amount_residual_currency"/>
                                    </td>

                                </tr>

                            </t>

                        </tbody>

                    </table>

                </div>

            </t>

        </t>

    </template>

</odoo>
