<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_currency_statement"
            model="ir.ui.view">

        <field name="name">
            res.partner.form.currency.statement
        </field>

        <field name="model">res.partner</field>

        <field name="inherit_id"
               ref="base.view_partner_form"/>

        <field name="arch"
               type="xml">

            <xpath expr="//sheet"
                   position="before">

                <div class="oe_button_box"
                     name="button_box">

                    <button
                        name="action_print_currency_statement"
                        type="object"
                        string="Currency Statement"
                        class="oe_stat_button btn-primary"/>

                </div>

            </xpath>

        </field>

    </record>

</odoo>
