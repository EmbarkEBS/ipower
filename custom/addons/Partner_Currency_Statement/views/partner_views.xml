<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_currency_statement"
            model="ir.ui.view">
        <field name="name">
            res.partner.form.currency.statement
        </field>

        <field name="model">res.partner</field>

        <field name="inherit_id"
               ref="base.view_partner_form"/>

        <field name="arch"
               type="xml">

            <header position="inside">

                <button
                    name="action_print_currency_statement"
                    string="Currency Statement"
                    type="object"
                    class="btn-primary"/>

            </header>

        </field>
    </record>

</odoo>