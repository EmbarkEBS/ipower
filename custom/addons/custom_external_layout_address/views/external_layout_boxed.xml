<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Header replacement -->
    <template id="external_layout_boxed_custom_header"
              inherit_id="web.external_layout_boxed">

        <xpath expr="//div[@name='company_address']"
               position="replace">

            <div name="company_address" class="mb4">
                <strong>iPOWER ELECTRIKA TRADING L.L.C</strong><br/>
                PO Box 451269, Dubai<br/>
                United Arab Emirates<br/>
              TRN: 100504732700003
            </div>

        </xpath>

    </template>

    <!-- Footer replacement -->
    <template id="external_layout_boxed_custom_footer"
          inherit_id="web.external_layout_boxed">

    <xpath expr="//div[@class='o_footer_content']"
           position="replace">

        <div class="o_footer_content">

            <div style="padding:0 40px;font-size:11px;">

                <div style="margin-bottom:5px;color:#888;font-style:italic;">
                    This document is electronically generated and valid without signature or company stamp.
                </div>

                <div style="
                    border-top:1px solid #1f3b73;
                    padding-top:6px;
                    text-align:center;
                    font-size:11px;
                    line-height:1.5;
                ">

                    Shed-2, Plot 1586, Umm Dera, Al Raafah,
                    Umm Al Quwain - United Arab Emirates

                    <br/>

                    CR No: 1024983 |
                    info@ipowerelectrika.com |
                    www.ipowerelectrika.com

                </div>

            </div>

            <div style="
                   height:25px;
    overflow:hidden;
    margin-top:5px;
    margin-left:-40px !important;
    margin-right:-50px !important;
    margin-bottom:-20px !important;
    padding-bottom:0;
            ">

                <svg width="100%"
                     height="25"
                     viewBox="0 0 1000 25"
                     preserveAspectRatio="none">

                    <polygon points="0,0 260,0 240,25 0,25"
                             fill="#1f3b73"/>

                    <polygon points="260,0 1000,0 1000,25 240,25"
                             fill="#e58b39"/>

                </svg>

            </div>

        </div>

    </xpath>

</template>
</odoo>