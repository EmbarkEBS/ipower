<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="stock_landed_cost_form_exemption" model="ir.ui.view">
        <field name="name">stock.landed.cost.form.exemption</field>
        <field name="model">stock.landed.cost</field>
        <field name="inherit_id" ref="stock_landed_costs.view_stock_landed_cost_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='valuation_adjustment_lines']/list/field[@name='product_id']"
                   position="after">
                <field name="exemption_rate" readonly="1"/>
            </xpath>

        </field>
    </record>

</odoo>