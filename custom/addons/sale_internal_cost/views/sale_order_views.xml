<odoo>
    <record id="view_order_form_inherit_internal_cost" model="ir.ui.view">
        <field name="name">sale.order.form.internal.cost</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Global Charges Tab -->
            <xpath expr="//page[@name='order_lines']" position="after">
                <page string="Internal Charges" name="internal_charges">
                    <group>
                        <group>
                            <field name="freight"/>
                            <field name="duty"/>
                            <field name="misc"/>
                        </group>
                        <group>
                            <field name="total_extra" readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>

            <!-- Ensure Unit Price is NOT readonly -->
            <!-- Note: Using //field[@name='price_unit'] to be safe across versions -->
            <xpath expr="//field[@name='order_line']//list//field[@name='price_unit']" position="attributes">
                <attribute name="readonly">0</attribute>
            </xpath>

        </field>
    </record>
</odoo>
