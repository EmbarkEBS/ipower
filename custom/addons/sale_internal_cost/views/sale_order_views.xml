<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_internal_cost" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.internal.cost</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Internal Charges Tab -->
            <xpath expr="//page[@name='order_lines']" position="after">
                <page string="Internal Charges">
                    <group>
                        <field name="freight"/>
                        <field name="duty"/>
                        <field name="misc"/>
                        <field name="total_extra" readonly="1"/>
                    </group>
                </page>
            </xpath>

            <!-- Line Columns -->
            <xpath expr="//field[@name='order_line']//list//field[@name='price_unit']" position="before">
                <field name="x_base_price" string="Unit Price"/>
                <field name="x_internal_charge" string="Int. Charge" optional="show"/>
            </xpath>

            <xpath expr="//field[@name='order_line']//list//field[@name='price_unit']" position="attributes">
                <attribute name="string">Price + Charges</attribute>
                <attribute name="readonly">1</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>

        </field>
    </record>
</odoo>
