<odoo>
    <record id="view_order_form_inherit_internal_cost" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.internal.cost</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Global Charges Tab -->
            <xpath expr="//page[@name='order_lines']" position="after">
                <page string="Internal Charges">
                    <group>
                        <field name="freight"/>
                        <field name="duty"/>
                        <field name="misc"/>
                    </group>
                </page>
            </xpath>

        </field>
    </record>
</odoo>
