<odoo>

    <record id="view_order_form_inherit_cost" model="ir.ui.view">
        <field name="name">sale.order.form.internal.cost</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Inject inside order line form -->
            <xpath expr="//field[@name='order_line']/form" position="inside">

                <group string="Internal Pricing">
                    <field name="price_without_cost"/>
                    <field name="total_internal_cost" readonly="1"/>
                    <field name="is_manual_price"/>
                </group>

                <group string="Internal Costs" groups="base.group_user">
                    <field name="internal_cost_ids" context="{'default_line_id': active_id}">
                        <tree editable="bottom">
                            <field name="cost_type"/>
                            <field name="amount"/>
                            <field name="description"/>
                        </tree>
                    </field>
                </group>

            </xpath>

        </field>
    </record>

</odoo>