<odoo>

    <!-- Inherit SALE ORDER LINE FORM (IMPORTANT) -->
    <record id="view_sale_order_line_form_inherit_cost" model="ir.ui.view">
        <field name="name">sale.order.line.form.internal.cost</field>
        <field name="model">sale.order.line</field>
        <field name="inherit_id" ref="sale.view_order_line_form"/>
        <field name="arch" type="xml">

            <xpath expr="//group" position="after">

                <group string="Internal Pricing">
                    <field name="price_without_cost"/>
                    <field name="total_internal_cost" readonly="1"/>
                    <field name="is_manual_price"/>
                </group>

                <group string="Internal Costs">
                    <field name="internal_cost_ids">
                        <tree editable="bottom">
                            <field name="cost_type"/>
                            <field name="amount"/>
                            <field name="description"/>
                        </tree>
                    </field>
                </group>

            </xpath>

        </field>
    </record>

</odoo>