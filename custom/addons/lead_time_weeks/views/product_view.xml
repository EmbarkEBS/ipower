<odoo>
    <record id="lead_time_weeks_view_clean" model="ir.ui.view">
        <field name="name">product.template.lead.time.weeks.clean.final</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">

            <!-- SAFE INSERT ONLY -->
            <xpath expr="//group[.//field[@name='weight']]" position="inside">
                <group>
                    <field name="lead_time_weeks"/>
                    <label string="weeks"/>
                </group>
            </xpath>

        </field>
    </record>
</odoo>