<odoo>
    <record id="view_product_form_lead_time_weeks" model="ir.ui.view">
        <field name="name">product.template.form.lead.time.weeks</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">

            <!-- FULL replacement removes label + unit (days) -->
            <xpath expr="//field[@name='sale_delay']" position="replace">
                <div class="o_row">
                    <field name="lead_time_weeks"/>
                    <span class="ms-2">weeks</span>
                </div>
            </xpath>

        </field>
    </record>
</odoo>