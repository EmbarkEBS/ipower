<odoo>
    <record id="view_product_form_lead_time_weeks" model="ir.ui.view">
        <field name="name">product.template.form.lead.time.weeks</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">

            <!-- Hide default days field -->
            <xpath expr="//field[@name='sale_delay']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Add weeks field -->
            <xpath expr="//field[@name='sale_delay']" position="after">
                <field name="lead_time_weeks"/>
            </xpath>

        </field>
    </record>
</odoo>