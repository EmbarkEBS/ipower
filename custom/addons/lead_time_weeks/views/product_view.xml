<odoo>
    <record id="view_product_form_lead_time_weeks_clean" model="ir.ui.view">
        <field name="name">product.template.form.lead.time.weeks.clean</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">

            <!-- STEP 1: HIDE ORIGINAL FIELD COMPLETELY -->
            <xpath expr="//field[@name='sale_delay']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- STEP 2: ADD YOUR FIELD IN SAME AREA -->
            <xpath expr="//group[.//field[@name='weight']]" position="inside">
                <div class="o_row">
                    <label for="lead_time_weeks"/>
                    <field name="lead_time_weeks"/>
                    <span class="ms-2">weeks</span>
                </div>
            </xpath>

        </field>
    </record>
</odoo>