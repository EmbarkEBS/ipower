<odoo>

    <record id="ir_cron_stock_reordering_alert" model="ir.cron">
        <field name="name">Stock Reordering Alert Check</field>
        <field name="model_id" ref="stock.model_stock_warehouse_orderpoint"/>
        <field name="state">code</field>
        <field name="code">model.action_check_low_stock_alerts()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="active">True</field>
    </record>

</odoo>
