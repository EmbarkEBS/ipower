<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_move_filter_boe" model="ir.ui.view">
        <field name="name">account.move.search.boe</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">

            <xpath expr="//filter[@name='partner']" position="after">

                <separator/>

                <filter name="group_by_boe_number"
                        string="BOE Number"
                        context="{'group_by':'boe_number'}"/>

                <filter name="group_by_boe_date"
                        string="BOE Date"
                        context="{'group_by':'boe_date'}"/>

            </xpath>

        </field>
    </record>

</odoo>
