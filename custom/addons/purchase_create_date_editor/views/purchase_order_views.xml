<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="purchase_order_form_inherit_dates"
            model="ir.ui.view">

        <field name="name">
            purchase.order.form.inherit.dates
        </field>

        <field name="model">purchase.order</field>

        <field name="inherit_id"
               ref="purchase.purchase_order_form"/>

        <field name="arch" type="xml">

            <xpath expr="//field[@name='date_order']"
                   position="after">

                <field name="editable_create_date"/>

                <field name="editable_confirmation_date"/>

            </xpath>

        </field>

    </record>

</odoo>