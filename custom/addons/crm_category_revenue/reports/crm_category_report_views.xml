<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <record id="crm_category_line_pivot"
            model="ir.ui.view">
        <field name="name">
            crm.lead.category.line.pivot
        </field>

        <field name="model">
            crm.lead.category.line
        </field>

        <field name="arch" type="xml">

            <pivot string="CRM Category Analysis">

                <field name="amount"
                       type="measure"/>

                <field name="category_id"
                       type="row"/>

                <field name="status"
                       type="col"/>

            </pivot>

        </field>
    </record>

</odoo>