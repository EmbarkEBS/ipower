<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- CRM Form View -->
    <record id="crm_lead_form_category_inherit" model="ir.ui.view">
        <field name="name">crm.lead.form.category.inherit</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">

                <page string="Category Details">

                    <field name="category_line_ids">
                        <list editable="bottom">
                            <field name="category_id"/>
                            <field name="vendor_ids"
               widget="many2many_tags"/>
                            <field name="status"/>
                            <field name="amount"/>
                        </list>
                    </field>

                    <group>
                        <field name="total_category_amount" readonly="1"/>
                    </group>

                </page>

            </xpath>

        </field>
    </record>

</odoo>



