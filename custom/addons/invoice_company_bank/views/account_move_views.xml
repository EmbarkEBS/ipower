<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_move_form_company_bank" model="ir.ui.view">
        <field name="name">account.move.form.company.bank</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='invoice_date']" position="after">

                <field name="company_bank_id"
                       invisible="move_type not in ('out_invoice','in_invoice')"/>

                <field name="bank_display_details"
                       widget="html"
                       readonly="1"
                       invisible="move_type not in ('out_invoice','in_invoice')"/>

            </xpath>

        </field>
    </record>

</odoo>
