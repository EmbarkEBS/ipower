<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sale_order_form_approval" model="ir.ui.view">
        <field name="name">sale.order.form.approval</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>

        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">

                <button
                    name="action_approve_quotation"
                    string="Approve"
                    type="object"
                    class="btn-primary"
                    invisible="approval_approved or not approval_required"/>

            </xpath>

            <xpath expr="//sheet" position="inside">

                <group string="Approval">

                    <field name="approval_required" readonly="1"/>

                    <field name="approval_approved" readonly="1"/>

                    <field name="approval_reason" readonly="1"/>

                </group>

            </xpath>

        </field>

    </record>

</odoo>
