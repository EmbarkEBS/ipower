<odoo>

    <record id="sale_approval_settings_form"
            model="ir.ui.view">

        <field name="name">sale.approval.settings.form</field>
        <field name="model">sale.approval.settings</field>

        <field name="arch" type="xml">
            <form>
                <sheet>

                    <group>

                        <field name="approval_manager_id"/>

                        <field name="min_markup"/>

                        <field name="max_order_value"/>

                    </group>

                </sheet>
            </form>
        </field>

    </record>

    <record id="sale_approval_settings_action"
            model="ir.actions.act_window">

        <field name="name">Approval Settings</field>
        <field name="res_model">sale.approval.settings</field>
        <field name="view_mode">list,form</field>

    </record>

    <menuitem
        id="menu_sale_approval_settings"
        name="Approval Settings"
        parent="sale.menu_sale_config"
        action="sale_approval_settings_action"
        sequence="99"/>

</odoo>
