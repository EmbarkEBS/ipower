<odoo>

<template id="purchase_order_template">

<t t-call="web.html_container">
<meta charset="UTF-8"/>
<t t-foreach="docs" t-as="o">

<!-- ✅ SAFE CURRENCY SYMBOL -->
<t t-set="cur_symbol"
   t-value="'&#8364;' if o.currency_id.name == 'EUR' else o.currency_id.symbol"/>

<main>
<div class="page" style=" padding:10px 40px 40px 40px;
                            font-size:11px;
                            color:#333;
                            line-height:1.4;  font-family: Helvetica, Arial, sans-serif !important;">

    <!-- HEADER -->
    <table style="
                                width:100%;
                                border-collapse:collapse;
                                margin-bottom:20px;
                            ">

                                <tr>

                                    <!-- COMPANY -->
                                    <td style="
                                        width:60%;
                                        vertical-align:top;
                                    ">

                                        <img t-if="o.company_id.logo"
                                             t-att-src="image_data_uri(o.company_id.logo)"
                                             style="
                                                max-height:80px;
                                                margin-bottom:10px;
                                                margin-left:-30px;
                                             "/>

                                        <div style="
                                            font-size:13px;
                                            line-height:1.7;
                                        ">

                                            <strong style="
                                                color:#1a3a5a;
                                                font-size:15px;
                                            ">
                                                <span t-esc="o.company_id.name"/>
                                            </strong>

                                            <br/>

                                            <span t-esc="o.company_id.street or ''"/>,

                                          
                                           
                                            <t t-if="o.company_id.state_id">
                                                 <span t-esc="o.company_id.state_id.name"/>
                                            </t>

                                            <br/>

                                            <span t-esc="o.company_id.country_id.name or ''"/>

                                            <br/>

                                        <p  style="margin-top:15px"> <strong>  TRN <span t-esc="o.company_id.vat or ''"/></strong></p>

                                        </div>

                                    </td>

                                    <!-- PURCHASE ORDER -->
                                    <td style="
                                        width:40%;
                                        vertical-align:top;
                                        text-align:right;
                                    ">

                                        <h1 style="
                                            margin:0;
                                            font-size:28px;
                                            font-weight:bold;
                                            color:#000;
                                            margin-top:20px;
                                        ">
                                            PURCHASE ORDER
                                        </h1>

                                        <!-- ORANGE LINE -->
                                       <!-- CENTER POLYGON LINE -->
<div style="
    width:220px;
    margin:5px auto;
">

<svg width="220"
     height="2"
     xmlns="http://www.w3.org/2000/svg">

    <defs>

        <!-- HORIZONTAL ORANGE FADE -->
        <linearGradient id="horizontalFade"
                        x1="0%"
                        y1="0%"
                        x2="100%"
                        y2="0%">

            <stop offset="0%"
                  stop-color="#f39223"
                  stop-opacity="1"/>

            <stop offset="100%"
                  stop-color="#f39223"
                  stop-opacity="0"/>

        </linearGradient>

    </defs>

    <rect x="0"
          y="0"
          width="220"
          height="2"
          fill="url(#horizontalFade)"/>

</svg>

</div>
                                        <div style="
                                            font-size:16px;
                                            text-align:center;
                                        ">

                                            #
                                            <span t-esc="'IP/PO/' + str(o.date_order.year)[-2:] + '/' + '%03d' % o.id"/>

                                        </div>

                                    </td>

                                </tr>

                            </table>

    <!-- SHIPPING + PO DETAILS -->
                       <t t-if="o.partner_id.state_id">
                                                         <span t-esc="o.partner_id.state_id.name"/>
                                                    </t>

                                                    -

                                                    <span t-esc="o.partner_id.country_id.name or ''"/>

                                                    <br/>

                                                  <t t-if="o.partner_id.vat">
<p  style="margin-top:15px"><strong >    TRN <span t-esc="o.partner_id.vat"/></strong></p>
</t>

                                                </td>

                                            </tr>

                                        </table>

                                    </td>

                                    <!-- META -->
                                    <td style="
                                        width:45%;
                                        vertical-align:top;
                                        padding-left:40px;
                                    ">

                                        <table style="
                                            width:100%;
                                            border-collapse:collapse;
                                        ">

                                            <tr>

                                                <td style="
                                                    padding:4px 0;
                                                    width:45%;
                                                    font-weight:bold;
                                                    color:#1a3a5a;
                                                ">
                                                    Order Date
                                                </td>

                                                <td style="padding:4px 0;">

                                                    :
                                                    <span t-field="o.date_order"
                                                          t-options='{"format": "dd MMMM yyyy"}'/>

                                                </td>

                                            </tr>

                                            <tr>

                                                <td style="
                                                    padding:4px 0;
                                                    font-weight:bold;
                                                    color:#1a3a5a;
                                                ">
                                                    Payment Terms
                                                </td>

                                                <td style="padding:4px 0;">

                                                    :
                                                    <span t-field="o.payment_term_id.name"/>

                                                </td>
                                                </tr>
                                            

                                            <tr>

                                                <td style="
                                                    padding:4px 0;
                                                    font-weight:bold;
                                                    color:#1a3a5a;
                                                ">
                                               Incoterms
                                                </td>

                                                <td style="padding:4px 0;text-align:left">

                                                    :
                                                    <span t-field="o.partner_id.x_studio_incoterm.code"/>

                                                </td>

                                            </tr>

                                            <tr>

                                                <td style="
                                                    padding:4px 0;
                                                    font-weight:bold;
                                                    color:#1a3a5a;
                                                ">
                                                    Our Ref
                                                </td>

                                                <td style="padding:4px 0;">

                                                    :
                                                    <span t-field="o.origin"/>

                                                </td>

                                            </tr>

                                        </table>

                                    </td>

                                </tr>

                            </table>
    <!-- LINE HEADER -->
    <table style="width:100%; margin-top:20px; background-color:#fff5e6;">
        <tr>
            <th style="width:5%;">S.No</th>
            <th style="width:45%;">Description</th>
            <th style="width:10%; text-align:center;">Qty</th>
           <th style="width:15%; text-align:right;">Unit Price</th>
            <th style="width:15%; text-align:right;">Total Price</th>
        </tr>
    </table>

    <!-- LINES -->
    <t t-set="i" t-value="0"/>
    <t t-foreach="o.order_line" t-as="line">
        <t t-set="i" t-value="i+1"/>

        <table style="width:100%; margin-top:4px;">
            <tr>
                <td style="width:5%;" t-esc="i"/>

                <td style="width:45%;">
                    <span t-esc="line.name"/>
                </td>

                <td style="width:10%; text-align:center;">
                   <span t-esc="int(round(line.product_qty))"/>
                </td>

              <!-- <td style="width:10%; text-align:center;">
                    <t t-set="seller" t-value="line.product_id.seller_ids.filtered(lambda s: s.partner_id == o.partner_id)[:1]"/>
                    <t t-if="seller">
                        <span t-esc="seller.delay"/>
                    </t>
                </td>--> 

                <!-- ✅ SAFE CURRENCY -->
              <td style="width:15%; text-align:right;">
    <span t-esc="'%.2f' % line.price_unit"/>
</td>

<td style="width:15%; text-align:right;">
    <span t-esc="'%.2f' % line.price_subtotal"/>
</td>
            </tr>

            <tr>
                <td></td>
                <td colspan="5">
                    <small t-esc="line.product_id.description or ''"/>
                    <div>
                        <strong>
                            <span t-field="line.x_studio_related_field_2fu_1jmn8bvrv"/>
                        </strong>
                    </div>
                </td>
            </tr>
        </table>
    </t>
<!-- SHIPPING DETAILS (ONLY FOR FREIGHT FORWARDER) -->
<t t-if="o.partner_id.category_id.filtered(lambda c: c.name == 'Freight Forwarders')">

    <div style="margin-top:20px;">
        <strong style="font-size:14px;">Shipping Details</strong>

        <table style="width:100%; margin-top:8px; border:1px solid #000; border-collapse:collapse;">

            <tr>
                <td style="border:1px solid #000; padding:6px; width:40%;">
                    <strong>Weight (kg)</strong>
                </td>
                <td style="border:1px solid #000; padding:6px;">
                    <span t-esc="o.x_studio_weightkg_1 or ''"/>
                </td>
            </tr>

            <tr>
                <td style="border:1px solid #000; padding:6px;">
                    <strong>Dimensions</strong>
                </td>
                <td style="border:1px solid #000; padding:6px;">
                    <span t-esc="o.x_studio_dimensions_1 or ''"/>
                </td>
            </tr>

            <tr>
                <td style="border:1px solid #000; padding:6px;">
                    <strong>Pickup Address</strong>
                </td>
                <td style="border:1px solid #000; padding:6px;">
                    <span t-esc="o.x_studio_pickup_address or ''"/>
                </td>
            </tr>

            <tr>
                <td style="border:1px solid #000; padding:6px;">
                    <strong>Delivery Location</strong>
                </td>
                <td style="border:1px solid #000; padding:6px;">
                    <span t-esc="o.x_studio_delivery_location or ''"/>
                </td>
            </tr>

            <tr>
                <td style="border:1px solid #000; padding:6px;">
                    <strong>Instructions</strong>
                </td>
                <td style="border:1px solid #000; padding:6px;">
                    <span t-esc="o.x_studio_special_instructions or ''"/>
                </td>
            </tr>

        </table>
    </div>

</t>
    <!-- TOTAL -->
    <table style="width:100%; margin-top:20px;">
    <tr>

        <!-- LEFT: AMOUNT IN WORDS -->
        <td style="width:60%;">
            <strong>Amount in Words:</strong><br/>
            <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/> Only
        </td>

        <!-- RIGHT: TOTAL BOX -->
        <td style="width:40%; text-align:right;">

            <div style="width:220px; margin-left:auto;">

                <!-- TOP BORDER (SUBTOTAL START) -->
                <div style="border-top:1px solid #000; padding-top:5px;">
                    Subtotal :
                    <span t-raw="cur_symbol + ' ' + ('%.2f' % o.amount_untaxed)"/>
                </div>

                <!-- TAX -->
                <div style="padding:3px 0;">
                    Tax :
                    <span t-raw="cur_symbol + ' ' + ('%.2f' % o.amount_tax)"/>
                </div>

                <!-- BOTTOM BORDER (AFTER TAX) -->
                <div style="border-bottom:1px solid #000; margin-bottom:5px;"></div>

                <!-- TOTAL -->
                <div style="font-weight:bold;">
                    Total :
                    <span t-raw="cur_symbol + ' ' + ('%.2f' % o.amount_total)"/>
                </div>

            </div>

        </td>

    </tr>
</table>
 <p t-field="o.note" class="mt-4"/>
    <!-- FOOTER -->
    <div style="position: fixed;
    bottom: 0;
    left: 20px;
    right: 20px;
    text-align: center;
    border-top: 1px solid #aaa;
    padding-top: 25px;
    font-size: 10px;">
        
        <strong t-esc="o.company_id.name"/> |
        <span t-esc="o.company_id.partner_id.street or ''"/> ,
        <span t-esc="o.company_id.partner_id.city or ''"/> ,
        <span t-esc="o.company_id.partner_id.country_id.name or ''"/>

    </div>

</div>
</main>

</t>
</t>

</template>

</odoo>