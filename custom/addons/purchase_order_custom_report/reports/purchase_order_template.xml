<odoo>
    <template id="purchase_order_template">
        <t t-call="web.html_container">
            <meta charset="UTF-8"/>
            <t t-foreach="docs" t-as="o">
                <main>
                    <div class="page" style="padding:10px 40px; font-family: sans-serif; font-size:12px; color: #333;">
                        
                        <!-- HEADER: LOGO AND COMPANY INFO -->
                        <table style="width:100%; border-bottom: 2px solid #eee; padding-bottom: 10px;">
                            <tr>
                                <td style="width:50%;">
                                    <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="width:80%;height:100px;margin-left:-30px"/>
                                    <div style="margin-top:10px;">
                                        <strong><span style="padding: 2px; font-size: 14px; font-weight: bold; color: #385580;" t-esc="o.company_id.name"/></strong><br/>
                                        <span t-esc="o.company_id.partner_id.street"/><br/>
                                        <span t-esc="o.company_id.partner_id.city"/>, <span t-esc="o.company_id.partner_id.country_id.name"/><br/>
                                        TRN: <span t-esc="o.company_id.vat"/>
                                    </div>
                                </td>
                                <td style="width:50%; text-align:right; vertical-align: top;">
                                    <h2 style="color: #000; margin-bottom: 5px; font-weight: bold;">PURCHASE ORDER</h2>
                                <p style="text-align:center;">    <span style="font-size: 14px;"># <span t-esc="'IP/PO/' + str(o.date_order.year)[-2:] + '/' + '%03d' % o.id"/></span></p>
                                </td>
                            </tr>
                        </table>

                        <!-- ADDRESSES AND META DATA -->
                        <table style="width:100%; margin-top:30px;">
                            <tr>
                                <td style="width:60%; vertical-align: top;">
                                    <strong style="color: #666;">To</strong><br/>
                                    <div style="margin-top: 5px; font-size: 13px;">
                                        <strong><span t-esc="o.partner_id.name"/></strong><br/>
                                        <span t-esc="o.partner_id.street"/><br/>
                                        <span t-esc="o.partner_id.city"/> - <span t-esc="o.partner_id.country_id.name"/><br/>
                                        TRN: <span t-esc="o.partner_id.vat"/>
                                    </div>
                                </td>
                                <td style="width:40%; vertical-align: top;">
                                    <table style="width:100%; text-align: left;">
                                        <tr>
                                            <td style="padding: 2px; font-size: 14px; font-weight: bold; color: #385580;"><strong>Order Date</strong></td>
                                            <td style="padding: 2px;">: <span t-esc="o.date_order.strftime('%d %B %Y')"/></td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 2px; font-size: 14px; font-weight: bold; color: #385580;"><strong>Incoterm</strong></td>
                                            <td style="padding: 2px;">: <span t-esc="o.payment_term_id.name"/></td>
                                        </tr>
                                         <tr>
                                            <td style="padding: 2px; font-size: 14px; font-weight: bold; color: #385580;"><strong>Sales Order</strong></td>
                                            <td style="padding: 2px;">: <span t-field="o.origin" class="m-0"/></td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 2px; font-size: 14px; font-weight: bold; color: #385580;"><strong>Shipping Terms</strong></td>
                                            <td style="padding: 2px;">: <span t-esc="o.incoterm_id.code"/></td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>

                        <!-- PRODUCT TABLE -->
                        <table style="width:100%; margin-top:30px; border-collapse: collapse;">
                            <thead>
                                <tr style="background-color: #4a4a4a; color: #ffffff;border-radius:25px;">
                                    <th style="padding: 10px; border: 1px solid #4a4a4a; text-align: center; width: 5%;">SN</th>
                                    <th style="padding: 10px; border: 1px solid #4a4a4a; width: 50%;">Description</th>
                                    <th style="padding: 10px; border: 1px solid #4a4a4a; text-align: center; width: 10%;">Qty</th>
                                    <th style="padding: 10px; border: 1px solid #4a4a4a; text-align: right; width: 15%;">Unit Price</th>
                                    <th style="padding: 10px; border: 1px solid #4a4a4a; text-align: right; width: 20%;">Total Price</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="sn" t-value="1"/>
                                <t t-foreach="o.order_line" t-as="line">
                                    <tr style="border-bottom: 1px solid #eee;">
                                        <td style="padding: 10px; text-align: center;" t-esc="sn"/>
                                        <td style="padding: 10px;">
                                            <strong><span t-esc="line.product_id.name"/></strong><br/>
                                              <strong>
                            <span t-field="line.x_studio_related_field_2fu_1jmn8bvrv"/>
                        </strong>
                                            
                   
                                        </td>
                                        <td style="padding: 10px; text-align: center;"><span t-esc="int(line.product_qty)"/></td>
                                        <td style="padding: 10px; text-align: right;"><span t-esc="'{0:,.2f}'.format(line.price_unit)"/></td>
                                        <td style="padding: 10px; text-align: right;"><span t-esc="'{0:,.2f}'.format(line.price_subtotal)"/></td>
                                 
                   
                      
                                    </tr>
                                    
                                    <t t-set="sn" t-value="sn + 1"/>
                                </t>
                                  <small t-esc="line.product_id.description or ''"/><br/>
                            </tbody>
                        </table>

                        <!-- TOTALS SECTION -->
                        <table style="width:100%; margin-top:20px;">
                            <tr>
                                <td style="width:60%; vertical-align: bottom;">
                                    <div style="margin-bottom: 10px;">
                                        <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/> only.
                                    </div>
    <div style="border-top: 1px solid #ccc; padding-top: 5px;">
    <strong>Notes:</strong><br/>
   <span t-field="o.note" class="mt-4"/>
</div>




                                </td>
                                <td style="width:40%;">
                                    <table style="width:100%; text-align: right; border-collapse: collapse;">
                                        <tr>
                                            <td style="padding: 5px;"><strong>Sub Total</strong></td>
                                            <td style="padding: 5px;"><span t-esc="'{0:,.2f}'.format(o.amount_untaxed)"/></td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 5px;"><strong>VAT (5%)</strong></td>
                                            <td style="padding: 5px;"><span t-esc="'{0:,.2f}'.format(o.amount_tax)"/></td>
                                        </tr>
                                        <tr style="font-size: 14px; font-weight: bold; color: #385580;">
                                            <td style="padding: 10px 5px; border-top: 2px solid #385580;">Total</td>
                                            <td style="padding: 10px 5px; border-top: 2px solid #385580;">
                                                <span t-esc="o.currency_id.name"/> <span t-esc="'{0:,.2f}'.format(o.amount_total)"/>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>
   <!-- FOOTER -->
    <div style="position: fixed;
    bottom: 0;
    left: 20px;
    right: 20px;
    text-align: center;
    border-top: 1px solid #aaa;
    padding-top: 25px;
    font-size: 10px;">
        
        <strong t-esc="o.company_id.name"/> |
        <span t-esc="o.company_id.partner_id.street or ''"/> ,
        <span t-esc="o.company_id.partner_id.city or ''"/> ,
        <span t-esc="o.company_id.partner_id.country_id.name or ''"/>

    </div>
                    </div>
                </main>
            </t>
        </t>
    </template>
</odoo>
