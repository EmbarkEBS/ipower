<odoo>
    <template id="purchase_order_template">
        <t t-call="web.html_container">
            <meta charset="UTF-8"/>
            <t t-foreach="docs" t-as="o">
                <main>
                    <div class="page" style="padding:10px 40px; font-family: sans-serif; font-size:12px; color: #333; line-height: 1.4;">
                        
                        <!-- HEADER: LOGO AND COMPANY INFO -->
                        <table style="width:100%; margin-bottom: 20px;">
                            <tr>
                                <td style="width:60%; vertical-align: top;">
                                    <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-height: 80px; margin-bottom: 10px;margin-left:-30px"/>
                                    <div style="font-size: 13px;">
                                        <strong style="color: #1a3a5a; font-size: 15px;"><span t-esc="o.company_id.name"/></strong><br/>
                                        <span t-field="o.company_id.partner_id" t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>
                                        TRN <span t-esc="o.company_id.vat"/>
                                    </div>
                                </td>
                                <td style="width:40%; text-align:right; vertical-align: top;">
                                    <h1 style="color: #000; margin: 0; font-size: 28px; font-weight: bold; letter-spacing: 1px;">PURCHASE ORDER</h1>
                                    <div style="height: 2px; width: 100%; background: linear-gradient(to left, #f39223, rgba(255,255,255,0)); margin-top: 5px; margin-bottom: 5px;"/>
                                    <div style="font-size: 16px; margin-top: 5px;text-align:center"># <span t-esc="'IP/PO/' + str(o.date_order.year)[-2:] + '/' + '%03d' % o.id"/></div>
                                </td>
                            </tr>
                        </table>

                        <!-- ADDRESSES AND META DATA -->
                        <table style="width:100%; margin-top:40px; margin-bottom: 40px;">
                            <tr>
                                <td style="width:55%; vertical-align: top;">
                                <div style="float: left; width: 3px; height: 70px; background: linear-gradient(to bottom, #1a3a5a, rgba(255,255,255,0)); margin-right: 15px;"/>
            
            <div style="overflow: hidden;"> 
                                    <strong style="color: #1a3a5a; font-size: 13px;">To</strong><br/>
                                    <div style="margin-top: 5px; font-size: 13px; line-height: 1.5;">
                                        <strong><span t-esc="o.partner_id.name"/></strong><br/>
                                        <span t-field="o.partner_id" t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/><br/>
                                        TRN <span t-esc="o.partner_id.vat"/>
                                    </div></div>
                                </td>
                                <td style="width:65%; vertical-align: top;">
                                    <table style="width:100%; border-collapse: collapse;">
                                        <tr>
                                            <td style="padding: 3px 0; font-weight: bold; color: #1a3a5a; width: 45%;">Order Date</td>
                                            <td style="padding: 3px 0;">: <span t-field="o.date_order" t-options='{"format": "dd MMMM yyyy"}'/></td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 3px 0; font-weight: bold; color: #1a3a5a;">Incoterm</td>
                                            <td style="padding: 3px 0;">: <span t-field="o.payment_term_id.name"/></td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 3px 0; font-weight: bold; color: #1a3a5a;">Shipping Terms</td>
                                            <td style="padding: 3px 0;">: <span t-field="o.incoterm_id.name"/></td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 3px 0; font-weight: bold; color: #1a3a5a;">Sales Order</td>
                                            <td style="padding: 3px 0;">: <span t-field="o.origin" class="m-0"/></td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>

                        <!-- PRODUCT TABLE -->
                        <table style="width:100%; border-collapse: collapse; margin-bottom: 20px;">
                            <thead>
                                <tr style="background-color: #4b4b4b; color: #ffffff;">
                                    <th style="padding: 10px; text-align: center; width: 8%; border-top-left-radius: 5px; border-bottom-left-radius: 5px;">SN</th>
                                    <th style="padding: 10px; text-align: left; width: 42%;">Description</th>
                                    <th style="padding: 10px; text-align: center; width: 10%;">Qty</th>
                                    <th style="padding: 10px; text-align: right; width: 15%;">Unit Price</th>
                                    <th style="padding: 10px; text-align: right; width: 25%; border-top-right-radius: 5px; border-bottom-right-radius: 5px;">Total Price</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="sn" t-value="1"/>
                                <t t-foreach="o.order_line" t-as="line">
                                    <tr>
                                        <td style="padding: 12px 10px; text-align: center; vertical-align: top;" t-esc="sn"/>
                                        <td style="padding: 12px 10px; vertical-align: top;">
                                            <div style="font-weight: bold; margin-bottom: 5px;"><span t-field="line.product_id.display_name"/></div>
                                            <div style="color: #666; font-size: 11px;"><small t-esc="line.product_id.description or ''"/></div>
                                        </td>
                                        <td style="padding: 12px 10px; text-align: center; vertical-align: top;"><span t-esc="int(line.product_qty)"/></td>
                                        <td style="padding: 12px 10px; text-align: right; vertical-align: top;"><span t-field="line.price_unit"/></td>
                                        <td style="padding: 12px 10px; text-align: right; vertical-align: top;"><span t-field="line.price_subtotal"/></td>
                                    </tr>
                                    <t t-set="sn" t-value="sn + 1"/>
                                </t>
                            </tbody>
                        </table>

                        <!-- TOTALS SECTION -->
                        <table style="width:100%; margin-top:10px;">
                            <tr>
                                <td style="width:55%; vertical-align: middle; padding-top: 40px;">
                                    <div style="font-size: 13px;">
                                        <strong>AED <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/> only.</strong>
                                    </div>
                                </td>
                                <td style="width:45%;">
                                    <table style="width:100%; text-align: right;">
                                        <tr>
                                            <td style="padding: 5px; font-weight: bold; width: 50%;">Sub Total</td>
                                            <td style="padding: 5px; width: 50%;"><span t-field="o.amount_untaxed"/></td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 5px; font-weight: bold;">VAT (5%)</td>
                                            <td style="padding: 5px;"><span t-field="o.amount_tax"/></td>
                                        </tr>
                                        <tr style="font-size: 16px; color: #1a3a5a;">
                                            <td style="padding: 10px 5px; font-weight: bold;">Total</td>
                                            <td style="padding: 10px 5px; font-weight: bold;">
                                                <span t-field="o.currency_id.name"/> <span t-field="o.amount_total"/>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>

                        <!-- NOTES -->
                        <div style="margin-top: 80px;">
                            <strong style="font-size: 14px; border-bottom: 1px solid #333; padding-bottom: 2px;">Notes</strong>
                            <div style="margin-top: 10px; color: #555;">
                                <t t-if="o.note">
                                    <span t-field="o.note"/>
                                </t>
                                <t t-else="">
                                    <i class="fa fa-circle" style="font-size: 8px; color: #1a3a5a; margin-right: 5px;"/> Thanks for giving us the opportunity to serve you
                                </t>
                            </div>
                        </div>

                        <!-- FOOTER INFO -->
                        <div style="position: absolute; bottom: 20px; left: 40px; right: 40px; font-size: 10px; color: #666; border-top: 1px solid #eee; padding-top: 10px; text-align: left;">
                            <div t-field="o.company_id.report_footer"/>
                            <div style="margin-top: 5px;">
                                <span t-esc="o.company_id.street"/>, <span t-esc="o.company_id.city"/> - <span t-esc="o.company_id.country_id.name"/> | 
                                CR No: <span t-esc="o.company_id.company_registry or 'N/A'"/> | <span t-esc="o.company_id.email"/> | <span t-esc="o.company_id.website"/>
                            </div>
                        </div>
                    </div>
                </main>
            </t>
        </t>
    </template>
</odoo>
