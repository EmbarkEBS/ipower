<odoo>
    <template id="purchase_order_template">

        <t t-call="web.html_container">
            <meta charset="UTF-8"/>

            <t t-foreach="docs" t-as="o">

                <main>

                    <div class="page">

                        <!-- MAIN CONTENT WRAPPER -->
                        <div style="
                            padding:10px 40px 40px 40px;
                            font-family:sans-serif;
                            font-size:12px;
                            color:#333;
                            line-height:1.4;
                        ">

                            <!-- ===================================================== -->
                            <!-- HEADER -->
                            <!-- ===================================================== -->

                            <table style="
                                width:100%;
                                border-collapse:collapse;
                                margin-bottom:20px;
                            ">

                                <tr>

                                    <!-- COMPANY -->
                                    <td style="
                                        width:60%;
                                        vertical-align:top;
                                    ">

                                        <img t-if="o.company_id.logo"
                                             t-att-src="image_data_uri(o.company_id.logo)"
                                             style="
                                                max-height:80px;
                                                margin-bottom:10px;
                                                margin-left:-30px;
                                             "/>

                                        <div style="
                                            font-size:13px;
                                            line-height:1.7;
                                        ">

                                            <strong style="
                                                color:#1a3a5a;
                                                font-size:15px;
                                            ">
                                                <span t-esc="o.company_id.name"/>
                                            </strong>

                                            <br/>

                                            <span t-esc="o.company_id.street or ''"/>

                                            <t t-if="o.company_id.street2">
                                                <br/>
                                                <span t-esc="o.company_id.street2"/>
                                            </t>

                                            <br/>

                                            <span t-esc="o.company_id.city or ''"/>

                                            <t t-if="o.company_id.state_id">
                                                , <span t-esc="o.company_id.state_id.name"/>
                                            </t>

                                            <br/>

                                            <span t-esc="o.company_id.country_id.name or ''"/>

                                            <br/>

                                            TRN <span t-esc="o.company_id.vat or ''"/>

                                        </div>

                                    </td>

                                    <!-- PURCHASE ORDER -->
                                    <td style="
                                        width:40%;
                                        vertical-align:top;
                                        text-align:right;
                                    ">

                                        <h1 style="
                                            margin:0;
                                            font-size:28px;
                                            font-weight:bold;
                                            color:#000;
                                        ">
                                            PURCHASE ORDER
                                        </h1>

                                        <!-- ORANGE LINE -->
                                       <!-- CENTER POLYGON LINE -->
<div style="
    width:140px;
    height:12px;
    margin-top:10px;
    margin-bottom:10px;
    margin-left:auto;
    margin-right:auto;
">

 <svg width="220"
     height="2"
     viewBox="0 0 220 2"
     xmlns="http://www.w3.org/2000/svg">

    <!-- ORANGE FIRST -->
    <polygon points="0,0 190,0 188,2 0,2"
             fill="#e58b39"/>

    <!-- GREY SECOND -->
    <polygon points="190,0 220,0 220,2 188,2"
             fill="#d9d9d9"/>

</svg>

</div>

                                        <div style="
                                            font-size:16px;
                                            text-align:center;
                                        ">

                                            #
                                            <span t-esc="'IP/PO/' + str(o.date_order.year)[-2:] + '/' + '%03d' % o.id"/>

                                        </div>

                                    </td>

                                </tr>

                            </table>

                            <!-- ===================================================== -->
                            <!-- ADDRESS + META -->
                            <!-- ===================================================== -->

                            <table style="
                                width:100%;
                                border-collapse:collapse;
                                margin-top:35px;
                                margin-bottom:35px;
                            ">

                                <tr>

                                    <!-- ADDRESS -->
                                    <td style="
                                        width:55%;
                                        vertical-align:top;
                                    ">

                                        <table style="
                                            width:100%;
                                            border-collapse:collapse;
                                        ">

                                            <tr>

                                                <!-- ORANGE BORDER -->
                                                <td style="
                                                    height:80%;
                                                    width:1px;
                                                    background:#f39223;
                                                    padding:0;
                                                ">
                                                </td>

                                                <td style="
                                                    height:10%;
                                                    width:1px;
                                                    background:#f7d7b5;
                                                    padding:0;
                                                ">
                                                </td>

                                                <td style="width:15px;">
                                                </td>

                                                <!-- ADDRESS CONTENT -->
                                                <td style="
                                                    vertical-align:top;
                                                    font-size:13px;
                                                    line-height:1.7;
                                                ">

                                                    <strong style="color:#1a3a5a;">
                                                        To
                                                    </strong>

                                                    <br/>

                                                    <strong>
                                                        <span t-esc="o.partner_id.name"/>
                                                    </strong>

                                                    <br/>

                                                    <span t-esc="o.partner_id.street or ''"/>

                                                    <t t-if="o.partner_id.street2">
                                                        <br/>
                                                        <span t-esc="o.partner_id.street2"/>
                                                    </t>

                                                    <br/>

                                                    <span t-esc="o.partner_id.city or ''"/>

                                                    <t t-if="o.partner_id.state_id">
                                                        , <span t-esc="o.partner_id.state_id.name"/>
                                                    </t>

                                                    <br/>

                                                    <span t-esc="o.partner_id.country_id.name or ''"/>

                                                    <br/>

                                                    TRN <span t-esc="o.partner_id.vat or ''"/>

                                                </td>

                                            </tr>

                                        </table>

                                    </td>

                                    <!-- META -->
                                    <td style="
                                        width:45%;
                                        vertical-align:top;
                                        padding-left:40px;
                                    ">

                                        <table style="
                                            width:100%;
                                            border-collapse:collapse;
                                        ">

                                            <tr>

                                                <td style="
                                                    padding:4px 0;
                                                    width:45%;
                                                    font-weight:bold;
                                                    color:#1a3a5a;
                                                ">
                                                    Order Date
                                                </td>

                                                <td style="padding:4px 0;">

                                                    :
                                                    <span t-field="o.date_order"
                                                          t-options='{"format": "dd MMMM yyyy"}'/>

                                                </td>

                                            </tr>

                                            <tr>

                                                <td style="
                                                    padding:4px 0;
                                                    font-weight:bold;
                                                    color:#1a3a5a;
                                                ">
                                                    Incoterm
                                                </td>

                                                <td style="padding:4px 0;">

                                                    :
                                                    <span t-field="o.payment_term_id.name"/>

                                                </td>

                                            </tr>

                                            <tr>

                                                <td style="
                                                    padding:4px 0;
                                                    font-weight:bold;
                                                    color:#1a3a5a;
                                                ">
                                                    Shipping Terms
                                                </td>

                                                <td style="padding:4px 0;">

                                                    :
                                                    <span t-field="o.incoterm_id.name"/>

                                                </td>

                                            </tr>

                                            <tr>

                                                <td style="
                                                    padding:4px 0;
                                                    font-weight:bold;
                                                    color:#1a3a5a;
                                                ">
                                                    Sales Order
                                                </td>

                                                <td style="padding:4px 0;">

                                                    :
                                                    <span t-field="o.origin"/>

                                                </td>

                                            </tr>

                                        </table>

                                    </td>

                                </tr>

                            </table>

                            <!-- ===================================================== -->
                            <!-- PRODUCT TABLE -->
                            <!-- ===================================================== -->

                            <table style="
                                width:100%;
                                border-collapse:collapse;
                                margin-bottom:20px;
                            ">

                                <thead>

                                    <tr style="
                                        background:#4b4b4b;
                                        color:#fff;
                                    ">

                                        <th style="
                                            padding:10px;
                                            width:5%;
                                            text-align:center;
                                            border-top-left-radius:10px;
                                            border-bottom-left-radius:10px;
                                        ">
                                            SN
                                        </th>

                                        <th style="
                                            padding:10px;
                                            width:55%;
                                            text-align:left;
                                        ">
                                            Description
                                        </th>

                                        <th style="
                                            padding:10px;
                                            width:7%;
                                            text-align:center;
                                        ">
                                            Qty
                                        </th>

                                        <th style="
                                            padding:10px;
                                            width:11%;
                                            text-align:right;
                                        ">
                                            Unit Price
                                        </th>

                                        <th style="
                                            padding:10px;
                                            width:12%;
                                            text-align:right;
                                            border-top-right-radius:10px;
                                            border-bottom-right-radius:10px;
                                        ">
                                            Total Price
                                        </th>

                                    </tr>

                                </thead>

                                <tbody>

                                    <t t-set="sn" t-value="1"/>

                                    <t t-foreach="o.order_line" t-as="line">

                                        <tr style="border-bottom:1px solid #d9d9d9;">

                                            <!-- SN -->
                                            <td style="
                                                padding:14px 10px;
                                                text-align:center;
                                                vertical-align:top;
                                            ">
                                                <span t-esc="sn"/>
                                            </td>

                                            <!-- DESCRIPTION -->
                                            <td style="
                                                padding:14px 10px;
                                                vertical-align:top;
                                                width:55%;
                                                white-space:normal;
                                                word-break:break-word;
                                            ">

                                                <div style="
                                                    font-weight:bold;
                                                    margin-bottom:6px;
                                                    font-size:13px;
                                                    line-height:1.5;
                                                    width:100%;
                                                ">
                                                    <span t-field="line.product_id.display_name"/>
                                                </div>

                                                <div style="
                                                    font-size:11px;
                                                    color:#666;
                                                    line-height:1.7;
                                                    width:100%;
                                                    display:block;
                                                    white-space:normal;
                                                    word-break:break-word;
                                                ">

                                                    <span t-esc="line.product_id.description or ''"/>

                                                </div>

                                            </td>

                                            <!-- QTY -->
                                            <td style="
                                                padding:14px 10px;
                                                text-align:center;
                                                vertical-align:top;
                                            ">
                                                <span t-esc="int(line.product_qty)"/>
                                            </td>

                                            <!-- UNIT PRICE -->
                                            <td style="
                                                padding:14px 10px;
                                                text-align:right;
                                                vertical-align:top;
                                            ">
                                                <span t-esc="'{:,.2f}'.format(line.price_unit)"/>
                                            </td>

                                            <!-- TOTAL -->
                                            <td style="
                                                padding:14px 10px;
                                                text-align:right;
                                                vertical-align:top;
                                            ">
                                                <span t-esc="'{:,.2f}'.format(line.price_subtotal)"/>
                                            </td>

                                        </tr>

                                        <t t-set="sn" t-value="sn + 1"/>

                                    </t>

                                </tbody>

                            </table>

                            <!-- ===================================================== -->
                            <!-- TOTALS -->
                            <!-- ===================================================== -->

                            <table style="
                                width:100%;
                                margin-top:20px;
                                border-collapse:collapse;
                            ">

                                <tr>

                                    <td style="
                                        width:55%;
                                        vertical-align:middle;
                                        padding-top:40px;
                                    ">

                                        <div style="font-size:13px;">

                                            <strong>

                                                <span t-esc="o.currency_id.name"/>
                                                <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/>
                                                only.

                                            </strong>

                                        </div>

                                    </td>

                                    <td style="width:45%;">

                                        <table style="
                                            width:100%;
                                            border-collapse:collapse;
                                            text-align:right;
                                        ">

                                            <tr>

                                                <td style="
                                                    padding:5px;
                                                    font-weight:bold;
                                                ">
                                                    Sub Total
                                                </td>

                                                <td style="padding:5px;">

                                                    <span t-esc="'{:,.2f}'.format(o.amount_untaxed)"/>

                                                </td>

                                            </tr>

                                            <tr>

                                                <td style="
                                                    padding:5px;
                                                    font-weight:bold;
                                                ">
                                                    VAT (5%)
                                                </td>

                                                <td style="padding:5px;">

                                                    <span t-esc="'{:,.2f}'.format(o.amount_tax)"/>

                                                </td>

                                            </tr>

                                            <tr style="
                                                font-size:16px;
                                                color:#1a3a5a;
                                            ">

                                                <td style="
                                                    padding:10px 5px;
                                                    font-weight:bold;
                                                ">
                                                    Total
                                                </td>

                                                <td style="
                                                    padding:10px 5px;
                                                    font-weight:bold;
                                                ">

                                                    <span t-esc="o.currency_id.name"/>
                                                    <span t-esc="'{:,.2f}'.format(o.amount_total)"/>

                                                </td>

                                            </tr>

                                        </table>

                                    </td>

                                </tr>

                            </table>

                            <!-- ===================================================== -->
                            <!-- NOTES -->
                            <!-- ===================================================== -->

                            <div style="margin-top:60px;">

                                <strong style="
                                    font-size:14px;
                                    border-bottom:1px solid #333;
                                    padding-bottom:2px;
                                ">
                                    Notes
                                </strong>

                                <div style="
                                    margin-top:10px;
                                    color:#555;
                                ">

                                    <t t-if="o.note">
                                        <span t-field="o.note"/>
                                    </t>

                                    <t t-else="">
                                        Thanks for giving us the opportunity to serve you
                                    </t>

                                </div>

                            </div>

                        </div>

                        <!-- ===================================================== -->
                        <!-- FOOTER -->
                        <!-- ===================================================== -->

                        <div class="footer" style="
                            font-family:sans-serif;
                            margin:0;
                            padding:0;
                            width:100%;
                        ">

                            <!-- FOOTER CONTENT -->
                            <table style="
                                width:100%;
                                border-collapse:collapse;
                                font-size:10px;
                                color:#555; border-top:1px solid #1f3b73;
    padding-top:6px;  margin-left:-40px;
    margin-right:-40px;
                            ">

                                <tr>

                                    <td style="
                                        padding:20px 40px;
                                        text-align:left;
                                    ">

                                        Office:
                                        <span t-esc="o.company_id.street or ''"/>

                                        <t t-if="o.company_id.street2">
                                            , <span t-esc="o.company_id.street2"/>
                                        </t>

                                        ,
                                        <span t-esc="o.company_id.city or ''"/>

                                        -
                                        <span t-esc="o.company_id.country_id.name or ''"/>

                                        <br/>

                                        CR No:
                                        <span t-esc="o.company_id.company_registry or 'N/A'"/>

                                        |

                                        <span t-esc="o.company_id.email or ''"/>

                                        |

                                        <span t-esc="o.company_id.website or ''"/>

                                    </td>

                                </tr>

                            </table>

                          
                           <!-- FULL WIDTH FOOTER BORDER -->
<div style="
    width:auto;
    height:25px;
    overflow:hidden;
    margin-top:5px;
    margin-left:-40px;
    margin-right:-40px;
">

    <svg width="100%"
         height="25"
         viewBox="0 0 1000 25"
         preserveAspectRatio="none"
         xmlns="http://www.w3.org/2000/svg">

        <!-- BLUE 25% -->
        <polygon points="0,0 260,0 240,25 0,25"
                 fill="#1f3b73"/>

        <!-- ORANGE 75% -->
        <polygon points="260,0 1000,0 1000,25 240,25"
                 fill="#e58b39"/>

    </svg>

</div>
                        </div>

                    </div>

                </main>

            </t>

        </t>

    </template>
</odoo>