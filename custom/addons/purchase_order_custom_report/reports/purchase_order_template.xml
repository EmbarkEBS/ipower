<odoo>

<template id="purchase_order_template">

<t t-call="web.html_container">
<t t-foreach="docs" t-as="o">

<main>
<div class="page" style="padding:10px 20px 60px 20px; font-size:12px; line-height:1.4; position:relative; min-height:1000px;">

    <!-- ================= HEADER ================= -->
    <table style="width:100%;">
        <tr>
            <td style="width:60%; vertical-align:top;">
                
                <!-- Company Name -->
                <strong style="font-size:13px;">
                    <span t-esc="o.company_id.name"/>
                </strong><br/>

                <!-- FULL ADDRESS (WITH PO BOX, NO DUPLICATE NAME) -->
                <span t-esc="o.company_id.partner_id.street or ''"/><br/>
                <span t-esc="'PO Box ' + (o.company_id.partner_id.zip or '') if o.company_id.partner_id.zip else ''"/><br/>
                <span t-esc="o.company_id.partner_id.city or ''"/>
                <span t-esc="', ' + o.company_id.partner_id.country_id.name if o.company_id.partner_id.country_id else ''"/>

            </td>

            <td style="width:40%; text-align:right;">
                <img t-if="o.company_id.logo"
                     t-att-src="image_data_uri(o.company_id.logo)"
                     style="height:60px;"/>
            </td>
        </tr>
    </table>

    <!-- ================= 2 COLUMN (UPDATED) ================= -->
    <table style="width:100%; margin-top:20px;">
        <tr>

            <!-- SHIPPING LEFT -->
            <td style="width:50%; vertical-align:top;">
                <strong>Shipping</strong><br/>
                <span t-esc="(o.dest_address_id or o.partner_id).name"/><br/>
                <span t-esc="(o.dest_address_id or o.partner_id).contact_address"/>
            </td>

            <!-- PO DETAILS RIGHT -->
            <td style="width:50%; vertical-align:top;">
                <strong>Purchase Order</strong><br/><br/>

                <table style="width:100%;">
                    <tr>
                        <td style="width:45%;"><strong>PO No</strong></td>
                        <td>
                            <span t-esc="'IP/PO/' + str(o.date_order.year)[-2:] + '/' + '%03d' % o.id"/>
                        </td>
                    </tr>

                    <tr>
                        <td><strong>Order Date</strong></td>
                        <td>
                            <span t-esc="o.date_order.strftime('%d-%m-%Y') if o.date_order else ''"/>
                        </td>
                    </tr>

                    <t t-if="o.incoterm_id">
                        <tr>
                            <td><strong>Incoterm</strong></td>
                            <td><span t-esc="o.incoterm_id.code"/></td>
                        </tr>
                    </t>

                    <t t-if="o.payment_term_id">
                        <tr>
                            <td><strong>Payment Terms</strong></td>
                            <td><span t-esc="o.payment_term_id.name"/></td>
                        </tr>
                    </t>

                    <t t-if="o.origin">
                        <tr>
                            <td><strong>Sales Ref</strong></td>
                            <td><span t-esc="o.origin"/></td>
                        </tr>
                    </t>
                </table>
            </td>

        </tr>
    </table>

    <!-- ================= LINE HEADER ================= -->
    <table style="width:100%; margin-top:20px; border-bottom:1px solid black;">
        <tr>
            <th style="width:5%;">S.No</th>
            <th style="width:45%;">Description</th>
            <th style="width:10%; text-align:center;">Qty</th>
            <th style="width:10%; text-align:center;">Lead Time (Weeks)</th>
            <th style="width:15%; text-align:right;">Unit</th>
            <th style="width:15%; text-align:right;">Amount</th>
        </tr>
    </table>

    <!-- ================= LINES ================= -->
    <t t-set="i" t-value="0"/>
    <t t-foreach="o.order_line" t-as="line">
        <t t-set="i" t-value="i+1"/>

        <table style="width:100%; margin-top:4px;">
            <tr>
                <td style="width:5%;" t-esc="i"/>
                <td style="width:45%;"><span t-esc="line.name"/></td>
                <td style="width:10%; text-align:center;">
                    <span t-field="line.product_qty" t-options='{"widget":"integer"}'/>
                </td>
                <td style="width:10%; text-align:center;">
                    <t t-set="seller"
                       t-value="line.product_id.seller_ids.filtered(lambda s: s.partner_id == o.partner_id)[:1]"/>
                    <t t-if="seller">
                        <span t-esc="round(seller.delay / 7, 1)"/>
                    </t>
                </td>
                <td style="width:15%; text-align:right;">
                    <span t-esc="'%.2f' % line.price_unit"/>
                </td>
                <td style="width:15%; text-align:right;">
                    <!-- FIX EURO SYMBOL -->
                    <span t-esc="formatLang(line.price_subtotal, currency_obj=o.currency_id)"/>
                </td>
            </tr>

            <tr>
                <td></td>
                <td colspan="5">
                    <small t-esc="line.product_id.description or ''"/>
                </td>
            </tr>
        </table>
    </t>

    <!-- ================= TOTAL ================= -->
    <table style="width:100%; margin-top:20px;">
        <tr>

            <!-- Amount in Words -->
            <td style="width:60%; vertical-align:top;">
                <strong>Amount in Words:</strong><br/>
                <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/> Only
            </td>

            <!-- Totals -->
            <td style="width:40%; text-align:right;">
                <div>Subtotal : <span t-esc="formatLang(o.amount_untaxed, currency_obj=o.currency_id)"/></div>
                <div>Tax : <span t-esc="formatLang(o.amount_tax, currency_obj=o.currency_id)"/></div>

                <div style="font-weight:bold;">
                    Total :
                    <span t-esc="formatLang(o.amount_total, currency_obj=o.currency_id)"/>
                </div>
            </td>

        </tr>
    </table>

    <!-- ================= FOOTER (SINGLE LINE) ================= -->
    <div style="position:absolute; bottom:0; left:20px; right:20px; text-align:center; border-top:1px solid #aaa; padding-top:5px; font-size:10px;">
        
        <strong t-esc="o.company_id.name"/> |
        <span t-esc="o.company_id.partner_id.street or ''"/> ,
        <span t-esc="'PO Box ' + (o.company_id.partner_id.zip or '') if o.company_id.partner_id.zip else ''"/> ,
        <span t-esc="o.company_id.partner_id.city or ''"/> ,
        <span t-esc="o.company_id.partner_id.country_id.name or ''"/>

    </div>

</div>
</main>

</t>
</t>

</template>

</odoo>