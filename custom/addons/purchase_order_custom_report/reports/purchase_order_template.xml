<odoo>
<template id="purchase_order_template">

<t t-call="web.html_container">
<t t-foreach="docs" t-as="o">
<t t-call="web.external_layout">

<div class="page">

    <div style="text-align:right;">
        <h3>Purchase Order</h3>
        <p><strong>PO No:</strong> <span t-esc="o.name"/></p>
        <p><strong>Date:</strong> <span t-esc="o.date_order"/></p>
    </div>

    <div>
        <strong>Vendor:</strong>
        <p t-esc="o.partner_id.name"/>
        <p t-esc="o.partner_id.contact_address"/>
    </div>

    <br/>

    <table style="width:100%; border-collapse: collapse;" border="1">
        <thead>
            <tr>
                <th>Description</th>
                <th>Qty</th>
                <th>Unit Price</th>
                <th>Amount</th>
            </tr>
        </thead>

        <tbody>
            <tr t-foreach="o.order_line" t-as="line">
                <td t-esc="line.name"/>
                <td t-esc="line.product_qty"/>
                <td t-esc="line.price_unit"/>
                <td t-esc="line.price_subtotal"/>
            </tr>
        </tbody>
    </table>

    <br/>

    <div style="text-align:right;">
        <p><strong>Untaxed:</strong> <span t-esc="o.amount_untaxed"/></p>
        <p><strong>Tax:</strong> <span t-esc="o.amount_tax"/></p>
        <p><strong>Total:</strong> <span t-esc="o.amount_total"/></p>
    </div>

    <br/>

    <div>
        <p><strong>Payment Terms:</strong>
            <span t-esc="o.payment_term_id.name"/>
        </p>

        <p><strong>Notes:</strong></p>
        <p t-esc="o.notes"/>
    </div>

</div>

</t>
</t>
</t>

</template>
</odoo>
