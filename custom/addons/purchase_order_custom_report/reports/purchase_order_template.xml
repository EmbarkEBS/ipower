<odoo>

    <!-- ========================= -->
    <!-- CUSTOM EXTERNAL LAYOUT -->
    <!-- ========================= -->
    <template id="custom_external_layout" inherit_id="web.external_layout">

        <!-- REMOVE DEFAULT HEADER -->
        <xpath expr="//div[contains(@class,'header')]" position="replace">
            <div class="header"/>
        </xpath>

        <!-- REMOVE DEFAULT FOOTER -->
        <xpath expr="//div[contains(@class,'footer')]" position="replace">
            <div class="footer"/>
        </xpath>

    </template>


    <!-- ========================= -->
    <!-- PURCHASE ORDER TEMPLATE -->
    <!-- ========================= -->
    <template id="purchase_order_template">

        <t t-call="web.external_layout">
        <t t-foreach="docs" t-as="o">

        <main>
        <div class="page" style="padding:10px 20px 80px 20px; font-size:12px; position:relative; min-height:1000px;">

            <!-- HEADER -->
            <table style="width:100%;">
                <tr>
                    <td style="width:60%;">
                        <strong>
                            <span t-esc="o.company_id.name"/>
                        </strong><br/>

                        <!-- FIXED ADDRESS -->
                        <span t-esc="o.company_id.partner_id.street or ''"/><br/>
                        <span t-esc="o.company_id.partner_id.city or ''"/>
                        <span t-esc="', ' + o.company_id.partner_id.country_id.name if o.company_id.partner_id.country_id else ''"/>
                    </td>

                    <td style="width:40%; text-align:right;">
                        <img t-if="o.company_id.logo"
                             t-att-src="image_data_uri(o.company_id.logo)"
                             style="height:60px;"/>
                    </td>
                </tr>
            </table>

            <!-- YOUR CONTENT (shortened here, keep your lines section same) -->

            <table style="width:100%; margin-top:20px;">
                <tr>

                    <!-- LEFT -->
                    <td style="width:60%;">
                        <strong>Amount in Words:</strong><br/>
                        <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/> Only
                    </td>

                    <!-- RIGHT -->
                    <td style="width:40%; text-align:right;">
                        <div>Subtotal : <span t-esc="'%.2f' % o.amount_untaxed"/></div>
                        <div>Tax : <span t-esc="'%.2f' % o.amount_tax"/></div>
                        <div style="font-weight:bold;">
                            Total :
                            <span t-esc="o.currency_id.symbol + ' ' + ('%.2f' % o.amount_total)"/>
                        </div>
                    </td>

                </tr>
            </table>

            <!-- FOOTER (FIXED BOTTOM) -->
            <div style="position:absolute; bottom:0; left:20px; right:20px; text-align:center; border-top:1px solid #aaa; font-size:10px; padding-top:5px;">

                <strong t-esc="o.company_id.name"/><br/>

                <span t-esc="o.company_id.partner_id.street or ''"/><br/>
                <span t-esc="o.company_id.partner_id.city or ''"/>
                <span t-esc="', ' + o.company_id.partner_id.country_id.name if o.company_id.partner_id.country_id else ''"/>

                <br/>
                Page <span class="page"/> of <span class="topage"/>

            </div>

        </div>
        </main>

        </t>
        </t>

    </template>

</odoo>