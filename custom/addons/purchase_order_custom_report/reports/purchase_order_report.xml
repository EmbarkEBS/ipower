<odoo>

    <record id="action_custom_purchase_order" model="ir.actions.report">
        <field name="name">Custom Purchase Order</field>
        <field name="model">purchase.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">purchase_order_custom_report.purchase_order_template</field>
        <field name="report_file">purchase_order_custom_report.purchase_order_template</field>

        <!-- THIS IS THE MISSING PART -->
        <field name="binding_model_id" ref="purchase.model_purchase_order"/>
        <field name="binding_type">report</field>

        <field name="print_report_name">'Purchase Order - %s' % (object.name)</field>
    </record>

</odoo>