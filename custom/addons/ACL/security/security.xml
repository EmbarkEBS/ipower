<odoo>

    <!-- Category -->
    <record id="module_category_acl" model="ir.module.category">
        <field name="name">Company Roles</field>
        <field name="sequence">10</field>
    </record>

    <!-- ADMIN -->
    <record id="group_acl_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="category_id" ref="module_category_acl"/>
        <field name="implied_ids" eval="[
            (4, ref('base.group_system')),
            (4, ref('sales_team.group_sale_manager')),
            (4, ref('stock.group_stock_manager')),
            (4, ref('account.group_account_manager'))
        ]"/>
    </record>

    <!-- SALES -->
    <record id="group_acl_sales" model="res.groups">
        <field name="name">Sales</field>
        <field name="category_id" ref="module_category_acl"/>
        <field name="implied_ids" eval="[
            (4, ref('sales_team.group_sale_salesman'))
        ]"/>
    </record>

    <!-- LOGISTIC -->
    <record id="group_acl_logistic" model="res.groups">
        <field name="name">Logistic</field>
        <field name="category_id" ref="module_category_acl"/>
        <field name="implied_ids" eval="[
            (4, ref('stock.group_stock_user'))
        ]"/>
    </record>

    <!-- ACCOUNTANT -->
    <record id="group_acl_accountant" model="res.groups">
        <field name="name">Accountant</field>
        <field name="category_id" ref="module_category_acl"/>
        <field name="implied_ids" eval="[
            (4, ref('account.group_account_user'))
        ]"/>
    </record>

</odoo>