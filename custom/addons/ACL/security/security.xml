<odoo>
    <data>

        <!-- CATEGORY -->
        <record id="module_category_acl" model="ir.module.category">
            <field name="name">ACL Management</field>
            <field name="sequence">30</field>
        </record>

        <!-- GROUPS -->
        <record id="group_management" model="res.groups">
            <field name="name">Admin</field>
            <field name="category_ids" eval="[(4, ref('module_category_acl'))]"/>
        </record>

        <record id="group_sales_officer" model="res.groups">
            <field name="name">Sales Officer</field>
            <field name="category_ids" eval="[(4, ref('module_category_acl'))]"/>
        </record>

        <record id="group_logistics" model="res.groups">
            <field name="name">Logistics</field>
            <field name="category_ids" eval="[(4, ref('module_category_acl'))]"/>
        </record>

        <record id="group_accountant" model="res.groups">
            <field name="name">Accountant</field>
            <field name="category_ids" eval="[(4, ref('module_category_acl'))]"/>
        </record>

    </data>
</odoo>