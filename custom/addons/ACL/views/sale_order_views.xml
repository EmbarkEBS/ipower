<odoo>

    <record id="view_sale_order_form_inherit_purchase_button" model="ir.ui.view">
        <field name="name">sale.order.form.purchase.button</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">

                <!-- ✅ Create PO -->
                <button name="action_create_purchase_order"
                        type="object"
                        string="Create Purchase Order"
                        class="btn-primary"
                        invisible="purchase_created"/>

                <!-- ✅ View PO -->
                <button name="action_view_purchase_order"
                        type="object"
                        string="View Purchase Order"
                        class="btn-secondary"
                        invisible="not purchase_created"/>

            </xpath>

        </field>
    </record>

</odoo>