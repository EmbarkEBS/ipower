<odoo>
    <record id="purchase_order_form_custom_print" model="ir.ui.view">
        <field name="name">purchase.order.form.custom.print</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
            <button name="action_preview_custom_po"
                        type="object"
                        string="Preview"
                        class="btn-secondary"
                        icon="fa-eye"/>
                <button name="action_print_custom_po"
                        type="object"
                        string="Print"
                        class="btn-primary"
                        icon="fa-print"/>
            </xpath>
        <xpath expr="//field[@name='x_studio_contact_person']" position="attributes">
    <attribute name="domain">[('id','in',contact_ids_domain)]</attribute>
</xpath>

        </field>

    </record>
</odoo>