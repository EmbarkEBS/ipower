<odoo>
    <record id="purchase_order_form_custom_print" model="ir.ui.view">
        <field name="name">purchase.order.form.custom.print</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
            <button name="action_preview_custom_po"
                        type="object"
                        string="Preview"
                        class="btn-secondary"
                        icon="fa-eye"/>
                <button name="action_print_custom_po"
                        type="object"
                        string="Print"
                        class="btn-primary"
                        icon="fa-print"/>
            </xpath>
<xpath expr="//field[@name='partner_id']" position="after">
    <field name="contact_person_id"/>
</xpath>
        </field>

    </record>
</odoo>