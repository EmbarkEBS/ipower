<odoo>

    <!-- PAPER FORMAT -->

    <record id="paperformat_custom_po"
            model="report.paperformat">

        <field name="name">Custom PO Paperformat</field>

        <field name="default" eval="False"/>

        <field name="format">A4</field>

        <field name="orientation">Portrait</field>

        <field name="margin_top">8</field>

        <field name="margin_bottom">0</field>

        <field name="margin_left">0</field>

        <field name="margin_right">0</field>

        <field name="header_line" eval="False"/>

        <field name="header_spacing">0</field>

        <field name="dpi">90</field>

    </record>

 <!-- Hide standard RFQ report -->
    <record id="purchase.action_report_purchase_quotation" model="ir.actions.report">
        <field name="binding_model_id" eval="False"/>
    </record>

    <!-- Hide standard Purchase Order report -->
    <record id="purchase.action_report_purchase_order" model="ir.actions.report">
        <field name="binding_model_id" eval="False"/>
    </record>
    <!-- REPORT -->

    <record id="action_report_custom_purchase_order"
            model="ir.actions.report">

        <field name="name">Custom Purchase Order</field>

        <field name="model">purchase.order</field>

        <field name="report_type">qweb-pdf</field>

       <field name="report_name">custom_po_report.purchase_order_template</field>

    <field name="report_file">custom_po_report.purchase_order_template</field>

    <field name="binding_model_id" ref="purchase.model_purchase_order"/>

    <field name="binding_type">report</field>

    <field name="print_report_name">'Purchase Order - %s' % (object.name)</field>

        <field name="paperformat_id"
               ref="custom_po_report.paperformat_custom_po"/>

       

    </record>

</odoo>