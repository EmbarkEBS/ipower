                                                         <span t-esc="o.partner_id.state_id.name"/>
                                                    </t>-->

                                                    -

                                                    <span t-esc="o.partner_id.country_id.name or ''"/>

                                                    <br/>

                                                  <t t-if="o.partner_id.vat">
<p  style="margin-top:15px"><strong >    TRN <span t-esc="o.partner_id.vat"/></strong></p>
</t>
   
<!-- ATTN ONLY IF CONTACT PERSON -->
<t t-if="o.contact_person_id.name">
    <p style="margin-top:5px">

        <strong>Attn</strong>

        <t t-if="o.partner_id.x_studio_salutation">
            <span t-esc="o.partner_id.x_studio_salutation"/>
        </t>

           <span t-esc="o.contact_person_id.name"/>

    </p>
</t>
                                                </td>

                                            </tr>

                                        </table>

