                                                    :
                                                    <span t-field="o.payment_term_id.name"/>

                                                </td>
                                                </tr>
                                            

                                            <tr>

                                                <td style="
                                                    padding:4px 0;
                                                    font-weight:bold;
                                                    color:#1a3a5a;
