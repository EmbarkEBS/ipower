                                                max-height:80px;
                                                margin-bottom:10px;
                                                margin-left:-30px;
                                             "/>

                                        <div style="
                                            font-size:13px;
                                            line-height:1.7;
                                        ">

                                            <strong style="
                                                color:#1a3a5a;
                                                font-size:15px;
                                            ">
                                                <span t-esc="o.company_id.name"/>
                                            </strong>

                                            <br/>

                                            <span t-esc="o.company_id.street or ''"/>, Dubai

                                          
                                           
                                         <!--  <t t-if="o.company_id.state_id">
                                                 <span t-esc="o.company_id.state_id.name"/>
                                            </t>--> 

