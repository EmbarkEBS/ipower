<odoo>
    <template id="purchase_order_template">

 

            <t t-foreach="docs" t-as="o">

                <style>
                    .fixed-footer {
                        position: fixed;
                        left: 0;
                        right: 0;
                        bottom: 0;
                        height: 35mm;
                    }

             @page {
        margin: 0 !important;
        padding: 0 !important;
    }

    html, body {
        margin: 0 !important;
        padding: 0 !important;
    }

    .article {
        margin: 0 !important;
        padding: 0 !important;
    }

    .page {
        margin: 0 !important;
        padding: 0 !important;
    }

    header,
    footer {
        display: none !important;
    }
                </style>
<main>
                <div class="page"
                     style="padding:10px 40px 40px 40px;
                            color:#333; margin:0;
                            line-height:1.4;
                            font-family: Helvetica, Arial, sans-serif !important;">

                 <!-- HEADER -->
    <table style="
                                width:100%;
                                border-collapse:collapse;
                                margin-bottom:20px;
                            ">

                                <tr>

                                    <!-- COMPANY -->
                                    <td style="
                                        width:60%;
                                        vertical-align:top;
                                    ">

                                        <img t-if="o.company_id.logo"
                                             t-att-src="image_data_uri(o.company_id.logo)"
                                             style="
                                                max-height:80px;
                                                margin-bottom:10px;
                                                margin-left:-30px;
                                             "/>

                                        <div style="
                                            font-size:13px;
                                            line-height:1.7;
                                        ">

                                            <strong style="
                                                color:#1a3a5a;
                                                font-size:15px;
                                            ">
                                                <span t-esc="o.company_id.name"/>
                                            </strong>

                                            <br/>

                                            <span t-esc="o.company_id.street or ''"/>,

                                          
                                           
                                            <t t-if="o.company_id.state_id">
                                                 <span t-esc="o.company_id.state_id.name"/>
                                            </t>

                                            <br/>

                                            <span t-esc="o.company_id.country_id.name or ''"/>

                                            <br/>

                                        <p  style="margin-top:15px"> <strong>  TRN <span t-esc="o.company_id.vat or ''"/></strong></p>

                                        </div>

                                    </td>

                                    <!-- PURCHASE ORDER -->
                                    <td style="
                                        width:40%;
                                        vertical-align:top;
                                        text-align:right;
                                    ">

                                        <h1 style="
                                            margin:0;
                                            font-size:28px;
                                            font-weight:bold;
                                            color:#000;
                                            margin-top:20px;
                                        ">
                                            PURCHASE ORDER
                                        </h1>

                                <div style="
    width:300px;
    margin:5px auto;
    text-align:center;
">

<svg width="300"
     height="4"
     xmlns="http://www.w3.org/2000/svg">

    <defs>

        <!-- HORIZONTAL ORANGE FADE -->
        <linearGradient id="horizontalFade"
                        x1="0%"
                        y1="0%"
                        x2="100%"
                        y2="0%">

            <!-- longer solid orange -->
            <stop offset="0%"
                  stop-color="#f39223"
                  stop-opacity="1"/>

            <stop offset="82%"
                  stop-color="#f39223"
                  stop-opacity="1"/>

            <!-- smooth fade -->
            <stop offset="100%"
                  stop-color="#f39223"
                  stop-opacity="0"/>

        </linearGradient>

    </defs>

    <!-- longer centered line -->
    <rect x="90"
          y="1"
          width="155"
          height="2"
          fill="url(#horizontalFade)"/>

</svg>

</div>
                                        <div style="
                                            font-size:16px;
                                            text-align:center;margin-top:10px;
                                        ">

                                            #
                                            <span t-esc="'IP/PO/' + str(o.date_order.year)[-2:] + '/' + '%03d' % o.id"/>

                                        </div>

                                    </td>

                                </tr>

                            </table>

  

                    <table style="width:100%;
                                  border-collapse:collapse;
                                  margin-top:30px;">

                        <thead>
                            <tr style="background:#4b4b4b;color:#fff;">
                                <th style="padding:10px;">SN</th>
                                <th style="padding:10px;">Product</th>
                                <th style="padding:10px;">Qty</th>
                                <th style="padding:10px;">Unit Price</th>
                                <th style="padding:10px;">Total</th>
                            </tr>
                        </thead>

                        <tbody>

                            <t t-set="sn" t-value="1"/>

                            <t t-foreach="o.order_line" t-as="line">

                                <tr style="border-bottom:1px solid #ddd;">
                                    <td style="padding:10px;text-align:center;">
                                        <span t-esc="sn"/>
                                    </td>

                                    <td style="padding:10px;">
                                        <strong>
                                            <span t-field="line.product_id.name"/>
                                        </strong>

                                        <br/>

                                        <span t-esc="line.product_id.description or ''"/>
                                    </td>

                                    <td style="padding:10px;text-align:center;">
                                        <span t-esc="int(line.product_qty)"/>
                                    </td>

                                    <td style="padding:10px;text-align:right;">
                                        <span t-esc="'{:,.2f}'.format(line.price_unit)"/>
                                    </td>

                                    <td style="padding:10px;text-align:right;">
                                        <span t-esc="'{:,.2f}'.format(line.price_subtotal)"/>
                                    </td>
                                </tr>

                                <t t-set="sn" t-value="sn + 1"/>

                            </t>

                        </tbody>

                    </table>

                    <table style="width:40%;
                                  margin-left:auto;
                                  margin-top:30px;">

                        <tr>
                            <td><strong>Sub Total</strong></td>
                            <td style="text-align:right;">
                                <span t-field="o.amount_untaxed"/>
                            </td>
                        </tr>

                        <tr>
                            <td><strong>Tax</strong></td>
                            <td style="text-align:right;">
                                <span t-field="o.amount_tax"/>
                            </td>
                        </tr>

                        <tr>
                            <td><strong>Total</strong></td>
                            <td style="text-align:right;">
                                <span t-field="o.amount_total"/>
                            </td>
                        </tr>

                    </table>

                    <div style="margin-top:40px;">
                         <strong style="
                                    font-size:14px;
                                    border-bottom:1px solid #e58b39;
                                    padding-bottom:2px;
                                ">
                                    Notes
                                </strong>
                        <br/>

                        <t t-if="o.note">
                            <span t-field="o.note"/>
                        </t>

                        <t t-else="">
                            Thanks for giving us the opportunity to serve you.
                        </t>
                    </div>

                    <div class="fixed-footer">
                        <div style="border-top:1px solid #1f3b73;
                                    padding-top:10px;
                                    text-align:center;
                                    font-size:11px;">
                            <span t-esc="o.company_id.name"/>
                            |
                            <span t-esc="o.company_id.website or ''"/>
                            |
                            <span t-esc="o.company_id.email or ''"/>
                        </div>
                    </div>

                </div>
</main>
            </t>

     

    </template>
</odoo>
