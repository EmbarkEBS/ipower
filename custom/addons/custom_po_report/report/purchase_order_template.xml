                                        ">
                                            Unit Price
                                        </th>

                                        <th style="
                                            padding:10px;
                                            width:12%;
                                            text-align:right;
                                            border-top-right-radius:10px;
                                            border-bottom-right-radius:10px;
                                        ">
                                            Total Price
                                        </th>

                                    </tr>

                                </thead>

                                <tbody>

                                    <t t-set="sn" t-value="1"/>

                                    <t t-foreach="o.order_line" t-as="line">

                                        <tr>

                                            <!-- SN -->
                                            <td style="font-size:15px;
                                               padding-top:15px;
                                                text-align:center;
                                                vertical-align:top;
                                            ">
                                                <span t-esc="sn"/>
                                            </td>

                                            <!-- DESCRIPTION -->
                                            <td style="
                                                padding-top:15px;
                                                vertical-align:top;
                                                width:55%;
                                                white-space:normal;
                                                word-break:break-word;
                                            ">

                                                <div style="
                                                    font-weight:bold;
                                                    margin-bottom:6px;
                                                    font-size:15px;
                                                    line-height:1.5;
                                                    width:100%;
                                                ">
                                                    <!--<span t-field="line.product_id.display_name"/>-->
                                                 
                                                 <span t-field="line.product_id.name"/>
                                                  </div>

                                            
                                            </td>

                                            <!-- QTY -->
                                            <td style="
                                              padding-top:15px;
                                              font-size:15px;
                                                text-align:center;
                                                vertical-align:top;
                                            ">
                                                <span t-esc="int(line.product_qty)"/>
                                            </td>

                                            <!-- UNIT PRICE -->
                                            <td style="
                                                padding-top:15px;
                                                font-size:15px;
                                                text-align:center;
                                                vertical-align:top;
                                            ">
                                                <span t-esc="'{:,.2f}'.format(line.price_unit)"/>
                                            </td>

                                            <!-- TOTAL -->
                                            <td style="
                                              padding-top:15px;
                                              font-size:15px;
                                                text-align:center;
                                                vertical-align:top;
                                            ">
                                                <span t-esc="'{:,.2f}'.format(line.price_subtotal)"/>
                                            </td>

                                        </tr>
                                        <tr >
                                        <td></td>
                                        <td  colspan="4" style="
                                          font-weight:bold;
                                          font-size:13px;
                                                    margin-bottom:6px;
                                                    
                                        ">                                
                    <span>Ordering Code: </span>      <span t-field="line.x_studio_related_field_2fu_1jmn8bvrv"/>
                      
</td></tr>
<tr style="border-bottom:1px solid #d9d9d9;">
                                        <td></td>
                                        <td  colspan="4" style="
                                           padding-botton:15px;
                                            font-size:12px;
                                            color:#666;
                                            line-height:1.7;
                                            white-space:normal;
                                            word-break:break-word;
                                        ">                               

                                                    <span t-esc="line.product_id.description or ''"/>

                                 
                                  
                                                </td></tr>
                                        <t t-set="sn" t-value="sn + 1"/>

                                    </t>

                                </tbody>

                            </table>
<!-- SHIPPING DETAILS (ONLY FOR FREIGHT FORWARDER) -->
<t t-if="o.partner_id.category_id.filtered(lambda c: c.name == 'Freight Forwarders')">

    <div style="margin-top:20px;">
        <strong style="font-size:14px;">Shipping Details</strong>

        <table style="width:100%; margin-top:8px; border:1px solid #000; border-collapse:collapse;">

            <tr>
                <td style="border:1px solid #000; padding:6px; width:40%;">
