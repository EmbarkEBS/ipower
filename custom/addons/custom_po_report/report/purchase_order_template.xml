<odoo>
    <template id="purchase_order_template">

        <t t-call="web.html_container">
<meta charset="UTF-8"/>
            <t t-foreach="docs" t-as="o">

<!-- ✅ SAFE CURRENCY SYMBOL -->
<t t-set="cur_symbol"
   t-value="'&#8364;' if o.currency_id.name == 'EUR' else o.currency_id.symbol"/>
                <style>
                    .fixed-footer {
                        position: fixed;
                        left: 0;
                        right: 0;
                        bottom: 0;
                        height: 22mm;
                    }

             @page {
        margin: 0px 40px 0px 40px !important;
        padding: 0 !important;
    }

    html, body {
        margin: 0 !important;
        padding: 0 !important;
    }

    .article {
        margin: 0 !important;
        padding: 0 !important;
    }

    .page {
        margin: 0 !important;
        padding: 0px 40px 0px 40px !important;
    }

