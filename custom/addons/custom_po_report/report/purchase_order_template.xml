                                        width:40%;
                                        vertical-align:top;
                                        text-align:center;
                                    ">

                                  <h1 style="
    margin:0;
    font-size:28px;
    font-weight:bold;
    color:#000;
    margin-top:20px;
">
    <t t-if="o.state in ['draft', 'sent']">
        RFQ
    </t>
    <t t-else="">
        PURCHASE ORDER
    </t>
</h1>

                                <div style="
    width:300px;
    margin:5px auto;
    text-align:center;
">

<svg width="300"
     height="4"
     xmlns="http://www.w3.org/2000/svg">

    <defs>

        <!-- HORIZONTAL ORANGE FADE -->
        <linearGradient id="horizontalFade"
                        x1="0%"
                        y1="0%"
                        x2="100%"
                        y2="0%">

            <!-- longer solid orange -->
            <stop offset="0%"
                  stop-color="#f39223"
                  stop-opacity="1"/>

            <stop offset="82%"
                  stop-color="#f39223"
                  stop-opacity="1"/>

            <!-- smooth fade -->
            <stop offset="100%"
                  stop-color="#f39223"
                  stop-opacity="0"/>

        </linearGradient>

    </defs>

    <!-- longer centered line -->
    <rect x="90"
          y="1"
          width="155"
          height="2"
          fill="url(#horizontalFade)"/>

</svg>

</div>
                                        <div style="
                                            font-size:16px;
                                            text-align:center;margin-top:10px;
                                        ">

                                            # <span t-field="o.name"/>
                                          <!---  <span t-esc="'IP/PO/' + str(o.date_order.year)[-2:] + '/' + '%03d' % o.id"/>-->
                                          


                                        </div>

                                    </td>

                                </tr>

                            </table>

  

