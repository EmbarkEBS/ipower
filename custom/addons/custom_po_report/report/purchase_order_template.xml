                                                    <span t-field="o.origin"/>

                                                </td>

                                            </tr></t>
<t t-if="o.x_studio_your_ref">
    <tr>
        <td style="  padding:4px 0;
                                                    font-weight:bold;
                                                    color:#1a3a5a;">
            Your Ref
        </td>
        <td style="padding:4px 0;">
            :
            <span t-esc="o.x_studio_your_ref"/>
        </td>
    </tr>
</t>
                                        </table>

                                    </td>

                                </tr>

                            </table>
      <!-- ===================================================== -->
                            <!-- PRODUCT TABLE -->
                            <!-- ===================================================== -->

                            <table style="
                                width:100%;
                                border-collapse:collapse;
                                margin-bottom:20px;
                            ">

                                <thead>

                                    <tr style="
                                        background:#4b4b4b;
                                        color:#fff;
                                    ">

                                        <th style="
                                            padding:10px;
