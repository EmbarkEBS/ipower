<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- PAPER FORMAT -->
    <record id="paperformat_zero_margin" model="report.paperformat">
        <field name="name">A4 Zero Margin for Custom Proforma Invoice</field>
        <field name="default">True</field>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">8</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line">False</field>
        <field name="header_spacing">0</field>
        <field name="dpi">96</field>
    </record>

    <!-- REPORT ACTION -->
    <record id="action_report_proforma_custom" model="ir.actions.report">
    <field name="name">Custom Proforma Invoice</field>
    <field name="model">sale.order</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">custom_proforma_report.proforma_template</field>
    <field name="report_file">custom_proforma_report.proforma_template</field>
    <field name="binding_model_id" ref="sale.model_sale_order"/>
    <field name="binding_type">report</field>
    <field name="paperformat_id" ref="custom_proforma_report.paperformat_zero_margin"/>
</record>
    </record>

</odoo>