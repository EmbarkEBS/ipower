<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Search View -->
    <record id="purchase_report_search_shipping" model="ir.ui.view">
        <field name="name">purchase.report.search.shipping</field>
        <field name="model">purchase.report</field>
        <field name="inherit_id" ref="purchase.view_purchase_order_search"/>
        <field name="arch" type="xml">

            <xpath expr="//search" position="inside">

                <field name="x_studio_delivery_location"/>

                <filter string="Delivery Location"
                        name="group_delivery_location"
                        context="{'group_by':'x_studio_delivery_location'}"/>

            </xpath>

        </field>
    </record>

    <!-- Tree/List View -->
    <record id="purchase_report_tree_shipping" model="ir.ui.view">
        <field name="name">purchase.report.tree.shipping</field>
        <field name="model">purchase.report</field>
        <field name="inherit_id" ref="purchase.purchase_report_view_tree"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='partner_id']" position="after">

                <field name="x_studio_delivery_location"/>
                <field name="x_studio_weightkg_1"/>
                <field name="x_studio_dimensions_1"/>
                <field name="x_studio_pickup_address"/>

            </xpath>

        </field>
    </record>

</odoo>