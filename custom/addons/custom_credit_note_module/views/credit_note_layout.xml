<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="external_layout_credit_note">
        <style>
        * {font-family: Helvetica, Arial, sans-serif !important;}
        .page {margin:0 !important;padding:10px 40px 0px 40px;}
        .footer{position:absolute;bottom:0;left:0;right:0;}
        </style>

        <div class="page" style="position:relative;color:#333;">
            <div class="header">
                <table style="width:100%;">
                    <tr>
                        <td style="width:60%;vertical-align:top;">
                            <img t-if="o.company_id.logo"
                                 t-att-src="image_data_uri(o.company_id.logo)"
                                 style="max-height:80px;"/>
                        </td>
                        <td>
                            <div style="font-size:13px;line-height:1.6;text-align:right;">
                                <strong style="font-size:16px;"><span t-esc="o.company_id.name"/></strong><br/>
                                <span t-esc="o.company_id.street or ''"/>, Dubai<br/>
                                <span t-esc="o.company_id.country_id.name or ''"/><br/>
                                <strong>TRN: <span t-esc="o.company_id.vat or ''"/></strong>
                            </div>
                        </td>
                    </tr>
                </table>
            </div>

            <div class="article">
                <t t-out="0"/>
            </div>

            <div class="footer">
                <div style="padding:0 40px;font-size:11px;">
                    <div style="margin-bottom:5px;color:#888;font-style:italic;">
                        This document is electronically generated and valid without signature or company stamp.
                    </div>
                </div>
            </div>
        </div>
    </template>

    <template id="credit_note_custom"
              inherit_id="account.report_invoice_document">

        <xpath expr="//t[@t-call='web.external_layout']" position="replace">

            <t t-if="o.move_type in ('out_refund','in_refund')"
               t-call="custom_credit_note_module.external_layout_credit_note">
                <t t-set="o" t-value="o"/>
                <t t-out="0"/>
            </t>

            <t t-else="" t-call="web.external_layout">
                <t t-set="o" t-value="o"/>
                <t t-out="0"/>
            </t>

        </xpath>

    </template>

</odoo>
