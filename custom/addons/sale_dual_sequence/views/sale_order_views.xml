<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_order_form_inherit_dual_sequence"
            model="ir.ui.view">

        <field name="name">
            sale.order.form.dual.sequence
        </field>

        <field name="model">sale.order</field>

        <field name="inherit_id"
               ref="sale.view_order_form"/>

        <field name="arch" type="xml">

            <xpath expr="//field[@name='name']"
                   position="replace">

                <field name="display_number"
                       readonly="1"/>

            </xpath>

        </field>

    </record>

</odoo>