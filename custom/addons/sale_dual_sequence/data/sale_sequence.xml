<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- QUOTATION -->
    <record id="seq_sale_quotation" model="ir.sequence">
        <field name="name">Sale Quotation</field>
        <field name="code">sale.quotation.sequence</field>

        <!-- FY-based prefix -->
        <field name="prefix">IP/QU/%(y)s/</field>

        <field name="padding">3</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- SALE ORDER -->
    <record id="seq_sale_order" model="ir.sequence">
        <field name="name">Sale Order</field>
        <field name="code">sale.order.sequence</field>

        <field name="prefix">IP/SO/%(y)s/</field>

        <field name="padding">3</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>

