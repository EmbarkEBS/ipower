<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- PAPER FORMAT -->
    <record id="paperformat_zero_margin" model="report.paperformat">
        <field name="name">A4 Zero Margin for Vendor Bill</field>
        <field name="default">True</field>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">60</field>
        <field name="margin_bottom">18</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line">False</field>
        <field name="header_spacing">50</field>
        <field name="dpi">96</field>
    </record>

    <!-- REPORT ACTION -->
    <record id="action_report_vendor_bill" model="ir.actions.report">
        <field name="name">Vendor Bill</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_vendor_bill_report.vendor_bill_template</field>
        <field name="report_file">custom_vendor_bill_report.vendor_bill_template</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
         <field name="print_report_name">'Vendor Bill- %s' % (object.name)</field>
        <field name="paperformat_id" ref="custom_invoice_report.paperformat_zero_margin"/>
    </record>

</odoo>