<odoo>

    <template id="vendor_bill_template">

      
     <t t-call="web.html_container">
<meta charset="UTF-8"/>


    <t t-foreach="docs" t-as="o">

        <t t-set="company" t-value="o.company_id"/>

        <t t-call="custom_vendor_bill_report.external_layout_ipower7">
                <!-- SAFE CURRENCY -->
                <t t-set="cur_symbol"
                   t-value="'&#8364;' if o.currency_id.name == 'EUR' else o.currency_id.symbol"/>

                 <style>
                   

    html, body {
        margin: 0 !important;
        padding: 0 !important;
    }

    .article {
        margin: 0 !important;
        padding: 0 !important;
    }
.page {
    padding: 0 40px !important;
}
  
                </style>

                <div class="page"
                     style="position:relative;
                            color:#333; padding:100px 0 0 0;
                            line-height:1.4;
                            font-family: Helvetica, Arial, sans-serif !important;">

                        <!-- WATERMARK -->
                        <div style="
                            position:absolute;
                            top:55%;
                            left:25%;
                            opacity:0.10;
                            transform:translate(-50%, -50%) rotate(-25deg);
                            z-index:0;
                            width:420px;
                            text-align:center;
                        ">

                            <img t-if="o.company_id.logo"
                                 t-att-src="image_data_uri(o.company_id.logo)"
                                 style="width:100%;"/>

                        </div>

                        <!-- HEADER -->
                        <table style="
                            width:100%;
                            border-collapse:collapse;
                            margin-bottom:20px;
                        ">

                            <tr>

                                <!-- COMPANY -->
                                <td style="
                                    width:60%;
                                    vertical-align:top;
                                ">

                                    <img t-if="o.company_id.logo"
                                         t-att-src="image_data_uri(o.company_id.logo)"
                                         style="
                                            max-height:80px;
                                            margin-bottom:10px;
                                            margin-left:-30px;
                                         "/>

                                    <div style="
                                        font-size:13px;
                                        line-height:1.7;
                                    ">

                                        <strong style="
                                            color:#1a3a5a;
                                            font-size:15px;
                                        ">
                                            <span t-esc="o.company_id.name"/>
                                        </strong>

                                        <br/>

                                        <span t-esc="o.company_id.street or ''"/>, Dubai

                                      <!--  <t t-if="o.company_id.state_id">
                                            ,
                                            <span t-esc="o.company_id.state_id.name"/>
                                        </t>-->

                                        <br/>

                                        <span t-esc="o.company_id.country_id.name or ''"/>

                                        <br/>

                                        <p style="margin-top:15px">
                                            <strong>
                                                TRN
                                                <span t-esc="o.company_id.vat or ''"/>
                                            </strong>
                                        </p>

                                    </div>

                                </td>

                                <!-- TITLE -->
                                <td style="
                                    width:40%;
                                    vertical-align:top;
                                    text-align:center;
                                ">

                                    <h1 style="
                                        margin:0;
                                        font-size:28px;
                                        font-weight:bold;
                                        color:#000;
                                        margin-top:20px;
                                    ">
                                        VENDOR BILL
                                    </h1>

                                    <div style="
                                        width:350px;
                                        margin:5px auto;
                                        text-align:center;
                                    ">

                                        <svg width="330"
                                             height="4"
                                             xmlns="http://www.w3.org/2000/svg">

                                            <defs>

                                                <linearGradient id="horizontalFade"
                                                                x1="0%"
                                                                y1="0%"
                                                                x2="100%"
                                                                y2="0%">

                                                    <stop offset="0%"
                                                          stop-color="#f39223"
                                                          stop-opacity="1"/>

                                                    <stop offset="82%"
                                                          stop-color="#f39223"
                                                          stop-opacity="1"/>

                                                    <stop offset="100%"
                                                          stop-color="#f39223"
                                                          stop-opacity="0"/>

                                                </linearGradient>

                                            </defs>

                                            <rect x="90"
                                                  y="1"
                                                  width="155"
                                                  height="2"
                                                  fill="url(#horizontalFade)"/>

                                        </svg>

                                    </div>

                                    <div style="
                                        font-size:16px;
                                        text-align:center;
                                        margin-top:10px;
                                    ">

                                        # <!--<span t-field="o.name"/>--> <span t-esc="o.ref or ''"/>

                                    </div>
 <div style="padding:5px 0;font-weight:bold; font-size:15px;color:#1a3a5a;">
 Balance Due

    :
  <span t-esc="o.currency_id.symbol"/>
<span t-esc="' %.2f' % o.amount_residual"/>
</div>
                                </td>

                            </tr>

                        </table>

                                             <!-- ADDRESS + META -->
                        <table style="
                            width:100%;
                            font-size:15px;
                            border-collapse:collapse;
                            margin-top:35px;
                            margin-bottom:35px;
                        ">

                            <tr>

                                <!-- BILL TO -->
                                <td style="
                                    width:55%; font-size:15px;
                                    vertical-align:top;
                                ">

                                    <table style="
                                        width:100%; font-size:15px;
                                        border-collapse:collapse;
                                    ">

                                        <strong style="color:#1a3a5a;">
                                           Bill From
                                        </strong>

                                        <tr>

                                            <td style="
                                                width:8px;
                                                padding:0;
                                                vertical-align:top;
                                            ">

                                                <svg width="8"
                                                     height="130"
                                                     xmlns="http://www.w3.org/2000/svg">

                                                    <defs>

                                                        <linearGradient id="verticalFade"
                                                                        x1="0%"
                                                                        y1="0%"
                                                                        x2="0%"
                                                                        y2="100%">

                                                            <stop offset="0%"
                                                                  stop-color="#f39223"
                                                                  stop-opacity="1"/>

                                                            <stop offset="100%"
                                                                  stop-color="#f39223"
                                                                  stop-opacity="0"/>

                                                        </linearGradient>

                                                    </defs>

                                                    <rect x="0"
                                                          y="0"
                                                          width="2"
                                                          height="130"
                                                          fill="url(#verticalFade)"/>

                                                </svg>

                                            </td>

                                            <td style="width:15px;"></td>

                                            <td style="
                                                vertical-align:top;
                                                font-size:15px;
                                                line-height:1.7;
                                            ">

                                                <strong>
                                                      <span t-esc="o.partner_id.parent_id.name if o.partner_id.parent_id else o.partner_id.name"/>
   
                                                    </strong>

                                                <br/>

                                                <span t-esc="o.partner_id.street or ''"/>

                                                <t t-if="o.partner_id.street2">
                                                    <br/>
                                                    <span t-esc="o.partner_id.street2"/>
                                                </t>

                                                <br/>

                                                <span t-esc="o.partner_id.city or ''"/>

                                               <!-- <t t-if="o.partner_id.state_id">
                                                    ,
                                                    <span t-esc="o.partner_id.state_id.name"/>
                                                </t>-->

                                                -

                                                <span t-esc="o.partner_id.country_id.name or ''"/>

                                                <br/>

                                                <t t-if="o.partner_id.vat">

                                                    <p style="margin-top:15px">

                                                        <strong>
                                                            TRN
                                                            <span t-esc="o.partner_id.vat"/>
                                                        </strong>

                                                    </p>

                                                </t>
<!-- ATTN ONLY IF CONTACT PERSON -->
<t t-if="o.partner_id.parent_id">
    <p style="margin-top:5px">

        <strong>Attn</strong>

        <t t-if="o.partner_id.x_studio_salutation">
            <span t-esc="o.partner_id.x_studio_salutation"/>
        </t>

        <span t-esc="o.partner_id.name"/>

    </p>
</t>
                                            </td>

                                        </tr>

                                    </table>

                                </td>

                                <!-- META -->
                                <td style="
                                    width:45%; font-size:15px;
                                    vertical-align:top;
                                    padding-left:40px;
                                ">

                                    <table style="
                                        width:100%; font-size:15px;
                                        border-collapse:collapse;
                                    ">

                                        <tr>

                                            <td style="
                                                padding:4px 0;
                                                width:45%;
                                                font-weight:bold; font-size:15px;
                                                color:#1a3a5a;
                                            ">
                                                Invoice Date
                                            </td>

                                            <td style="padding:4px 0;">

                                                :
                                                <span t-field="o.invoice_date"/>

                                            </td>

                                        </tr>

                                        <tr>

                                            <td style="
                                                padding:4px 0; font-size:15px;
                                                font-weight:bold;
                                                color:#1a3a5a;
                                            ">
                                                Due Date
                                            </td>

                                            <td style="padding:4px 0;">

                                                :
                                                <span t-field="o.invoice_date_due"/>

                                            </td>

                                        </tr>

                                      <!--  <tr>

                                            <td style=" font-size:15px;
                                                padding:4px 0;
                                                font-weight:bold;
                                                color:#1a3a5a;
                                            ">
                                                Payment Terms
                                            </td>

                                            <td style="padding:4px 0;">

                                                :
                                                <span t-field="o.invoice_payment_term_id.name"/>

                                            </td>

                                        </tr>-->

                                       <tr>

                                         <td style="padding:5px 0;font-weight:bold; font-size:15px;color:#1a3a5a;">
   Our PO Number
</td>
<td>
    :
    <span t-esc="o.invoice_origin or ''"/>
</td>

                                        </tr>
                                       <!--<t t-if="o.ref">   <tr>

                                       <td style="padding:5px 0;font-weight:bold; font-size:15px;color:#1a3a5a;">
  Customer Bill Number
</td>
<td>
    :
    <span t-esc="o.ref or ''"/>
</td>

                                        </tr></t> -->
                                         
                                     <t t-if="o.invoice_incoterm_id.code">   <tr>
    <td style="padding:5px 0;font-weight:bold; font-size:15px; font-size:15px;color:#1a3a5a;">
        Incoterm
    </td>
    <td>
        :
        <span t-esc="o.invoice_incoterm_id.code if o.invoice_incoterm_id else ''"/><t t-if="o.incoterm_location"> - <span t-field="o.incoterm_location"/></t>
       <!-- <span t-esc="o.invoice_incoterm_id.name if o.invoice_incoterm_id else ''"/>-->
    </td>
</tr></t>
<t t-set="sale_order" t-value="o.line_ids.sale_line_ids.order_id[:1]"/>

<t t-if="sale_order and sale_order.x_studio_customer_po_ref"><tr>

                                            <td style="
                                                padding:5px 0; font-size:15px;
                                                font-weight:bold;
                                                color:#1a3a5a;
                                            ">
                                                Customer PO Ref
                                            </td>

                                            <td>
                                                :
                                               <span t-esc="sale_order.x_studio_customer_po_ref"/>
                                            </td>

                                        </tr></t>

                                      
                                    </table>

                                </td>

                            </tr>

                        </table>

                        <!-- PRODUCT TABLE -->
                        <table style="
                            width:100%;
                            border-collapse:collapse;
                            margin-bottom:20px;
                        ">

                            <thead>

                                <tr style="
                                    background:#4b4b4b;
                                    color:#fff;
                                ">

                                    <th style="
                                        padding:10px;
                                        width:5%;
                                        text-align:center;
                                        border-top-left-radius:10px;
                                        border-bottom-left-radius:10px;
                                    ">
                                        SN
                                    </th>

                                    <th style="
                                        padding:10px;
                                        width:45%;
                                        text-align:center;
                                    ">
                                        Product Specification
                                    </th>
   <th style="
                                        padding:10px;
                                        width:12%;
                                        text-align:center;
                                    ">
                                      HS Code
                                    </th>
                                    <th style="
                                        padding:10px;
                                        width:7%;
                                        text-align:center;
                                    ">
                                        Qty
                                    </th>

                                    <th style="
                                        padding:10px;
                                        width:11%;
                                        text-align:right;
                                    ">
                                        Unit Price
                                    </th>

                                    <th style="
                                        padding:10px;
                                        width:12%;
                                        text-align:right;
                                        border-top-right-radius:10px;
                                        border-bottom-right-radius:10px;
                                    ">
                                        Total Price
                                    </th>

                                </tr>

                            </thead>

                           <tbody>

    <t t-set="sn" t-value="1"/>

    <t t-foreach="o.invoice_line_ids" t-as="line">

        <!-- SECTION -->
        <t t-if="line.display_type == 'line_section'">

            <tr>
                <td colspan="6"
                    style="
                        padding-top:15px;
                        padding-bottom:10px;
                        padding-left:15px;
                        font-size:15px;
                        font-weight:bold;
                        color:#1a3a5a;
                        border-bottom:1px solid #d9d9d9;
                        background:#f7f7f7;
                    ">
                    <span t-field="line.name"/>
                </td>
            </tr>

        </t>

        <!-- NOTE -->
        <t t-elif="line.display_type == 'line_note'">

            <tr>
                <td></td>
                <td colspan="5"
                    style="
                        padding:10px 0;
                        font-style:italic;
                        color:#666;
                    ">
                    <span t-field="line.name"/>
                </td>
            </tr>

        </t>

        <!-- NORMAL PRODUCT -->
        <t t-else="">

            <tr>

                <!-- SN -->
                <td style="
                    font-size:15px;
                    padding-top:15px;
                    text-align:center;
                    vertical-align:top;
                ">
                    <span t-esc="sn"/>
                </td>

                <!-- PRODUCT -->
                <td style="
                    padding-top:15px;
                    vertical-align:top;
                    width:45%;
                    white-space:normal;
                    word-break:break-word;
                ">

                    <div style="
                        font-weight:bold;
                        margin-bottom:6px;
                        font-size:15px;
                        line-height:1.5;
                        width:100%;
                    ">
                        <span t-esc="line.product_id.name"/>
                    </div>

                </td>

                <!-- HS CODE -->
                <td style="
                    padding-top:15px;
                    font-size:15px;
                    text-align:center;
                    vertical-align:top;
                ">
                    <span t-esc="line.product_id.product_tmpl_id.hs_code or ''"/>
                </td>

                <!-- QTY -->
                <td style="
                    padding-top:15px;
                    font-size:15px;
                    text-align:center;
                    vertical-align:top;
                ">
                    <span t-esc="int(line.quantity)"/>
                </td>

                <!-- UNIT PRICE -->
                <td style="
                    padding-top:15px;
                    font-size:15px;
                    text-align:center;
                    vertical-align:top;
                ">
                    <span t-esc="'{:,.2f}'.format(line.price_unit)"/>
                </td>

                <!-- TOTAL -->
                <td style="
                    padding-top:15px;
                    font-size:15px;
                    text-align:center;
                    vertical-align:top;
                ">
                    <span t-esc="'{:,.2f}'.format(line.price_subtotal)"/>
                </td>

            </tr>

            <!-- ORDERING CODE -->
            <t t-if="line.product_id.product_tmpl_id.x_studio_sku_code">

                <tr>
                    <td></td>

                    <td colspan="5"
                        style="
                            font-size:13px;
                            font-weight:bold;
                        ">

                        <span>Ordering Code: </span>

                        <span t-esc="line.product_id.product_tmpl_id.x_studio_sku_code"/>

                    </td>
                </tr>

            </t>

            <!-- DESCRIPTION -->
            <t t-if="line.product_id.description">

                <tr style="border-bottom:1px solid #d9d9d9;">

                    <td></td>

                    <td colspan="5"
                        style="
                            padding-bottom:15px;
                            font-size:12px;
                            color:#666;
                            line-height:1.7;
                            white-space:normal;
                            word-break:break-word;
                        ">

                        <span t-esc="line.product_id.description"/>

                    </td>

                </tr>

            </t>

            <t t-set="sn" t-value="sn + 1"/>

        </t>

    </t>

</tbody>

                        </table>

                        <!-- TOTAL -->
                        <table style="
                            width:100%;
                            margin-top:20px;
                            border-collapse:collapse;
                        ">

                            <tr>

                                <td style="
                                    width:55%;
                                    vertical-align:middle;
                                    font-size:15px;
                                    padding-top:40px;
                                    padding-left:20px;
                                    text-align:left;
                                ">

                                    <div style="font-size:13px;">

                                        <strong>
                                            Amount in Words:
                                            <span t-esc="o.currency_id.name"/>
                                            <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/>
                                            only.
                                        </strong>

                                    </div>

                                </td>

                                <td style="width:45%; padding-right:30px;!important">
                                    <table style="
                                        width:100%;
                                        border-collapse:collapse;
                                        text-align:right;
                                    ">

                                        <tr>

                                            <td style="
                                                padding:5px;
                                                font-weight:bold;
                                            ">
                                                Sub Total
                                            </td>

                                            <td style="padding:5px;">
                                                  <span t-esc="cur_symbol + ' {:,.2f}'.format(o.amount_untaxed)"/>
                                            </td>

                                        </tr>

                                        <t t-if="o.tax_totals">

    <t t-set="subtotals"
       t-value="o.tax_totals.get('subtotals', [])"/>

    <t t-foreach="subtotals" t-as="subtotal">

        <t t-foreach="subtotal.get('tax_groups', [])" t-as="tax_group">

            <tr>

                <td style="padding:5px;font-weight:bold;">
                    VAT (
                    <span t-esc="
                        int(
                            env['account.tax'].browse(
                                tax_group['involved_tax_ids'][0]
                            ).amount
                        )
                    "/>%)
                </td>

                <td style="padding:5px;text-align:right;">
                    <span t-esc="o.currency_id.symbol"/>
                    <span t-esc="'{:,.2f}'.format(tax_group['tax_amount_currency'])"/>
                </td>

            </tr>

        </t>

    </t>

</t>
                                        <tr style="
                                            font-size:16px;
                                            color:#1a3a5a;
                                        ">

                                            <td style="
                                                padding:10px 5px;
                                                font-weight:bold;
                                            ">
                                                Total
                                            </td>

                                            <td style="
                                                padding:10px 5px;
                                                font-weight:bold;
                                            ">
                                                <span t-esc="cur_symbol + ' {:,.2f}'.format(o.amount_total)"/>
                                            </td>

                                        </tr>

                                    </table>

                                </td>

                            </tr>

                        </table>

                        <!-- NOTES -->
                        <div style="margin-top:60px;padding-left:20px;">

                            <strong style="
                                font-size:14px;
                                border-bottom:1px solid #e58b39;
                                padding-bottom:2px;
                            ">
                                Notes
                            </strong>

                            <div style="
                                margin-top:10px;
                                font-size:14px;
                                color:#555;
                            ">

                                <t t-if="o.narration">
                                    <span t-esc="o.narration"/>
                                </t>

                                <t t-else="">
                                    Thanks for giving us the opportunity to serve you
                                </t>

                            </div>

                        </div> 

                    </div> <!-- page -->

                </t>

            </t>

        </t>

    </template>

</odoo>