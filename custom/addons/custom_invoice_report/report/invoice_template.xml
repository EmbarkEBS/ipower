<odoo>

   <template id="invoice_template">

        <t t-call="web.basic_layout">

            <main style="margin:0 !important; padding:0 !important;">

                <t t-foreach="docs" t-as="o">

                    <!-- Currency -->
                    <t t-set="cur_symbol"
                       t-value="'&#8364;' if o.currency_id.name == 'EUR' else o.currency_id.symbol"/>

                    <style>

                        @page {
                            size: A4;
                            margin: 0mm 0mm 0mm 0mm;
                        }

                        html,
                        body,
                        main,
                        .article {
                            margin: 0 !important;
                            padding: 0 !important;
                        }

                        header,
                        footer {
                            display: none !important;
                        }

                        .custom-page {
                            position: relative;
                            min-height: 1120px;
                            padding: 20px 40px 0px 40px;
                            font-family: Helvetica, Arial, sans-serif;
                            color: #333;
                            line-height: 1.4;
                        }

                        .fixed-footer {
                            position: absolute;
                            left: 0;
                            right: 0;
                            bottom: 0;
                            height: 22mm;
                        }

                        table {
                            border-collapse: collapse;
                        }

                    </style>

                    <!-- ================================================= -->
                    <!-- PAGE -->
                    <!-- ================================================= -->

                    <div class="custom-page">

                        <!-- WATERMARK -->

                        <div style="
                            position:absolute;
                            top:50%;
                            left:25%;
                            opacity:0.08;
                            transform:translate(-50%, -50%) rotate(-25deg);
                            z-index:0;
                            width:420px;
                            text-align:center;
                        ">

                            <img t-if="o.company_id.logo"
                                 t-att-src="image_data_uri(o.company_id.logo)"
                                 style="width:100%;"/>

                        </div>


                        <!-- ================================================= -->
                        <!-- HEADER -->
                        <!-- ================================================= -->

                        <table style="
                            width:100%;
                            margin-bottom:25px;
                        ">

                            <tr>

                                <!-- COMPANY -->

                                <td style="
                                    width:60%;
                                    vertical-align:top;
                                ">

                                    <img t-if="o.company_id.logo"
                                         t-att-src="image_data_uri(o.company_id.logo)"
                                         style="
                                            max-height:75px;
                                            margin-bottom:10px;
                                         "/>

                                    <div style="
                                        font-size:13px;
                                        line-height:1.7;
                                    ">

                                        <strong style="
                                            color:#1a3a5a;
                                            font-size:16px;
                                        ">
                                            <span t-esc="o.company_id.name"/>
                                        </strong>

                                        <br/>

                                        <span t-esc="o.company_id.street or ''"/>

                                        <t t-if="o.company_id.state_id">
                                            ,
                                            <span t-esc="o.company_id.state_id.name"/>
                                        </t>

                                        <br/>

                                        <span t-esc="o.company_id.country_id.name or ''"/>

                                        <br/><br/>

                                        <strong>
                                            TRN:
                                            <span t-esc="o.company_id.vat or ''"/>
                                        </strong>

                                    </div>

                                </td>


                                <!-- TITLE -->

                                <td style="
                                    width:40%;
                                    text-align:center;
                                    vertical-align:top;
                                ">

                                    <h1 style="
                                        margin:0;
                                        margin-top:15px;
                                        font-size:28px;
                                        color:#000;
                                    ">
                                        TAX INVOICE
                                    </h1>

                                    <div style="
                                        font-size:16px;
                                        margin-top:12px;
                                    ">

                                        #
                                        <span t-field="o.name"/>

                                    </div>

                                </td>

                            </tr>

                        </table>


                        <!-- ================================================= -->
                        <!-- CUSTOMER + META -->
                        <!-- ================================================= -->

                        <table style="
                            width:100%;
                            margin-top:20px;
                            margin-bottom:35px;
                            font-size:13px;
                        ">

                            <tr>

                                <!-- BILL TO -->

                                <td style="
                                    width:55%;
                                    vertical-align:top;
                                ">

                                    <strong style="
                                        color:#1a3a5a;
                                        font-size:14px;
                                    ">
                                        Bill To
                                    </strong>

                                    <div style="
                                        margin-top:10px;
                                        border-left:2px solid #f39223;
                                        padding-left:15px;
                                        line-height:1.8;
                                    ">

                                        <strong>
                                            <span t-esc="o.partner_id.name"/>
                                        </strong>

                                        <br/>

                                        <span t-esc="o.partner_id.street or ''"/>

                                        <t t-if="o.partner_id.street2">
                                            <br/>
                                            <span t-esc="o.partner_id.street2"/>
                                        </t>

                                        <br/>

                                        <span t-esc="o.partner_id.city or ''"/>

                                        <t t-if="o.partner_id.state_id">
                                            ,
                                            <span t-esc="o.partner_id.state_id.name"/>
                                        </t>

                                        <br/>

                                        <span t-esc="o.partner_id.country_id.name or ''"/>

                                        <t t-if="o.partner_id.vat">

                                            <br/><br/>

                                            <strong>
                                                TRN:
                                                <span t-esc="o.partner_id.vat"/>
                                            </strong>

                                        </t>

                                    </div>

                                </td>


                                <!-- META -->

                                <td style="
                                    width:45%;
                                    vertical-align:top;
                                    padding-left:40px;
                                ">

                                    <table style="
                                        width:100%;
                                        font-size:13px;
                                    ">

                                        <tr>

                                            <td style="
                                                padding:5px 0;
                                                width:45%;
                                                font-weight:bold;
                                                color:#1a3a5a;
                                            ">
                                                Invoice Date
                                            </td>

                                            <td>
                                                :
                                                <span t-field="o.invoice_date"/>
                                            </td>

                                        </tr>

                                        <tr>

                                            <td style="
                                                padding:5px 0;
                                                font-weight:bold;
                                                color:#1a3a5a;
                                            ">
                                                Due Date
                                            </td>

                                            <td>
                                                :
                                                <span t-field="o.invoice_date_due"/>
                                            </td>

                                        </tr>

                                        <tr>

                                            <td style="
                                                padding:5px 0;
                                                font-weight:bold;
                                                color:#1a3a5a;
                                            ">
                                                Payment Terms
                                            </td>

                                            <td>
                                                :
                                                <span t-esc="o.invoice_payment_term_id.name or ''"/>
                                            </td>

                                        </tr>

                                        <tr>

                                            <td style="
                                                padding:5px 0;
                                                font-weight:bold;
                                                color:#1a3a5a;
                                            ">
                                                Sales Order Ref
                                            </td>

                                            <td>
                                                :
                                                <span t-esc="o.ref or ''"/>
                                            </td>

                                        </tr>
  <t t-if="o.x_studio_customer_po_ref"><tr>

                                            <td style="
                                                padding:5px 0;
                                                font-weight:bold;
                                                color:#1a3a5a;
                                            ">
                                                Customer PO Ref
                                            </td>

                                            <td>
                                                :
                                              <span t-esc="o.x_studio_customer_po_ref or ''"/>
                                            </td>

                                        </tr></t>
                                    </table>

                                </td>

                            </tr>

                        </table>


                        <!-- ================================================= -->
                        <!-- PRODUCT TABLE -->
                        <!-- ================================================= -->

                        <table style="
                            width:100%;
                            margin-top:10px;
                        ">

                            <thead>

                                <tr style="
                                    background:#4b4b4b;
                                    color:#fff;
                                ">

                                    <th style="
                                        padding:10px;
                                        width:5%;
                                        text-align:center;
                                    ">
                                        SN
                                    </th>

                                    <th style="
                                        padding:10px;
                                        width:55%;
                                        text-align:left;
                                    ">
                                        Product Specification
                                    </th>

                                    <th style="
                                        padding:10px;
                                        width:10%;
                                        text-align:center;
                                    ">
                                        Qty
                                    </th>

                                    <th style="
                                        padding:10px;
                                        width:15%;
                                        text-align:right;
                                    ">
                                        Unit Price
                                    </th>

                                    <th style="
                                        padding:10px;
                                        width:15%;
                                        text-align:right;
                                    ">
                                        Total
                                    </th>

                                </tr>

                            </thead>

                            <tbody>

                                <t t-set="sn" t-value="1"/>

                                <t t-foreach="o.invoice_line_ids" t-as="line">

                                    <tr style="
                                        border-bottom:1px solid #ddd;
                                    ">

                                        <td style="
                                            padding:12px 5px;
                                            text-align:center;
                                            vertical-align:top;
                                        ">
                                            <span t-esc="sn"/>
                                        </td>

                                        <td style="
                                            padding:12px 5px;
                                            vertical-align:top;
                                        ">

                                            <strong>
                                                <span t-esc="line.product_id.name"/>
                                            </strong>

                                            <br/>

                                            <span style="
                                                font-size:12px;
                                                color:#666;
                                            ">
                                                <span t-esc="line.product_id.description or ''"/>
                                            </span>

                                        </td>

                                        <td style="
                                            padding:12px 5px;
                                            text-align:center;
                                            vertical-align:top;
                                        ">
                                            <span t-esc="int(line.quantity)"/>
                                        </td>

                                        <td style="
                                            padding:12px 5px;
                                            text-align:right;
                                            vertical-align:top;
                                        ">
                                            <span t-esc="'{:,.2f}'.format(line.price_unit)"/>
                                        </td>

                                        <td style="
                                            padding:12px 5px;
                                            text-align:right;
                                            vertical-align:top;
                                        ">
                                            <span t-esc="'{:,.2f}'.format(line.price_subtotal)"/>
                                        </td>

                                    </tr>

                                    <t t-set="sn" t-value="sn + 1"/>

                                </t>

                            </tbody>

                        </table>


                        <!-- ================================================= -->
                        <!-- TOTAL -->
                        <!-- ================================================= -->

                        <table style="
                            width:100%;
                            margin-top:30px;
                        ">

                            <tr>

                                <td style="
                                    width:55%;
                                    vertical-align:top;
                                ">

                                    <div style="
                                        font-size:13px;
                                        padding-top:20px;
                                    ">

                                        <strong>
                                            Amount in Words:
                                        </strong>

                                        <br/>

                                        <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/>

                                    </div>

                                </td>


                                <td style="
                                    width:45%;
                                ">

                                    <table style="
                                        width:100%;
                                        text-align:right;
                                    ">

                                        <tr>

                                            <td style="
                                                padding:6px;
                                                font-weight:bold;
                                            ">
                                                Sub Total
                                            </td>

                                            <td style="padding:6px;">
                                                <span t-raw="cur_symbol + ' ' + ('%.2f' % o.amount_untaxed)"/>
                                            </td>

                                        </tr>

                                        <tr>

                                            <td style="
                                                padding:6px;
                                                font-weight:bold;
                                            ">
                                                VAT
                                            </td>

                                            <td style="padding:6px;">
                                                <span t-raw="cur_symbol + ' ' + ('%.2f' % o.amount_tax)"/>
                                            </td>

                                        </tr>

                                        <tr style="
                                            font-size:16px;
                                            color:#1a3a5a;
                                        ">

                                            <td style="
                                                padding:10px 6px;
                                                font-weight:bold;
                                            ">
                                                Total
                                            </td>

                                            <td style="
                                                padding:10px 6px;
                                                font-weight:bold;
                                            ">
                                                <span t-raw="cur_symbol + ' ' + ('%.2f' % o.amount_total)"/>
                                            </td>

                                        </tr>

                                    </table>

                                </td>

                            </tr>

                        </table>


                        <!-- ================================================= -->
                        <!-- FOOTER -->
                        <!-- ================================================= -->

                        <div class="fixed-footer">

                            <div style="
                                padding:0 40px;
                                font-size:11px;
                                color:#555;
                            ">

                                <div style="
                                    border-top:1px solid #1f3b73;
                                    padding-top:8px;
                                    text-align:center;
                                ">

                                    <span t-esc="o.company_id.city or ''"/>
                                    -
                                    <span t-esc="o.company_id.country_id.name or ''"/>

                                    |

                                    <span t-esc="o.company_id.email or ''"/>

                                    |

                                    <span t-esc="o.company_id.website or ''"/>

                                </div>

                            </div>

                            <!-- COLOR BAR -->

                            <div style="
                                width:100%;
                                height:25px;
                                margin-top:5px;
                            ">

                                <svg width="100%"
                                     height="25"
                                     viewBox="0 0 1000 25"
                                     preserveAspectRatio="none"
                                     xmlns="http://www.w3.org/2000/svg">

                                    <polygon points="0,0 260,0 240,25 0,25"
                                             fill="#1f3b73"/>

                                    <polygon points="260,0 1000,0 1000,25 240,25"
                                             fill="#e58b39"/>

                                </svg>

                            </div>

                        </div>

                    </div>

                </t>

            </main>

        </t>

    </template>

</odoo>