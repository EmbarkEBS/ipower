<odoo>

    <template id="invoice_template">

        <t t-call="web.html_container">

            <meta charset="UTF-8"/>

            <t t-foreach="docs" t-as="o">

                <!-- SAFE CURRENCY -->
                <t t-set="cur_symbol"
                   t-value="'&#8364;' if o.currency_id.name == 'EUR' else o.currency_id.symbol"/>

                <style>

                    .fixed-footer {
                        position: fixed;
                        left: 0;
                        right: 0;
                        bottom: 0;
                        height: 22mm;
                    }

             @page {
        margin: 0px 40px 0px 40px !important;
        padding: 0 !important;
    }

    html, body {
        margin: 0 !important;
        padding: 0 !important;
    }

    .article {
        margin: 0 !important;
        padding: 0 !important;
    }

    .page {
        margin: 0 !important;
        padding: 0px 40px 0px 40px !important;
    }
 @page {
        size: A4;
        margin: 0 !important;
    }
    header,
    footer {
        display: none !important;
    }
                </style>

                <main>

                    <div class="page" style="padding:0px 40px 0px 40px;position:relative;
                            color:#333; margin:0;
                            line-height:1.4;
                            font-family: Helvetica, Arial, sans-serif !important;">

                        <!-- WATERMARK -->
                        <div style="
                            position:absolute;
                            top:60%;
                            left:25%;
                            opacity:0.10;
                            transform:translate(-50%, -50%) rotate(-25deg);
                            z-index:0;
                            width:420px;
                            text-align:center;
                        ">

                            <img t-if="o.company_id.logo"
                                 t-att-src="image_data_uri(o.company_id.logo)"
                                 style="width:100%;"/>

                        </div>

                        <!-- HEADER -->
                        <table style="
                            width:100%;
                            border-collapse:collapse;
                            margin-bottom:20px;
                        ">

                            <tr>

                                <!-- COMPANY -->
                                <td style="
                                    width:60%;
                                    vertical-align:top;
                                ">

                                    <img t-if="o.company_id.logo"
                                         t-att-src="image_data_uri(o.company_id.logo)"
                                         style="
                                            max-height:80px;
                                            margin-bottom:10px;
                                            margin-left:-30px;
                                         "/>

                                    <div style="
                                        font-size:13px;
                                        line-height:1.7;
                                    ">

                                        <strong style="
                                            color:#1a3a5a;
                                            font-size:15px;
                                        ">
                                            <span t-esc="o.company_id.name"/>
                                        </strong>

                                        <br/>

                                        <span t-esc="o.company_id.street or ''"/>

                                        <t t-if="o.company_id.state_id">
                                            ,
                                            <span t-esc="o.company_id.state_id.name"/>
                                        </t>

                                        <br/>

                                        <span t-esc="o.company_id.country_id.name or ''"/>

                                        <br/>

                                        <p style="margin-top:15px">
                                            <strong>
                                                TRN
                                                <span t-esc="o.company_id.vat or ''"/>
                                            </strong>
                                        </p>

                                    </div>

                                </td>

                                <!-- TITLE -->
                                <td style="
                                    width:40%;
                                    vertical-align:top;
                                    text-align:center;
                                ">

                                    <h1 style="
                                        margin:0;
                                        font-size:28px;
                                        font-weight:bold;
                                        color:#000;
                                        margin-top:20px;
                                    ">
                                        TAX INVOICE
                                    </h1>

                                    <div style="
                                        width:350px;
                                        margin:5px auto;
                                        text-align:center;
                                    ">

                                        <svg width="330"
                                             height="4"
                                             xmlns="http://www.w3.org/2000/svg">

                                            <defs>

                                                <linearGradient id="horizontalFade"
                                                                x1="0%"
                                                                y1="0%"
                                                                x2="100%"
                                                                y2="0%">

                                                    <stop offset="0%"
                                                          stop-color="#f39223"
                                                          stop-opacity="1"/>

                                                    <stop offset="82%"
                                                          stop-color="#f39223"
                                                          stop-opacity="1"/>

                                                    <stop offset="100%"
                                                          stop-color="#f39223"
                                                          stop-opacity="0"/>

                                                </linearGradient>

                                            </defs>

                                            <rect x="90"
                                                  y="1"
                                                  width="155"
                                                  height="2"
                                                  fill="url(#horizontalFade)"/>

                                        </svg>

                                    </div>

                                    <div style="
                                        font-size:16px;
                                        text-align:center;
                                        margin-top:10px;
                                    ">

                                        # <span t-field="o.name"/>

                                    </div>

                                </td>

                            </tr>

                        </table>

                        <!-- ADDRESS + META -->
                        <table style="
                            width:100%;
                            font-size:13px;
                            border-collapse:collapse;
                            margin-top:35px;
                            margin-bottom:35px;
                        ">

                            <tr>

                                <!-- BILL TO -->
                                <td style="
                                    width:55%;
                                    vertical-align:top;
                                ">

                                    <table style="
                                        width:100%;
                                        border-collapse:collapse;
                                    ">

                                        <strong style="color:#1a3a5a;">
                                            Bill To
                                        </strong>

                                        <tr>

                                            <td style="
                                                width:8px;
                                                padding:0;
                                                vertical-align:top;
                                            ">

                                                <svg width="8"
                                                     height="130"
                                                     xmlns="http://www.w3.org/2000/svg">

                                                    <defs>

                                                        <linearGradient id="verticalFade"
                                                                        x1="0%"
                                                                        y1="0%"
                                                                        x2="0%"
                                                                        y2="100%">

                                                            <stop offset="0%"
                                                                  stop-color="#f39223"
                                                                  stop-opacity="1"/>

                                                            <stop offset="100%"
                                                                  stop-color="#f39223"
                                                                  stop-opacity="0"/>

                                                        </linearGradient>

                                                    </defs>

                                                    <rect x="0"
                                                          y="0"
                                                          width="2"
                                                          height="130"
                                                          fill="url(#verticalFade)"/>

                                                </svg>

                                            </td>

                                            <td style="width:15px;"></td>

                                            <td style="
                                                vertical-align:top;
                                                font-size:13px;
                                                line-height:1.7;
                                            ">

                                                <strong>
                                                    <span t-esc="o.partner_id.name"/>
                                                </strong>

                                                <br/>

                                                <span t-esc="o.partner_id.street or ''"/>

                                                <t t-if="o.partner_id.street2">
                                                    <br/>
                                                    <span t-esc="o.partner_id.street2"/>
                                                </t>

                                                <br/>

                                                <span t-esc="o.partner_id.city or ''"/>

                                                <t t-if="o.partner_id.state_id">
                                                    ,
                                                    <span t-esc="o.partner_id.state_id.name"/>
                                                </t>

                                                -

                                                <span t-esc="o.partner_id.country_id.name or ''"/>

                                                <br/>

                                                <t t-if="o.partner_id.vat">

                                                    <p style="margin-top:15px">

                                                        <strong>
                                                            TRN
                                                            <span t-esc="o.partner_id.vat"/>
                                                        </strong>

                                                    </p>

                                                </t>

                                            </td>

                                        </tr>

                                    </table>

                                </td>

                                <!-- META -->
                                <td style="
                                    width:45%;
                                    vertical-align:top;
                                    padding-left:40px;
                                ">

                                    <table style="
                                        width:100%;
                                        border-collapse:collapse;
                                    ">

                                        <tr>

                                            <td style="
                                                padding:4px 0;
                                                width:45%;
                                                font-weight:bold;
                                                color:#1a3a5a;
                                            ">
                                                Invoice Date
                                            </td>

                                            <td style="padding:4px 0;">

                                                :
                                                <span t-field="o.invoice_date"/>

                                            </td>

                                        </tr>

                                        <tr>

                                            <td style="
                                                padding:4px 0;
                                                font-weight:bold;
                                                color:#1a3a5a;
                                            ">
                                                Due Date
                                            </td>

                                            <td style="padding:4px 0;">

                                                :
                                                <span t-field="o.invoice_date_due"/>

                                            </td>

                                        </tr>

                                        <tr>

                                            <td style="
                                                padding:4px 0;
                                                font-weight:bold;
                                                color:#1a3a5a;
                                            ">
                                                Payment Terms
                                            </td>

                                            <td style="padding:4px 0;">

                                                :
                                                <span t-field="o.invoice_payment_term_id.name"/>

                                            </td>

                                        </tr>

                                       <tr>

                                            <td style="
                                                padding:5px 0;
                                                font-weight:bold;
                                                color:#1a3a5a;
                                            ">
                                                Sales Order Ref
                                            </td>

                                            <td>
                                                :
                                                <span t-esc="o.ref or ''"/>
                                            </td>

                                        </tr>
<t t-set="sale_order" t-value="o.line_ids.sale_line_ids.order_id[:1]"/>

<t t-if="sale_order and sale_order.x_studio_customer_po_ref"><tr>

                                            <td style="
                                                padding:5px 0;
                                                font-weight:bold;
                                                color:#1a3a5a;
                                            ">
                                                Customer PO Ref
                                            </td>

                                            <td>
                                                :
                                               <span t-esc="sale_order.x_studio_customer_po_ref"/>
                                            </td>

                                        </tr></t>
                                    </table>

                                </td>

                            </tr>
<t t-set="pickings"
   t-value="o.invoice_line_ids.sale_line_ids.order_id.picking_ids.filtered(lambda p: p.state != 'cancel')"/>

<t t-if="pickings"><tr>

                                            <td style="
                                                padding:5px 0;
                                                font-weight:bold;
                                                color:#1a3a5a;
                                            ">
                                              Delivery Note Number
                                            </td>

                                            <td>
                                                :
                                               <t t-foreach="pickings" t-as="p">
                <span t-esc="p.name"/>
                <t t-if="not loop.last">, </t>
          
                                            </td>

                                        </tr>
                                      
                                        </t>
                                    </table>

                                </td>

                            </tr>
                        </table>

                        <!-- PRODUCT TABLE -->
                        <table style="
                            width:100%;
                            border-collapse:collapse;
                            margin-bottom:20px;
                        ">

                            <thead>

                                <tr style="
                                    background:#4b4b4b;
                                    color:#fff;
                                ">

                                    <th style="
                                        padding:10px;
                                        width:5%;
                                        text-align:center;
                                        border-top-left-radius:10px;
                                        border-bottom-left-radius:10px;
                                    ">
                                        SN
                                    </th>

                                    <th style="
                                        padding:10px;
                                        width:55%;
                                        text-align:center;
                                    ">
                                        Product Specification
                                    </th>

                                    <th style="
                                        padding:10px;
                                        width:7%;
                                        text-align:center;
                                    ">
                                        Qty
                                    </th>

                                    <th style="
                                        padding:10px;
                                        width:11%;
                                        text-align:right;
                                    ">
                                        Unit Price
                                    </th>

                                    <th style="
                                        padding:10px;
                                        width:12%;
                                        text-align:right;
                                        border-top-right-radius:10px;
                                        border-bottom-right-radius:10px;
                                    ">
                                        Total Price
                                    </th>

                                </tr>

                            </thead>

                            <tbody>

                                <t t-set="sn" t-value="1"/>

                                <t t-foreach="o.invoice_line_ids" t-as="line">

                                    <tr>

                                        <td style="
                                           font-size:15px;
                                           padding-top:15px;
                                           text-align:center;
                                           vertical-align:top;
                                        ">
                                            <span t-esc="sn"/>
                                        </td>

                                        <td style="
                                            padding-top:15px;
                                            vertical-align:top;
                                            width:55%;
                                            white-space:normal;
                                            word-break:break-word;
                                        ">

                                            <div style="
                                                font-weight:bold;
                                                margin-bottom:6px;
                                                font-size:15px;
                                                line-height:1.5;
                                                width:100%;
                                            ">

                                                <span t-esc="line.product_id.name"/>

                                            </div>

                                        </td>

                                        <td style="
                                          padding-top:15px;
                                          font-size:15px;
                                          text-align:center;
                                          vertical-align:top;
                                        ">
                                            <span t-esc="int(line.quantity)"/>
                                        </td>

                                        <td style="
                                            padding-top:15px;
                                            font-size:15px;
                                            text-align:center;
                                            vertical-align:top;
                                        ">
                                            <span t-esc="'{:,.2f}'.format(line.price_unit)"/>
                                        </td>

                                        <td style="
                                          padding-top:15px;
                                          font-size:15px;
                                          text-align:center;
                                          vertical-align:top;
                                        ">
                                            <span t-esc="'{:,.2f}'.format(line.price_subtotal)"/>
                                        </td>

                                    </tr>

                                    <tr>

                                        <td></td>

                                        <td colspan="4" style="
                                            font-weight:bold;
                                            font-size:11px;
                                        ">

                                            <span>Taxes: </span>

                                            <span t-esc="', '.join(line.tax_ids.mapped('name'))"/>

                                        </td>

                                    </tr>

                                    <tr style="border-bottom:1px solid #d9d9d9;">

                                        <td></td>

                                        <td colspan="4" style="
                                            font-size:12px;
                                            color:#666;
                                            line-height:1.7;
                                            white-space:normal;
                                            word-break:break-word;
                                        ">

                                            <span t-esc="line.product_id.description or ''"/>

                                        </td>

                                    </tr>

                                    <t t-set="sn" t-value="sn + 1"/>

                                </t>

                            </tbody>

                        </table>

                        <!-- TOTAL -->
                        <table style="
                            width:100%;
                            margin-top:20px;
                            border-collapse:collapse;
                        ">

                            <tr>

                                <td style="
                                    width:55%;
                                    vertical-align:middle;
                                    font-size:15px;
                                    padding-top:40px;
                                    padding-left:20px;
                                    text-align:left;
                                ">

                                    <div style="font-size:13px;">

                                        <strong>
                                            Amount in Words:
                                            <span t-esc="o.currency_id.name"/>
                                            <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/>
                                            only.
                                        </strong>

                                    </div>

                                </td>

                                <td style="width:45%;">

                                    <table style="
                                        width:100%;
                                        border-collapse:collapse;
                                        text-align:right;
                                    ">

                                        <tr>

                                            <td style="
                                                padding:5px;
                                                font-weight:bold;
                                            ">
                                                Sub Total
                                            </td>

                                            <td style="padding:5px;">
                                                <span t-raw="cur_symbol + ' ' + ('%.2f' % o.amount_untaxed)"/>
                                            </td>

                                        </tr>

                                        <tr>

                                            <td style="
                                                padding:5px;
                                                font-weight:bold;
                                            ">
                                                VAT
                                            </td>

                                            <td style="padding:5px;">
                                                <span t-raw="cur_symbol + ' ' + ('%.2f' % o.amount_tax)"/>
                                            </td>

                                        </tr>

                                        <tr style="
                                            font-size:16px;
                                            color:#1a3a5a;
                                        ">

                                            <td style="
                                                padding:10px 5px;
                                                font-weight:bold;
                                            ">
                                                Total
                                            </td>

                                            <td style="
                                                padding:10px 5px;
                                                font-weight:bold;
                                            ">
                                                <span t-raw="cur_symbol + ' ' + ('%.2f' % o.amount_total)"/>
                                            </td>

                                        </tr>

                                    </table>

                                </td>

                            </tr>

                        </table>

                        <!-- NOTES -->
                        <div style="margin-top:60px;padding-left:20px;">

                            <strong style="
                                font-size:14px;
                                border-bottom:1px solid #e58b39;
                                padding-bottom:2px;
                            ">
                                Notes
                            </strong>

                            <div style="
                                margin-top:10px;
                                font-size:14px;
                                color:#555;
                            ">

                                <t t-if="o.narration">
                                    <span t-esc="o.narration"/>
                                </t>

                                <t t-else="">
                                    Thanks for giving us the opportunity to serve you
                                </t>

                            </div>

                        </div>

                        <!-- FOOTER -->
                        <div class="fixed-footer">

                            <div style="
                                padding:0 40px;
                                font-size:11px;
                                color:#555;
                            ">

                                <div style="
                                    margin-bottom:5px;
                                    color:#888;
                                    font-style:italic;
                                ">
                                    This document is electronically generated and valid without signature or company stamp.
                                </div>

                                <div style="
                                    border-top:1px solid #1f3b73;
                                    padding-top:6px;
                                    text-align:center;
                                ">

                                    <t t-if="o.company_id.street2">
                                        <span t-esc="o.company_id.street2"/>
                                    </t>

                                    <span t-esc="o.company_id.city or ''"/>
                                    -
                                    <span t-esc="o.company_id.country_id.name or ''"/>

                                    <br/>

                                    CR No:
                                    <span t-esc="o.company_id.company_registry or 'N/A'"/>

                                    |

                                    <span t-esc="o.company_id.email or ''"/>

                                    |

                                    <span t-esc="o.company_id.website or ''"/>

                                </div>

                            </div>

                            <!-- COLOR BAR -->
                            <div style="
                                width:auto;
                                height:25px;
                                overflow:hidden;
                                margin-top:5px;
                                margin-left:-40px;
                                margin-right:-50px;
                            ">

                                <svg width="100%"
                                     height="25"
                                     viewBox="0 0 1000 25"
                                     preserveAspectRatio="none"
                                     xmlns="http://www.w3.org/2000/svg">

                                    <polygon points="0,0 260,0 240,25 0,25"
                                             fill="#1f3b73"/>

                                    <polygon points="260,0 1000,0 1000,25 240,25"
                                             fill="#e58b39"/>

                                </svg>

                            </div>

                        </div> <!-- fixed-footer -->

                    </div> <!-- page -->

                </main>

            </t>

        </t>

    </template>

</odoo>