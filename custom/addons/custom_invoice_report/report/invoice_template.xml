<odoo>

    <template id="invoice_template">

        <t t-call="web.html_container">
<meta charset="UTF-8"/>


    <t t-foreach="docs" t-as="o">

        <t t-set="company" t-value="o.company_id"/>

        <t t-call="custom_invoice_report.external_layout_ipower4">

                <!-- SAFE CURRENCY -->
                <t t-set="cur_symbol"
                   t-value="'&#8364;' if o.currency_id.name == 'EUR' else o.currency_id.symbol"/>

               <style>
                   

    html, body {
        margin: 0 !important;
        padding: 0 !important;
    }

    .article {
        margin: 0 !important;
        padding: 0 !important;
    }
.page {
    padding: 0 40px !important;
}
  table,
tr,
td,
th {
    border: none ;
}
table {
    border-collapse: separate !important;
    border-spacing: 0 !important;
}

td, th {
    border: 0 ;
    outline: 0 !important;
}
                </style>

                <div class="page"
                     style="position:relative;
                            color:#333; padding:100px 0 0 0;
                            line-height:1.4;
                            font-family: Helvetica, Arial, sans-serif !important;">

                        <!-- WATERMARK 
                        <div style="
                            position:absolute;
                            top:55%;
                            left:25%;
                            opacity:0.10;
                            transform:translate(-50%, -50%) rotate(-25deg);
                            z-index:0;
                            width:420px;
                            text-align:center;
                        ">

                            <img t-if="o.company_id.logo"
                                 t-att-src="image_data_uri(o.company_id.logo)"
                                 style="width:100%;"/>

                        </div>-->

                        <!-- ADDRESS + META -->
                        <table style="
                            width:100%;
                            font-size:15px;
                            border-collapse:collapse;
                            margin-top:35px;
                            margin-bottom:35px;
                        ">

                            <tr>

                                <!-- BILL TO -->
                                <td style="
                                    width:55%;
                                    vertical-align:top;
                                ">

                                    <table style="
                                        width:100%;font-size:15px;
                                        border-collapse:collapse;
                                    ">

                                        <strong style="color:#1a3a5a;">
                                            Bill To
                                        </strong>

                                        <tr>

                                            <td style="
                                                width:8px;
                                                padding:0;
                                                vertical-align:top;
                                            ">

                                                <svg width="8"
                                                     height="130"
                                                     xmlns="http://www.w3.org/2000/svg">

                                                    <defs>

                                                        <linearGradient id="verticalFade"
                                                                        x1="0%"
                                                                        y1="0%"
                                                                        x2="0%"
                                                                        y2="100%">

                                                            <stop offset="0%"
                                                                  stop-color="#f39223"
                                                                  stop-opacity="1"/>

                                                            <stop offset="100%"
                                                                  stop-color="#f39223"
                                                                  stop-opacity="0"/>

                                                        </linearGradient>

                                                    </defs>

                                                    <rect x="0"
                                                          y="0"
                                                          width="2"
                                                          height="130"
                                                          fill="url(#verticalFade)"/>

                                                </svg>

                                            </td>

                                            <td style="width:15px;"></td>

                                            <td style="
                                                vertical-align:top;
                                                font-size:15px;
                                                line-height:1.7;
                                            ">

                                                <strong>
                                                      <span t-esc="o.partner_id.parent_id.name if o.partner_id.parent_id else o.partner_id.name"/>
   
                                                    </strong>

                                                <br/>

                                                <span t-esc="o.partner_id.street or ''"/>

                                                <t t-if="o.partner_id.street2">
                                                    <br/>
                                                    <span t-esc="o.partner_id.street2"/>
                                                </t>

                                                <br/>

                                                <span t-esc="o.partner_id.city or ''"/>

                                               <!-- <t t-if="o.partner_id.state_id">
                                                    ,
                                                    <span t-esc="o.partner_id.state_id.name"/>
                                                </t>-->

                                                -

                                                <span t-esc="o.partner_id.country_id.name or ''"/>

                                                <br/>

                                                <t t-if="o.partner_id.vat">

                                                    <p style="margin-top:15px">

                                                        <strong>
                                                            TRN
                                                            <span t-esc="o.partner_id.vat"/>
                                                        </strong>

                                                    </p>

                                                </t>
<!-- ATTN ONLY IF CONTACT PERSON -->
<t t-if="o.partner_id.parent_id">
    <p style="margin-top:5px">

        <strong>Attn</strong>

        <t t-if="o.partner_id.x_studio_salutation">
            <span t-esc="o.partner_id.x_studio_salutation"/>
        </t>

        <span t-esc="o.partner_id.name"/>

    </p>
</t>
                                            </td>

                                        </tr>

                                    </table>

                                </td>

                                <!-- META -->
                                <td style="
                                    width:45%;font-size:15px;
                                    vertical-align:top;
                                    padding-left:40px;
                                ">

                                    <table style="
                                        width:100%;font-size:15px;
                                        border-collapse:collapse;
                                    ">

                                      <t t-if="o.invoice_date">  <tr>

                                            <td style="
                                                padding:4px 0;
                                                width:45%;font-size:15px;
                                                font-weight:bold;
                                                color:#1a3a5a;
                                            ">
                                                Invoice Date
                                            </td>

                                            <td style="padding:4px 0;">

                                                :
                                              
 <span t-field="o.invoice_date" t-options='{"format": "dd MMMM yyyy"}'/>
                                            </td>

                                        </tr></t>

                                        <tr>

                                            <td style="
                                                padding:4px 0;font-size:15px;
                                                font-weight:bold;
                                                color:#1a3a5a;
                                            ">
                                                Due Date
                                            </td>

                                            <td style="padding:4px 0;">

                                                :
                                             
 <span t-field="o.invoice_date_due" t-options='{"format": "dd MMMM yyyy"}'/>
                                            </td>

                                        </tr>

                                       <!-- <tr>

                                            <td style="
                                                padding:4px 0;
                                                font-weight:bold;
                                                color:#1a3a5a;
                                            ">
                                                Payment Terms
                                            </td>

                                            <td style="padding:4px 0;">

                                                :
                                                <span t-field="o.invoice_payment_term_id.name"/>

                                            </td>

                                        </tr>-->

                                       <tr>

                                            <td style="
                                                padding:5px 0;font-size:15px;
                                                font-weight:bold;
                                                color:#1a3a5a;
                                            ">
                                                Sales Order Ref
                                            </td>

                                            <td>
                                                :
                                                <span t-esc="o.ref or ''"/>
                                            </td>

                                        </tr>
<t t-set="sale_order" t-value="o.line_ids.sale_line_ids.order_id[:1]"/>

<t t-if="sale_order and sale_order.x_studio_customer_po_ref"><tr>

                                            <td style="
                                                padding:5px 0;font-size:15px;
                                                font-weight:bold;
                                                color:#1a3a5a;
                                            ">
                                                Customer PO Ref
                                            </td>

                                            <td>
                                                :
                                               <span t-esc="sale_order.x_studio_customer_po_ref"/>
                                            </td>

                                        </tr></t>

                                        <tr>
    <td style="
        padding:4px 0;font-size:15px;
        font-weight:bold;
        color:#1a3a5a;
    ">
        Delivery Note No
    </td>

    <td style="padding:4px 0;">
        :
        <t t-set="pickings"
           t-value="o.invoice_line_ids.sale_line_ids.order_id.picking_ids.filtered(lambda p: p.state == 'done')"/>

        <t t-set="pickings"
   t-value="o.invoice_line_ids.sale_line_ids.order_id.picking_ids.filtered(lambda p: p.state == 'done')"/>

<span t-esc="', '.join(pickings.mapped('name'))"/>
    </td>
</tr>
                                    </table>

                                </td>

                            </tr>

                        </table>

                        <!-- PRODUCT TABLE -->
                        <table style="
                            width:100%;
                            border-collapse:collapse;
                            margin-bottom:20px;
                        ">

                            <thead>

                                <tr style="
                                    background:#4b4b4b;
                                    color:#fff;
                                ">

                                    <th style="
                                        padding:10px;
                                        width:5%;
                                        text-align:center;
                                        border-top-left-radius:10px;
                                        border-bottom-left-radius:10px;
                                    ">
                                        SN
                                    </th>

                                    <th style="
                                        padding:10px;
                                        width:45%;
                                        text-align:center;
                                    ">
                                        Product Specification
                                    </th>
   <th style="
                                        padding:10px;
                                        width:12%;
                                        text-align:center;
                                    ">
                                      HS Code
                                    </th>
                                    <th style="
                                        padding:10px;
                                        width:7%;
                                        text-align:center;
                                    ">
                                        Qty
                                    </th>

                                    <th style="
                                        padding:10px;
                                        width:11%;
                                        text-align:right;
                                    ">
                                        Unit Price
                                    </th>

                                    <th style="
                                        padding:10px;
                                        width:12%;
                                        text-align:right;
                                        border-top-right-radius:10px;
                                        border-bottom-right-radius:10px;
                                    ">
                                        Total Price
                                    </th>

                                </tr>

                            </thead>

<tbody>

    <t t-set="sn" t-value="1"/>

    <t t-foreach="o.invoice_line_ids" t-as="line">

        <!-- SECTION -->
        <t t-if="line.display_type == 'line_section'">

            <tr>
                <td colspan="6"
                    style="
                        padding-top:15px;
                        padding-bottom:10px;
                        font-size:15px;
                        font-weight:bold;padding-left:15px;
                        color:#1a3a5a;
                        border-bottom:1px solid #d9d9d9;
                        background:#f7f7f7;
                    ">
                    <span t-field="line.name"/>
                </td>
            </tr>

        </t>

        <!-- NOTE -->
        <t t-elif="line.display_type == 'line_note'">

            <tr>
                <td></td>
                <td colspan="5"
                    style="
                        padding:10px 0;
                        font-style:italic;
                        color:#666;
                    ">
                    <span t-field="line.name"/>
                </td>
            </tr>

        </t>

        <!-- PRODUCT LINE -->
        <t t-else="">

            <tr>

                <td style="
                   font-size:15px;
                   padding-top:15px;
                   text-align:center;
                   vertical-align:top;
                ">
                    <span t-esc="sn"/>
                </td>

                <td style="
                    padding-top:15px;
                    vertical-align:top;
                    width:45%;
                    white-space:normal;
                    word-break:break-word;
                ">
                    <div style="
                        font-weight:bold;
                        margin-bottom:6px;
                        font-size:15px;
                        line-height:1.5;
                        width:100%;
                    ">
                       <t t-if="line.product_id">
    <span t-field="line.product_id.name"/>
</t>
<t t-else="">
    <span t-field="line.name"/>
</t>
                    </div>
                </td>

                <td style="
                    padding-top:15px;
                    font-size:15px;
                    text-align:center;
                    vertical-align:top;
                ">
                    <span t-esc="line.product_id.product_tmpl_id.hs_code"/>
                </td>

                <td style="
                    padding-top:15px;
                    font-size:15px;
                    text-align:center;
                    vertical-align:top;
                ">
                    <span t-esc="int(line.quantity)"/>
                </td>

                <td style="
                    padding-top:15px;
                    font-size:15px;
                    text-align:center;
                    vertical-align:top;
                ">
                    <span t-esc="'{:,.2f}'.format(line.price_unit)"/>
                </td>

                <td style="
                    padding-top:15px;
                    font-size:15px;
                    text-align:center;
                    vertical-align:top;
                ">
                    <span t-esc="'{:,.2f}'.format(line.price_subtotal)"/>
                </td>

            </tr>

            <!-- ORDERING CODE -->
            <t t-set="ordering_code"
   t-value="line.product_id.product_tmpl_id.x_studio_sku_code"/>

<t t-if="ordering_code">
            <tr>
                <td></td>

                <td colspan="5"
                    style="
                        font-weight:bold;
                        font-size:13px;
                    ">

                    <span>Ordering Code: </span>

                    <span t-esc="line.product_id.product_tmpl_id.x_studio_sku_code or ''"/>

                </td>
            </tr>
</t>
            <!-- SERIAL NUMBERS -->
            <tr>

                <td></td>

                <td colspan="5"
                    style="
                      margin-bottom:6px;
                        font-size:11px;
                    ">

                    <t t-if="line.sale_line_ids.move_ids.move_line_ids.filtered(lambda ml: ml.lot_id)">

                        <t t-set="serials"
   t-value="', '.join(line.sale_line_ids.move_ids.move_line_ids.filtered(lambda ml: ml.lot_id).mapped('lot_id.name'))"/>

<t t-if="serials">
    <span><strong>Serial No:</strong></span>
    <small> <span t-esc="serials"/> </small>
</t>

                    </t>

                </td>

            </tr>

            <!-- DESCRIPTION -->
            <tr>
    <td style="border-bottom:1px solid #d9d9d9;"></td>

                <td colspan="4"
                    style="
                        padding-bottom:15px;border-bottom:1px solid #d9d9d9 !important;
                        font-size:12px;
                        color:#666;
                        line-height:1.7;
                        white-space:normal;
                        word-break:break-word;
                    ">

                    <span t-esc="line.product_id.description or ''"/>

                </td>

            </tr>

            <t t-set="sn" t-value="sn + 1"/>

        </t>

    </t>

</tbody>

                        </table>

                        <!-- TOTAL -->
                        <table style="
                            width:100%;
                            margin-top:20px;
                            border-collapse:collapse;
                        ">

                            <tr>

                                <td style="
                                    width:55%;
                                    vertical-align:middle;
                                    font-size:15px;
                                    padding-top:40px;
                                    padding-left:20px;
                                    text-align:left;
                                ">

                                    <div style="font-size:13px;">

                                        <strong>
                                            Amount in Words:
                                            <span t-esc="o.currency_id.name"/>
                                            <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/>
                                            only.
                                        </strong>

                                    </div>

                                </td>

                                <td style="width:45%;">

                                    <table style="
                                        width:100%;
                                        border-collapse:collapse;
                                        text-align:right;padding-right:20px;
                                    ">

                                        <tr>

                                            <td style="
                                                padding:5px;
                                                font-weight:bold;
                                            ">
                                                Sub Total
                                            </td>

                                            <td style="padding:5px;">
                                              
                                                 <span t-esc="cur_symbol + ' {:,.2f}'.format(o.amount_untaxed)"/>
                                            </td>

                                        </tr>

                                    <t t-if="o.tax_totals and o.tax_totals.get('subtotals')">

    <t t-foreach="o.tax_totals['subtotals']" t-as="subtotal">

        <t t-foreach="subtotal['tax_groups']" t-as="tax_group">

            <tr>

                <td style="padding:5px;font-weight:bold;">
                    VAT (
                    <span t-esc="
                        int(
                            tax_group.get('involved_tax_ids')
                            and env['account.tax'].browse(
                                tax_group['involved_tax_ids'][0]
                            ).amount
                            or 0
                        )
                    "/>%)
                </td>

                <td style="padding:5px;text-align:right;">
                    <span t-esc="o.currency_id.symbol"/>
                    <span t-esc="'{:,.2f}'.format(tax_group['tax_amount_currency'])"/>
                </td>

            </tr>

        </t>

    </t>
 </t>

                                        <tr style="
                                            font-size:16px;
                                            color:#1a3a5a;
                                        ">

                                            <td style="
                                                padding:10px 5px;
                                                font-weight:bold;
                                            ">
                                                Total
                                            </td>

                                            <td style="
                                                padding:10px 5px;
                                                font-weight:bold;
                                            ">
                                               
                                                <span t-esc="cur_symbol + ' {:,.2f}'.format(o.amount_total)"/>
                                            </td>

                                        </tr>

                                    </table>

                                </td>

                            </tr>

                        </table>

                        <!-- NOTES -->
                        <div style="margin-top:60px;padding-left:20px;">

                            <strong style="
                                font-size:14px;
                                border-bottom:1px solid #e58b39;
                                padding-bottom:2px;
                            ">
                                Notes
                            </strong>

                            <div style="
                                margin-top:10px;
                                font-size:14px;
                                color:#555;
                            ">

                                <t t-if="o.narration">
                                    <span t-esc="o.narration"/>
                                </t>

                                <t t-else="">
                                    Thanks for giving us the opportunity to serve you
                                </t>

                            </div>

                        </div> <div style="margin-top:60px;padding-left:20px;">

    <strong style="
        font-size:14px;
        border-bottom:1px solid #e58b39;
        padding-bottom:2px;
    ">
        Our Bank Info:
    </strong>

    <div style="
        margin-top:10px;
        font-size:14px;
        color:#555;
    ">

        <t t-if="o.company_bank_id">

            <table style="font-size:13px; border-collapse:collapse;">

                <tr>
                    <td style="padding-right:10px;">
                        <strong>Account Name:</strong>
                    </td>
                    <td>
                        <span t-esc="o.company_bank_id.acc_holder_name or o.company_id.name"/>
                    </td>
                </tr>

                <tr>
                    <td style="padding-right:10px;">
                        <strong>A/C Number:</strong>
                    </td>
                    <td>
                        <span t-esc="o.company_bank_id.acc_number"/>
                    </td>
                </tr>

              <tr t-if="o.company_bank_id.iban">
                    <td style="padding-right:10px;">
                        <strong>IBAN Number:</strong>
                    </td>
                    <td>
                    <span t-esc="o.company_bank_id.iban"/>
                    </td>
                </tr>

                <tr t-if="o.company_bank_id.bank_id">
                    <td style="padding-right:10px;">
                        <strong>Bank Name:</strong>
                    </td>
                    <td>
                        <span t-esc="o.company_bank_id.bank_id.name"/>
                    </td>
                </tr>

              

            </table>

        </t>

    </div>

</div>  <!-- fixed-footer -->

                    </div> <!-- page -->

                </t>

            </t>

        </t>

    </template>

</odoo>