<odoo>
    <record id="invoice_form_custom_print" model="ir.ui.view">
    <field name="name">account.move.form.custom.print</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">

        <xpath expr="//header" position="inside">
         <button name="action_preview_custom_invoice"
                        type="object"
                        string="Preview"
                        class="btn-secondary"
                        icon="fa-eye"
                         invisible="move_type != 'out_invoice'"/>

            <button name="action_print_custom_invoice"
                    type="object"
                    string="Print Invoice"
                    class="btn-primary"
                    icon="fa-print" invisible="move_type != 'out_invoice'"/>

        </xpath>

    </field>
</record>
</odoo>