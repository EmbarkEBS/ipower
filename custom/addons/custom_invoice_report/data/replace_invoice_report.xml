<?xml version="1.0" encoding="utf-8"?>

<odoo>

<!-- Replace Odoo invoice report with custom report -->
<record id="account.account_invoices_without_payment" model="ir.actions.report">
    <field name="report_name">custom_invoice_report.invoice_template</field>
    <field name="report_file">custom_invoice_report.invoice_template</field>
    <field name="print_report_name">'Invoice- %s' % (object.name)</field>
</record>


</odoo>
