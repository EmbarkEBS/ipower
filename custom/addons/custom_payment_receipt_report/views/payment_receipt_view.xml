<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_payment_form_receipt"
            model="ir.ui.view">

        <field name="name">
            account.payment.form.receipt
        </field>

        <field name="model">
            account.payment
        </field>

        <field name="inherit_id"
               ref="account.view_account_payment_form"/>

        <field name="arch"
               type="xml">

            <xpath expr="//header"
                   position="inside">

                <button
                    name="action_print_payment_receipt"
                    type="object"
                    string="Print Receipt"
                    class="btn-primary"/>

            </xpath>

        </field>

    </record>

</odoo>