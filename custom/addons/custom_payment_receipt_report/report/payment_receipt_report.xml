<?xml version="1.0" encoding="utf-8"?>
<odoo>
<record id="paperformat_payment_receipt"
            model="report.paperformat">

        <field name="name">Payment Receipt A4</field>

        <field name="default" eval="False"/>

        <field name="format">A4</field>

        <field name="orientation">Portrait</field>

        <field name="margin_top">15</field>

        <field name="margin_bottom">0</field>

        <field name="margin_left">7</field>

        <field name="margin_right">7</field>

        <field name="header_line" eval="False"/>

        <field name="header_spacing">5</field>

        <field name="dpi">90</field>

    </record>


    <record id="action_payment_receipt"
            model="ir.actions.report">

        <field name="name">Payment Receipt/field>

        <field name="model">account.payment</field>

        <field name="report_type">qweb-pdf</field>

        <field name="report_name">custom_payment_receipt_report.payment_receipt_template</field>

        <field name="report_file">custom_payment_receipt_report.payment_receipt_template</field>

        <field name="binding_model_id"
               ref="account.model_account_payment"/>

        <field name="binding_type">report</field>
<field name="paperformat_id"
       ref="custom_payment_receipt_report.paperformat_payment_receipt"/>
        <field name="print_report_name">
            'Receipt - %s' % (object.name)
        </field>

    </record>

</odoo>