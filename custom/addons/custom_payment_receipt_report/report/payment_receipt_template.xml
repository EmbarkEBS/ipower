<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="payment_receipt_template">

        <t t-call="web.html_container">

            <t t-foreach="docs" t-as="o">

                <div class="page" style="padding:10px 40px;font-family:Helvetica,Arial,sans-serif;">

                    <style>
                        .table{
                            width:100%;
                            border-collapse:collapse;
                        }
                        .table th,
                        .table td{
                            border:1px solid #cccccc;
                            padding:6px;
                        }
                    </style>

                    <!-- HEADER -->

                    <table style="width:100%;margin-bottom:20px;">
                        <tr>

                            <td style="width:50%;vertical-align:top;">

                                <img t-if="o.company_id.logo"
                                     t-att-src="image_data_uri(o.company_id.logo)"
                                     style="max-height:80px;"/>

                            </td>

                            <td style="text-align:right;vertical-align:top;">

                                <strong style="font-size:18px;">
                                    <span t-esc="o.company_id.name"/>
                                </strong>

                                <br/>

                                <span t-esc="o.company_id.street or ''"/>

                                <br/>

                                <span t-esc="o.company_id.city or ''"/>
                                ,
                                <span t-esc="o.company_id.country_id.name or ''"/>

                                <br/>

                                <strong>
                                    TRN:
                                    <span t-esc="o.company_id.vat or ''"/>
                                </strong>

                            </td>

                        </tr>
                    </table>

                    <!-- TITLE -->

                    <div style="text-align:center;margin-bottom:20px;">

                        <h2 style="color:#1f3b73;">
                            PAYMENT RECEIPT
                        </h2>

                    </div>

                    <!-- RECEIPT DETAILS -->

                 <table style="width:100%;margin-bottom:20px;">
    <tr>

        <td width="50%">
            <strong>Receipt No:</strong>
            <span t-field="o.name"/>

            <br/><br/>

            <strong>Date:</strong>
            <span t-field="o.date"/>
        </td>

        <td width="50%">
            <strong>Partner:</strong>
            <span t-field="o.partner_id"/>

            <br/><br/>

            <strong>Reference:</strong>
            <span t-esc="o.memo or ''"/>
        </td>

    </tr>
</table>

                    <!-- PAYMENT TABLE -->

                    <table class="table">

                        <thead>

                            <tr style="background:#1f3b73;color:white;">

                                <th>Description</th>
                                <th style="text-align:right;">Amount</th>

                            </tr>

                        </thead>

                        <tbody>

                            <tr>

                                <td>Payment Received</td>

                                <td style="text-align:right;">

                                    <span t-field="o.amount"
                                          t-options="{'widget':'monetary','display_currency':o.currency_id}"/>

                                </td>

                            </tr>

                        </tbody>

                    </table>

                    <!-- INVOICES -->

                    <t t-if="o.reconciled_invoice_ids">

                        <br/>

                        <h4 style="color:#1f3b73;">
                            Settled Invoices
                        </h4>

                        <table class="table">

                            <thead>

                                <tr style="background:#1f3b73;color:white;">

                                    <th>Invoice</th>
                                    <th>Date</th>
                                    <th>Reference</th>
                                    <th style="text-align:right;">Amount</th>

                                </tr>

                            </thead>

                            <tbody>

                                <t t-foreach="o.reconciled_invoice_ids"
                                   t-as="inv">

                                    <tr>

                                        <td>
                                            <span t-esc="inv.name"/>
                                        </td>

                                        <td>
                                            <span t-esc="inv.invoice_date"/>
                                        </td>

                                        <td>
                                            <span t-esc="inv.ref or ''"/>
                                        </td>

                                        <td style="text-align:right;">

                                            <span t-field="inv.amount_total"
                                                  t-options="{'widget':'monetary','display_currency':inv.currency_id}"/>

                                        </td>

                                    </tr>

                                </t>

                            </tbody>

                        </table>

                    </t>

                    <!-- TOTAL -->

                    <table style="width:35%;margin-top:20px;margin-left:auto;">

                        <tr>

                            <td style="
                                background:#1f3b73;
                                color:white;
                                padding:8px;
                                font-weight:bold;
                            ">
                                Total Received
                            </td>

                            <td style="
                                text-align:right;
                                border:1px solid #cccccc;
                                padding:8px;
                            ">

                                <span t-field="o.amount"
                                      t-options="{'widget':'monetary','display_currency':o.currency_id}"/>

                            </td>

                        </tr>

                    </table>

                    <!-- FOOTER -->

                    <div style="margin-top:60px;font-size:11px;">

                        <div style="color:#888;font-style:italic;">
                            This document is electronically generated and valid without signature or company stamp.
                        </div>

                        <div style="
                            border-top:1px solid #1f3b73;
                            padding-top:6px;
                            text-align:center;
                            margin-top:10px;
                        ">

                            <span t-esc="o.company_id.city or ''"/>
                            -
                            <span t-esc="o.company_id.country_id.name or ''"/>

                            <br/>

                            CR No:
                            <span t-esc="o.company_id.company_registry or 'N/A'"/>

                            |

                            <span t-esc="o.company_id.email or ''"/>

                            |

                            <span t-esc="o.company_id.website or ''"/>

                        </div>

                        <div style="margin-top:5px;">

                            <svg width="100%"
                                 height="25"
                                 viewBox="0 0 1000 25"
                                 preserveAspectRatio="none">

                                <polygon points="0,0 260,0 240,25 0,25"
                                         fill="#1f3b73"/>

                                <polygon points="260,0 1000,0 1000,25 240,25"
                                         fill="#e58b39"/>

                            </svg>

                        </div>

                    </div>

                </div>

            </t>

        </t>

    </template>

</odoo>