<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_payslip_form_custom_print" model="ir.ui.view">
        <field name="name">hr.payslip.form.custom.print</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>

        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="%(action_custom_payslip_report)d"
                    type="action"
                    string="Print"
                    class="btn-primary"/>
            </xpath>
        </field>
    </record>

</odoo>