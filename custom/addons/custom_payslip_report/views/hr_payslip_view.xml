<odoo>

    <record id="hr_payslip_form_custom_print"
            model="ir.ui.view">

        <field name="name">
            hr.payslip.form.custom.print
        </field>

        <field name="model">hr.payslip</field>

        <field name="inherit_id"
               ref="hr_payroll.hr_payslip_view_form"/>

        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">

                <button
                    name="%(custom_payslip_report.action_custom_payslip_report)d"
                    type="action"
                    string="Print Custom Payslip"
                    class="btn-primary"/>

            </xpath>

        </field>

    </record>

</odoo>