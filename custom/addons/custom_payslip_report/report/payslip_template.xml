<?xml version="1.0" encoding="UTF-8"?>

<odoo>

<template id="custom_payslip_template">

<t t-call="web.html_container">

<t t-foreach="docs" t-as="o">

<div class="page">

<style>

body{
    font-family: Arial, Helvetica, sans-serif;
    font-size:11px;
}

table{
    width:100%;
    border-collapse:collapse;
}

.header-line{
    border-top:3px solid #F58220;
    margin-top:10px;
    margin-bottom:15px;
}

.section-title{
    background:#666666;
    color:#fff;
    font-size:11px;
    font-weight:bold;
    padding:5px 8px;
    text-transform:uppercase;
}

.info-table td{
    padding:2px 4px;
    font-size:10px;
}

.salary-table{
    width:100%;
}

.salary-table th{
    background:none;
    color:#24478f;
    font-size:10px;
    text-align:left;
    padding:4px;
    border-bottom:1px solid #ddd;
}

.salary-table td{
    font-size:10px;
    padding:4px;
    border-bottom:1px solid #eee;
}

.total-row td{
    border-top:2px solid #888;
    font-weight:bold;
}

.summary-table td{
    border:1px solid #1F3A93;
}

.summary-box{
    text-align:center;
    padding:12px;
    min-height:65px;
}

.summary-title{
    color:#1F3A93;
    font-size:11px;
    font-weight:bold;
}

.summary-amount{
    font-size:18px;
    font-weight:bold;
    margin-top:5px;
}

.net-box{
    background:#082B84;
    color:#fff;
    text-align:center;
    padding:12px;
    min-height:65px;
}

.net-box .summary-title{
    color:white;
}

.net-box .summary-amount{
    color:white;
}

.notes-title{
    color:#1F3A93;
    font-size:14px;
    font-weight:bold;
}

.orange-line{
    width:60px;
    height:2px;
    background:#F58220;
    margin-top:5px;
    margin-bottom:10px;
}

.footer{
    font-size:10px;
}

</style>

<!-- HEADER -->

<table>
<tr>

<td style="width:28%;vertical-align:middle;">
    <img t-if="o.company_id.logo"
         t-att-src="image_data_uri(o.company_id.logo)"
         style="max-height:80px;"/>
</td>
  <tr>

                                                <!-- ORANGE BORDER -->
                                              <td style="
    width:8px;
    padding:0;
    vertical-align:top;
">

    <svg width="8"
         height="130"
         xmlns="http://www.w3.org/2000/svg">

        <defs>

            <!-- VERTICAL ORANGE FADE -->
            <linearGradient id="verticalFade"
                            x1="0%"
                            y1="0%"
                            x2="0%"
                            y2="100%">

                <stop offset="0%"
                      stop-color="#f39223"
                      stop-opacity="1"/>

                <stop offset="100%"
                      stop-color="#f39223"
                      stop-opacity="0"/>

            </linearGradient>

        </defs>

        <rect x="0"
              y="0"
              width="2"
              height="130"
              fill="url(#verticalFade)"/>

    </svg>

</td>
<td style="width:42%;vertical-align:top;">
    <div style="font-size:20px;font-weight:bold;color:#1F3A93;">
        <span t-field="o.company_id.name"/>
    </div>

    <div>
        <span t-field="o.company_id.street"/>
    </div>

    <div>
        <span t-esc="o.company_id.country_id.name or ''"/>
    </div>

    <div>
        TRN 1:
        <span t-field="o.company_id.vat"/>
    </div>
</td>

<td style="width:30%;text-align:right;vertical-align:top;">
    <div style="
        color:#1F3A93;
        font-size:28px;
        font-weight:bold;
    ">
        PAYSLIP1
    </div>

    <div style="font-size:16px;">
        <span t-esc="o.date_to.strftime('%B %Y')"/>
    </div>

    <br/>

    <div>
        Payslip No :
        <span t-field="o.number"/>
    </div>

    <div>
        Payment Date :
        <span t-field="o.date_to"/>
    </div>

    <div>
        Currency :
        AED
    </div>
</td>

</tr>
</table>

<div class="header-line"/>

<hr/>

<!-- EMPLOYEE -->

<table>

<tr>

<td width="45%">

<div class="section-title">
EMPLOYEE INFORMATION
</div>

<br/>

Employee :
<span t-field="o.employee_id.name"/>

<br/><br/>

Job Title :
<span t-field="o.employee_id.job_id.name"/>

<br/><br/>

Work Email :
<span t-field="o.employee_id.work_email"/>

<br/><br/>

Bank :
<span></span>

<br/><br/>

IBAN :
<span></span>

</td>

<td width="10%"></td>

<td width="45%">

<div class="section-title">
SALARY INFORMATION
</div>

<br/>

Pay Period :
<span t-field="o.date_from"/>
-
<span t-field="o.date_to"/>

<br/><br/>

Worked Days :

<t t-set="days"
   t-value="sum(o.worked_days_line_ids.mapped('number_of_days'))"/>

<span t-esc="days"/>

<br/><br/>

Status :
<span t-field="o.state"/>

</td>

</tr>

</table>

<br/>

<!-- EARNINGS / DEDUCTIONS -->

<table>

<tr>

<td width="48%" valign="top">

<div class="section-title">
EARNINGS
</div>

<table border="1">

<tr>
<th>Description</th>
<th>Amount</th>
</tr>

<t t-set="earnings" t-value="0"/>

<t t-foreach="o.line_ids.filtered(lambda l: l.total &gt; 0)"
   t-as="line">

<t t-set="earnings"
   t-value="earnings + line.total"/>

<tr>

<td>
<span t-field="line.name"/>
</td>

<td style="text-align:right">
<span t-esc="'{:,.2f}'.format(line.total)"/>
</td>

</tr>

</t>

<tr>

<td>
<b>Total Earnings</b>
</td>

<td style="text-align:right">
<b>
<span t-esc="'{:,.2f}'.format(earnings)"/>
</b>
</td>

</tr>

</table>

</td>

<td width="4%"></td>

<td width="48%" valign="top">

<div class="section-title">
DEDUCTIONS
</div>

<table border="1">

<tr>
<th>Description</th>
<th>Amount</th>
</tr>

<t t-set="deductions" t-value="0"/>

<t t-foreach="o.line_ids.filtered(lambda l: l.total &lt; 0)"
   t-as="line">

<t t-set="deductions"
   t-value="deductions + abs(line.total)"/>

<tr>

<td>
<span t-field="line.name"/>
</td>

<td style="text-align:right">
<span t-esc="'{:,.2f}'.format(abs(line.total))"/>
</td>

</tr>

</t>

<tr>

<td>
<b>Total Deductions</b>
</td>

<td style="text-align:right">
<b>
<span t-esc="'{:,.2f}'.format(deductions)"/>
</b>
</td>

</tr>

</table>

</td>

</tr>

</table>

<br/>

<!-- SUMMARY -->

<table>

<tr>

<td width="33%">

<div class="summary-box">

TOTAL EARNINGS

<br/><br/>

<b>
<span t-esc="'{:,.2f}'.format(earnings)"/>
</b>

</div>

</td>

<td width="33%">

<div class="summary-box">

TOTAL DEDUCTIONS

<br/><br/>

<b>
<span t-esc="'{:,.2f}'.format(deductions)"/>
</b>

</div>

</td>

<td width="34%">

<div class="net-box">

NET PAY

<br/><br/>

<h2>
<span t-out="o.net_wage if 'net_wage' in o._fields else ''"/>
</h2>

</div>

</td>

</tr>

</table>

<br/>

<div>

<b>Amount In Words :</b>

<span t-esc="o.company_id.currency_id.amount_to_text(o.net_wage)"/>

</div>

<br/>
<!-- Notes & Footer Section -->
<div class="row mt32" style="margin-top:30px;">

    <!-- Left Side : Notes -->
    <div class="col-7">
        <div style="font-size:12px;">

            <h5 style="
                color:#1F3A93;
                font-weight:bold;
                margin-bottom:10px;
            ">
                Notes
            </h5>

            <div style="
                width:80px;
                height:2px;
                background:#F58220;
                margin-bottom:10px;
            "/>

            <p style="margin:0;">
                ● This is a system-generated document and does not require any signature.
            </p>

        </div>
    </div>

    <!-- Right Side : Company Footer -->
    <div class="col-5 text-end">

        <table style="
            width:100%;
            font-size:11px;
            border-collapse:collapse;
        ">
            <tr>
                <td style="padding:3px 0;">
                    <strong>Address :</strong>
                </td>
                <td style="padding:3px 0;">
                    <span t-esc="o.company_id.street"/>
                    <t t-if="o.company_id.street2">
                        , <span t-esc="o.company_id.street2"/>
                    </t>
                    <br/>
                    <span t-esc="o.company_id.city"/>
                </td>
            </tr>

            <tr>
                <td style="padding:3px 0;">
                    <strong>Email :</strong>
                </td>
                <td style="padding:3px 0;">
                    <span t-esc="o.company_id.email"/>
                </td>
            </tr>

            <tr>
                <td style="padding:3px 0;">
                    <strong>Website :</strong>
                </td>
                <td style="padding:3px 0;">
                    <span t-esc="o.company_id.website"/>
                </td>
            </tr>

            <tr>
                <td style="padding:3px 0;">
                    <strong>Phone :</strong>
                </td>
                <td style="padding:3px 0;">
                    <span t-esc="o.company_id.phone"/>
                </td>
            </tr>
        </table>

    </div>

</div>
<div style="font-size:11px">

This is a system generated payslip and does not require signature.

</div>

</div>

</t>

</t>

</template>

</odoo>