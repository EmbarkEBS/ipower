<?xml version="1.0" encoding="UTF-8"?>

<odoo>

<template id="custom_payslip_template">

    <t t-call="web.html_container">

        <t t-foreach="docs" t-as="o">

            <t t-set="earnings"
               t-value="sum(o.line_ids.filtered(lambda l: l.appears_on_payslip and l.total &gt; 0).mapped('total'))"/>

            <t t-set="deductions"
               t-value="sum(abs(l.total) for l in o.line_ids.filtered(lambda l: l.appears_on_payslip and l.total &lt; 0))"/>

            <t t-set="working_days"
               t-value="sum(o.worked_days_line_ids.mapped('number_of_days'))"/>

            <div class="page">

                <style>

                    body{
                        font-family:Arial,Helvetica,sans-serif;
                        font-size:11px;
                        color:#222;
                    }

                    table{
                        width:100%;
                        border-collapse:collapse;
                    }

                    .section-title{
                        background:#666;
                        color:#fff;
                        font-weight:bold;
                        font-size:11px;
                        padding:6px 10px;
                        text-transform:uppercase;
                    }

                    .top-orange{
                        height:3px;
                        background:#f58220;
                        margin-top:10px;
                        margin-bottom:25px;
                    }

                    .info td{
                        padding:3px 0;
                        font-size:11px;
                    }

                    .salary-table th{
                        color:#1f3a93;
                        font-size:11px;
                        text-align:left;
                        padding:4px;
                    }

                    .salary-table td{
                        padding:4px;
                        font-size:11px;
                    }

                    .total-line{
                        border-top:2px solid #777;
                        border-bottom:2px solid #ddd;
                        font-weight:bold;
                        color:#1f3a93;
                    }

                    .summary td{
                        border:1px solid #18327e;
                    }

                    .summary-box{
                        text-align:center;
                        height:70px;
                        padding:10px;
                    }

                    .summary-title{
                        color:#18327e;
                        font-weight:bold;
                        font-size:12px;
                    }

                    .summary-value{
                        font-size:18px;
                        font-weight:bold;
                        margin-top:5px;
                    }

                    .net-box{
                        background:#072a8a;
                        color:white;
                        text-align:center;
                        height:70px;
                        padding:10px;
                    }

                    .footer-note{
                        font-size:11px;
                    }

                </style>

                <!-- HEADER -->

                <table>
                    <tr>

                        <td style="width:25%;vertical-align:top;">

                            <img t-if="o.company_id.logo"
                                 t-att-src="image_data_uri(o.company_id.logo)"
                                 style="max-height:90px;"/>

                        </td>

                        <td style="width:2%;">

                            <div style="
                                width:2px;
                                height:120px;
                                background:#f58220;
                            "/>

                        </td>

                        <td style="width:43%;padding-left:15px;vertical-align:top;">

                            <div style="
                                color:#1f3a93;
                                font-size:20px;
                                font-weight:bold;
                            ">
                                <span t-field="o.company_id.name"/>
                            </div>

                            <div>
                                <span t-field="o.company_id.street"/>
                            </div>

                            <div>
                                <span t-esc="o.company_id.country_id.name or ''"/>
                            </div>

                            <div style="margin-top:10px;">
                                TRN :
                                <span t-field="o.company_id.vat"/>
                            </div>

                        </td>

                        <td style="width:30%;vertical-align:top;">

                            <div style="
                                color:#0b2d8d;
                                font-size:36px;
                                font-weight:bold;
                            ">
                                PAYSLIP
                            </div>

                            <div style="font-size:18px;">
                                <span t-esc="o.date_to.strftime('%B %Y')"/>
                            </div>

                            <br/>

                            <table style="font-size:11px;">
                                <tr>
                                    <td>Payslip No</td>
                                    <td>:</td>
                                    <td><span t-field="o.name"/></td>
                                </tr>

                                <tr>
                                    <td>Payment Date</td>
                                    <td>:</td>
                                    <td><span t-field="o.date_to"/></td>
                                </tr>

                                <tr>
                                    <td>Currency</td>
                                    <td>:</td>
                                    <td><span t-field="o.currency_id.name"/></td>
                                </tr>
                            </table>

                        </td>

                    </tr>
                </table>

                <div class="top-orange"/>

                <!-- INFO -->

                <table>
                    <tr>

                        <td style="width:45%;vertical-align:top;">

                            <div class="section-title">
                                Employee Information
                            </div>

                            <table class="info">

                                <tr>
                                    <td>Employee Name</td>
                                    <td>:</td>
                                    <td><span t-field="o.employee_id.legal_name"/></td>
                                </tr>

                                <tr>
                                    <td>Employee Mail</td>
                                    <td>:</td>
                                    <td><span t-field="o.employee_id.work_email"/></td>
                                </tr>

                                <tr>
                                    <td>Designation</td>
                                    <td>:</td>
                                    <td><span t-field="o.version_id.job_id"/></td>
                                </tr>

                                <tr>
                                    <td>Date of Joining</td>
                                    <td>:</td>
                                    <td>
                                        <span t-out="o.version_id.employee_id.with_context(before_date=o.date_to)._get_first_contract_date()"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>Bank Name</td>
                                    <td>:</td>
                                    <td>
                                        <span t-esc="o.employee_id.bank_account_ids[:1].bank_id.name if o.employee_id.bank_account_ids else ''"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>IBAN</td>
                                    <td>:</td>
                                    <td>
                                        <span t-esc="o.employee_id.bank_account_ids[:1].acc_number if o.employee_id.bank_account_ids else ''"/>
                                    </td>
                                </tr>

                            </table>

                        </td>

                        <td style="width:5%;"/>

                        <td style="width:50%;vertical-align:top;">

                            <div class="section-title">
                                Salary Information
                            </div>

                            <table class="info">

                                <tr>
                                    <td>Pay Period</td>
                                    <td>:</td>
                                    <td>
                                        <span t-field="o.date_from"/>
                                        -
                                        <span t-field="o.date_to"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>Working Days</td>
                                    <td>:</td>
                                    <td>
                                        <span t-esc="working_days"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>Paid Days</td>
                                    <td>:</td>
                                    <td>
                                        <span t-esc="working_days"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>Leave Days</td>
                                    <td>:</td>
                                    <td>0</td>
                                </tr>

                                <tr>
                                    <td>Loss Of Pay Days</td>
                                    <td>:</td>
                                    <td>0</td>
                                </tr>

                            </table>

                        </td>

                    </tr>
                </table>

                <br/>

                <!-- EARNINGS + DEDUCTIONS -->

                <table>

                    <tr>

                        <td style="width:48%;vertical-align:top;">

                            <div class="section-title">Earnings</div>

                            <table class="salary-table">

                                <tr>
                                    <th>Description</th>
                                    <th style="text-align:right;">Amount</th>
                                </tr>

                                <t t-foreach="o.line_ids.filtered(lambda l: l.appears_on_payslip and l.total &gt; 0)" t-as="line">

                                    <tr>
                                        <td><span t-field="line.name"/></td>
                                        <td style="text-align:right;">
                                            <span t-out="line.total"
                                                  t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                                        </td>
                                    </tr>

                                </t>

                                <tr class="total-line">
                                    <td>Total Earnings</td>
                                    <td style="text-align:right;">
                                        <span t-out="earnings"
                                              t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                                    </td>
                                </tr>

                            </table>

                        </td>

                        <td style="width:4%;"/>

                        <td style="width:48%;vertical-align:top;">

                            <div class="section-title">Deductions</div>

                            <table class="salary-table">

                                <tr>
                                    <th>Description</th>
                                    <th style="text-align:right;">Amount</th>
                                </tr>

                                <t t-foreach="o.line_ids.filtered(lambda l: l.appears_on_payslip and l.total &lt; 0)" t-as="line">

                                    <tr>
                                        <td><span t-field="line.name"/></td>
                                        <td style="text-align:right;">
                                            <span t-esc="'{:,.2f}'.format(abs(line.total))"/>
                                        </td>
                                    </tr>

                                </t>

                                <tr class="total-line">
                                    <td>Total Deductions</td>
                                    <td style="text-align:right;">
                                        <span t-esc="'{:,.2f}'.format(deductions)"/>
                                    </td>
                                </tr>

                            </table>

                        </td>

                    </tr>

                </table>

                <br/><br/>

                <!-- SUMMARY -->

                <table class="summary">

                    <tr>

                        <td>
                            <div class="summary-box">
                                <div class="summary-title">TOTAL EARNINGS (AED)</div>
                                <div class="summary-value">
                                    <span t-esc="'{:,.2f}'.format(earnings)"/>
                                </div>
                            </div>
                        </td>

                        <td>
                            <div class="summary-box">
                                <div class="summary-title">TOTAL DEDUCTIONS (AED)</div>
                                <div class="summary-value">
                                    <span t-esc="'{:,.2f}'.format(deductions)"/>
                                </div>
                            </div>
                        </td>

                        <td>
                            <div class="net-box">
                                <div>NET PAY (AED)</div>
                                <div style="font-size:22px;font-weight:bold;">
                                    <span t-esc="'{:,.2f}'.format(o.net_wage)"/>
                                </div>
                            </div>
                        </td>

                        <td>
                            <div class="summary-box">
                                <div class="summary-title">AMOUNT IN WORDS</div>
                                <div style="font-size:10px;">
                                    <span t-esc="o.company_id.currency_id.amount_to_text(o.net_wage)"/>
                                </div>
                            </div>
                        </td>

                        <td>
                            <div class="summary-box">
                                <div class="summary-title">PAYMENT MODE</div>
                                <div>Bank Transfer</div>
                            </div>
                        </td>

                    </tr>

                </table>

                <br/><br/>

                <!-- FOOTER -->

                <table>

                    <tr>

                        <td style="width:50%;">

                            <div style="font-size:24px;">
                                Notes
                            </div>

                            <div style="
                                width:80px;
                                height:2px;
                                background:#f58220;
                                margin-top:5px;
                                margin-bottom:10px;
                            "/>

                            <div class="footer-note">
                                ● This is a system-generated document and does not require any signature.
                            </div>

                        </td>

                        <td style="
                            width:50%;
                            text-align:right;
                            font-size:11px;
                            vertical-align:bottom;
                        ">

                            <span t-field="o.company_id.street"/>
                            |
                            <span t-field="o.company_id.email"/>
                            |
                            <span t-field="o.company_id.website"/>
                            |
                            <span t-field="o.company_id.phone"/>

                        </td>

                    </tr>

                </table>

            </div>

        </t>

    </t>

</template>


</odoo>
