<odoo>

    <record id="paperformat_custom_delivery"
            model="report.paperformat">

        <field name="name">Custom Delivery Slip Paperformat</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">8</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>

    </record>


    <record id="action_report_custom_delivery_slip"
            model="ir.actions.report">

        <field name="name">Delivery Slip</field>

        <field name="model">stock.picking</field>

        <field name="report_type">qweb-pdf</field>

        <!-- IMPORTANT -->
        <field name="report_name">custom_delivery_slip_report.delivery_slip_template</field>

        <!-- IMPORTANT -->
        <field name="report_file">custom_delivery_slip_report.delivery_slip_template</field>

        <field name="binding_model_id"
               ref="stock.model_stock_picking"/>

        <field name="binding_type">report</field>

        <field name="print_report_name">'Delivery Slip - %s' % (object.name)</field>

        <field name="paperformat_id"
               ref="custom_delivery_slip_report.paperformat_custom_delivery"/>

    </record>

</odoo>