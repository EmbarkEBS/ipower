<t t-if="serials">
    <span>Serial No:</span>
    <small><span t-esc="serials"/></small>
</t>

</td>
    </tr>

    <tr style="border-bottom:1px solid #d9d9d9;">
        <td></td>
       
                                        <td colspan="4" style="
