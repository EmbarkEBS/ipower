            <br/>
            <span t-esc="o.sale_id.partner_invoice_id.city or ''"/> -

            <t t-if="o.sale_id.partner_invoice_id.country_id">
               
                <span t-esc="o.sale_id.partner_invoice_id.country_id.name"/>
            </t>

            <t t-if="o.sale_id.partner_invoice_id.phone">
                <br/>
                <span t-esc="o.sale_id.partner_invoice_id.phone"/>
            </t>
                                                    <br/>

                                                  <t t-if="o.sale_id.partner_invoice_id.vat">
<p  style="margin-top:15px"><strong >    TRN <span t-esc="o.sale_id.partner_invoice_id.vat"/></strong></p>
</t>
   
<!-- ATTN ONLY IF CONTACT PERSON -->
<t t-if="o.partner_id.parent_id">
    <p style="margin-top:5px">

        <strong>Attn</strong>

        <t t-if="o.partner_id.x_studio_salutation">
            <span t-esc="o.partner_id.x_studio_salutation"/>
