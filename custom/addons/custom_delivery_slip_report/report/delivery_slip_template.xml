<odoo>

    <template id="delivery_slip_template">

        <t t-call="web.html_container">
            <meta charset="UTF-8"/>

            <t t-foreach="docs" t-as="o">

                <main>

                    <div class="page"
                         style="padding:20px 40px;
                                position:relative;
                                color:#333;
                                line-height:1.4;
                                font-family: Helvetica, Arial, sans-serif !important;">

                        <table style="width:100%; border-collapse:collapse; margin-bottom:20px;">

                            <tr>

                                <td style="width:60%; vertical-align:top;">

                                    <img t-if="o.company_id.logo"
                                         t-att-src="image_data_uri(o.company_id.logo)"
                                         style="max-height:80px;
                                                margin-bottom:10px;"/>

                                    <div style="font-size:13px; line-height:1.7;">

                                        <strong style="color:#1a3a5a; font-size:15px;">
                                            <span t-esc="o.company_id.name"/>
                                        </strong>

                                        <br/>

                                        <span t-esc="o.company_id.street or ''"/>

                                        <br/>

                                        <span t-esc="o.company_id.country_id.name or ''"/>

                                    </div>

                                </td>

                                <td style="width:40%; text-align:right; vertical-align:top;">

                                    <h2 style="margin:0; color:#1a3a5a;">
                                        DELIVERY SLIP
                                    </h2>

                                    <br/>

                                    <strong>Reference:</strong>
                                    <span t-esc="o.name"/>

                                    <br/>

                                    <strong>Scheduled Date:</strong>
                                    <span t-field="o.scheduled_date"/>

                                    <br/>

                                    <strong>Customer:</strong>
                                    <span t-esc="o.partner_id.name"/>

                                </td>

                            </tr>

                        </table>

                        <table style="width:100%; border-collapse:collapse; margin-top:20px; font-size:13px;">

                            <thead>

                                <tr style="background:#1a3a5a; color:white;">
                                    <th style="padding:8px; border:1px solid #ccc; text-align:left;">
                                        Product
                                    </th>

                                    <th style="padding:8px; border:1px solid #ccc; text-align:center;">
                                        Quantity
                                    </th>

                                    <th style="padding:8px; border:1px solid #ccc; text-align:center;">
                                        UOM
                                    </th>
                                </tr>

                            </thead>

                            <tbody>

                                <tr t-foreach="o.move_ids_without_package" t-as="line">

                                    <td style="padding:8px; border:1px solid #ccc;">
                                        <span t-esc="line.product_id.display_name"/>
                                    </td>

                                    <td style="padding:8px; border:1px solid #ccc; text-align:center;">
                                        <span t-esc="line.quantity"/>
                                    </td>

                                    <td style="padding:8px; border:1px solid #ccc; text-align:center;">
                                        <span t-esc="line.product_uom.name"/>
                                    </td>

                                </tr>

                            </tbody>

                        </table>

                    </div>

                </main>

            </t>

        </t>

    </template>

</odoo>
