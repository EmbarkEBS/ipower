                <t t-if="o.sale_id.partner_shipping_id.phone">
                    <br/>
                    <span t-esc="o.sale_id.partner_shipping_id.phone"/>
                </t>
            </div>
        </td>
    </tr>

</t>
    
                            </table>
</td>
</tr>
