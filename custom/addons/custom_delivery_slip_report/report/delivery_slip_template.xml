<odoo>

    <template id="delivery_slip_template">

        <t t-call="web.html_container">
            <meta charset="UTF-8"/>

            <t t-foreach="docs" t-as="o">

                <main>

                   <div class="page"
                     style="padding:10px 40px 40px 40px;position:relative;
                            color:#333; margin:0;
                            line-height:1.4;
                            font-family: Helvetica, Arial, sans-serif !important;">
                            <!-- WATERMARK -->
<div style="
    position:absolute;
    top:60%;
    left:25%;
    opacity:0.10;
    transform:translate(-50%, -50%) rotate(-25deg);
    z-index:0;
    width:420px;
    text-align:center;
">

    <img t-if="o.company_id.logo"
         t-att-src="image_data_uri(o.company_id.logo)"
         style="width:100%;"/>

</div>

                 <!-- HEADER -->
    <table style="
                                width:100%;
                                border-collapse:collapse;
                                margin-bottom:20px;
                            ">

                                <tr>

                                    <!-- COMPANY -->
                                    <td style="
                                        width:60%;
                                        vertical-align:top;
                                    ">

                                        <img t-if="o.company_id.logo"
                                             t-att-src="image_data_uri(o.company_id.logo)"
                                             style="
                                                max-height:80px;
                                                margin-bottom:10px;
                                                margin-left:-30px;
                                             "/>

                                        <div style="
                                            font-size:13px;
                                            line-height:1.7;
                                        ">

                                            <strong style="
                                                color:#1a3a5a;
                                                font-size:15px;
                                            ">
                                                <span t-esc="o.company_id.name"/>
                                            </strong>

                                            <br/>

                                            <span t-esc="o.company_id.street or ''"/>,

                                          
                                           
                                            <t t-if="o.company_id.state_id">
                                                 <span t-esc="o.company_id.state_id.name"/>
                                            </t>

                                            <br/>

                                            <span t-esc="o.company_id.country_id.name or ''"/>

                                            <br/>

                                        <p  style="margin-top:15px"> <strong>  TRN <span t-esc="o.company_id.vat or ''"/></strong></p>

                                        </div>

                                    </td>

                                    <!-- SALES ORDER -->
                                    <td style="
                                        width:40%;
                                        vertical-align:top;
                                        text-align:center;
                                    ">

                                        <h1 style="
                                            margin:0;
                                            font-size:28px;
                                            font-weight:bold;
                                            color:#000;
                                            margin-top:20px;
                                        ">
                                            Delivery Note
                                        </h1>

                                <div style="
    width:350px;
    margin:5px auto;
    text-align:center;
">

<svg width="330"
     height="4"
     xmlns="http://www.w3.org/2000/svg">

    <defs>

        <!-- HORIZONTAL ORANGE FADE -->
        <linearGradient id="horizontalFade"
                        x1="0%"
                        y1="0%"
                        x2="100%"
                        y2="0%">

            <!-- longer solid orange -->
            <stop offset="0%"
                  stop-color="#f39223"
                  stop-opacity="1"/>

            <stop offset="82%"
                  stop-color="#f39223"
                  stop-opacity="1"/>

            <!-- smooth fade -->
            <stop offset="100%"
                  stop-color="#f39223"
                  stop-opacity="0"/>

        </linearGradient>

    </defs>

    <!-- longer centered line -->
    <rect x="90"
          y="1"
          width="155"
          height="2"
          fill="url(#horizontalFade)"/>

</svg>

</div>
                                        <div style="
                                            font-size:16px;
                                            text-align:center;margin-top:10px;
                                        ">

                                            # <span t-field="o.name"/>
                                          <!---  <span t-esc="'IP/SO/' + str(o.date_order.year)[-2:] + '/' + '%03d' % o.id"/>-->
                                          


                                        </div>

                                    </td>

                                </tr>

                            </table>


                               
                        <table style="width:100%; border-collapse:collapse; margin-top:20px; font-size:13px;">

                            <thead>

                                <tr style="background:#1a3a5a; color:white;">
                                    <th style="padding:8px; border:1px solid #ccc; text-align:left;">
                                        Product
                                    </th>

                                    <th style="padding:8px; border:1px solid #ccc; text-align:center;">
                                        Quantity
                                    </th>

                                    <th style="padding:8px; border:1px solid #ccc; text-align:center;">
                                        UOM
                                    </th>
                                </tr>

                            </thead>

                            <tbody>

                               <tr t-foreach="o.move_ids"
    t-as="line">

                                    <td style="padding:8px; border:1px solid #ccc;">
                                        <span t-esc="line.product_id.display_name"/>
                                    </td>

                                    <td style="padding:8px; border:1px solid #ccc; text-align:center;">
                                        <span t-esc="line.quantity"/>
                                    </td>

                                    <td style="padding:8px; border:1px solid #ccc; text-align:center;">
                                        <span t-esc="line.product_uom.name"/>
                                    </td>

                                </tr>

                            </tbody>

                        </table>
     <!-- FOOTER CONTENT -->
                          <!-- FOOTER -->
<div class="fixed-footer">

    <!-- FOOTER TEXT -->
    <div style="
        padding:0 40px;
        font-size:11px;
        color:#555;
    ">

        <div style="
            margin-bottom:5px;
            color:#888;
            font-style:italic;
        ">
            This document is electronically generated and valid without signature or company stamp.
        </div>

        <div style="
            border-top:1px solid #1f3b73;
            padding-top:6px;
            text-align:center;
        ">

            <t t-if="o.company_id.street2">
                <span t-esc="o.company_id.street2"/>
            </t>

            
            <span t-esc="o.company_id.city or ''"/>
            -
            <span t-esc="o.company_id.country_id.name or ''"/>

            <br/>

            CR No:
            <span t-esc="o.company_id.company_registry or 'N/A'"/>

            |

            <span t-esc="o.company_id.email or ''"/>

            |

            <span t-esc="o.company_id.website or ''"/>

        </div>

    </div>

    <!-- FULL BLEED BAR -->
   <!-- ABSOLUTE FULL WIDTH BAR -->
                           <!-- FULL WIDTH FOOTER BORDER -->
<div style="
    width:auto;
    height:25px;
    overflow:hidden;
    margin-top:5px;
    margin-left:-40px;
    margin-right:-50px;
">

    <svg width="100%"
         height="25"
         viewBox="0 0 1000 25"
         preserveAspectRatio="none"
         xmlns="http://www.w3.org/2000/svg">

        <!-- BLUE 25% -->
        <polygon points="0,0 260,0 240,25 0,25"
                 fill="#1f3b73"/>

        <!-- ORANGE 75% -->
        <polygon points="260,0 1000,0 1000,25 240,25"
                 fill="#e58b39"/>

    </svg>

</div>
 </div>

                    </div>

                </main>

            </t>

        </t>

    </template>

</odoo>
