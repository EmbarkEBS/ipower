        ">
            Your Ref
        </td>
        <td style="padding:4px 0;">
            :
            <span t-field="o.purchase_id.partner_ref"/>
        </td>
    </tr>
</t>
  <t t-set="sale_order" t-value="o.sale_id"/>                                     
<t t-if="sale_order and sale_order.x_studio_customer_po_ref">
    <tr>
        <td style="font-weight:bold; font-size:15px;color:#1a3a5a;">
            Customer PO Ref
        </td>
        <td>
            :
            <span t-field="sale_order.x_studio_customer_po_ref"/>
        </td>
    </tr>
</t>

 <!-- Dropship -->
<t t-if="'Dropship' in (o.picking_type_id.name or '') and
         o.purchase_id and
         o.purchase_id.dest_address_id">

    <tr>
        <td style="padding:4px 0;font-size:15px;font-weight:bold;color:#1a3a5a;vertical-align:top;">
            Delivery Address
        </td>

        <td style="padding:4px 0;font-size:15px;font-family:Arial,sans-serif;line-height:1.4;">
            :
            <div style="margin-top:-20px;margin-left:6px">
                <strong>
                    <span t-esc="o.purchase_id.dest_address_id.name"/>
                </strong>

                <t t-if="o.purchase_id.dest_address_id.street">
                    <br/><span t-esc="o.purchase_id.dest_address_id.street"/>
                </t>

                <t t-if="o.purchase_id.dest_address_id.street2">
                    <br/><span t-esc="o.purchase_id.dest_address_id.street2"/>
                </t>

                <br/>
                <span t-esc="o.purchase_id.dest_address_id.city or ''"/>

                <t t-if="o.purchase_id.dest_address_id.country_id">
                    <br/>
                    <span t-esc="o.purchase_id.dest_address_id.country_id.name"/>
                </t>
            </div>
        </td>
    </tr>

</t>

<!-- Sales Delivery - show only when delivery address differs from invoice address -->
<t t-elif="o.picking_type_id.code == 'outgoing'
           and o.sale_id
           and o.sale_id.partner_shipping_id
           and o.sale_id.partner_invoice_id
           and o.sale_id.partner_shipping_id.id != o.sale_id.partner_invoice_id.id">

    <tr>
        <td style="padding:4px 0;font-size:15px;font-weight:bold;color:#1a3a5a;vertical-align:top;">
            Delivery Address
        </td>

        <td style="padding:4px 0;font-size:15px;font-family:Arial,sans-serif;line-height:1.4;">
            :
            <div style="margin-top:-20px;margin-left:6px">
                <strong>
                    <span t-esc="o.sale_id.partner_shipping_id.name"/>
                </strong>

                <t t-if="o.sale_id.partner_shipping_id.street">
                    <br/>
                    <span t-esc="o.sale_id.partner_shipping_id.street"/>
                </t>

                <t t-if="o.sale_id.partner_shipping_id.street2">
                    <br/>
                    <span t-esc="o.sale_id.partner_shipping_id.street2"/>
