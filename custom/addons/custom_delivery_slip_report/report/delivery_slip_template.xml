<odoo>

    <template id="delivery_slip_template">

        <t t-call="web.html_container">
            <meta charset="UTF-8"/>

            <t t-foreach="docs" t-as="o">
                <style>
                    .fixed-footer {
                        position: fixed;
                        left: 0;
                        right: 0;
                        bottom: 0;
                        height: 22mm;
                    }

             @page {
        margin: 0px 40px 0px 40px !important;
        padding: 0 !important;
    }

    html, body {
        margin: 0 !important;
        padding: 0 !important;
    }

    .article {
        margin: 0 !important;
        padding: 0 !important;
    }

    .page {
        margin: 0 !important;
        padding: 0px 40px 0px 40px !important;
    }

    header,
    footer {
        display: none !important;
    }
                </style>
                <main>

                   <div class="page"
                     style="padding:10px 40px 40px 40px;position:relative;
                            color:#333; margin:0;
                            line-height:1.4;
                            font-family: Helvetica, Arial, sans-serif !important;">
                            <!-- WATERMARK -->
<div style="
    position:absolute;
    top:72%;
    left:25%;
    opacity:0.10;
    transform:translate(-50%, -50%) rotate(-25deg);
    z-index:0;
    width:420px;
    text-align:center;
">

    <img t-if="o.company_id.logo"
         t-att-src="image_data_uri(o.company_id.logo)"
         style="width:100%;"/>

</div>

                 <!-- HEADER -->
    <table style="
                                width:100%;
                                border-collapse:collapse;
                                margin-bottom:20px;
                            ">

                                <tr>

                                    <!-- COMPANY -->
                                    <td style="
                                        width:60%;
                                        vertical-align:top;
                                    ">

                                        <img t-if="o.company_id.logo"
                                             t-att-src="image_data_uri(o.company_id.logo)"
                                             style="
                                                max-height:80px;
                                                margin-bottom:10px;
                                                margin-left:-30px;
                                             "/>

                                        <div style="
                                            font-size:13px;
                                            line-height:1.7;
                                        ">

                                            <strong style="
                                                color:#1a3a5a;
                                                font-size:15px;
                                            ">
                                                <span t-esc="o.company_id.name"/>
                                            </strong>

                                            <br/>

                                            <span t-esc="o.company_id.street or ''"/>, Dubai

                                          
                                           
                                         <!--   <t t-if="o.company_id.state_id">
                                                 <span t-esc="o.company_id.state_id.name"/>
                                            </t>-->

                                            <br/>

                                            <span t-esc="o.company_id.country_id.name or ''"/>

                                            <br/>

                                        <p  style="margin-top:15px"> <strong>  TRN <span t-esc="o.company_id.vat or ''"/></strong></p>

                                        </div>

                                    </td>

                                    <!-- SALES ORDER -->
                                    <td style="
                                        width:40%;
                                        vertical-align:top;
                                        text-align:center;
                                    ">

                                        <h1 style="
                                            margin:0;
                                            font-size:28px;
                                            font-weight:bold;
                                            color:#000;
                                            margin-top:20px;
                                        ">
                                            Delivery Note
                                        </h1>

                                <div style="
    width:350px;
    margin:5px auto;
    text-align:center;
">

<svg width="330"
     height="4"
     xmlns="http://www.w3.org/2000/svg">

    <defs>

        <!-- HORIZONTAL ORANGE FADE -->
        <linearGradient id="horizontalFade"
                        x1="0%"
                        y1="0%"
                        x2="100%"
                        y2="0%">

            <!-- longer solid orange -->
            <stop offset="0%"
                  stop-color="#f39223"
                  stop-opacity="1"/>

            <stop offset="82%"
                  stop-color="#f39223"
                  stop-opacity="1"/>

            <!-- smooth fade -->
            <stop offset="100%"
                  stop-color="#f39223"
                  stop-opacity="0"/>

        </linearGradient>

    </defs>

    <!-- longer centered line -->
    <rect x="90"
          y="1"
          width="155"
          height="2"
          fill="url(#horizontalFade)"/>

</svg>

</div>
                                        <div style="
                                            font-size:16px;
                                            text-align:center;margin-top:10px;
                                        ">

                                            # <span t-field="o.name"/>
                                          <!---  <span t-esc="'IP/SO/' + str(o.date_order.year)[-2:] + '/' + '%03d' % o.id"/>-->
                                          


                                        </div>

                                    </td>

                                </tr>

                            </table>


     <!-- ===================================================== -->
                            <!-- ADDRESS + META -->
                            <!-- ===================================================== -->

                            <table style="
                                width:100%;
                                font-size:15px;
                                border-collapse:collapse;
                                margin-top:35px;
                                margin-bottom:35px;
                            ">

                                <tr>

                                    <!-- ADDRESS -->
                                    <td style="
                                        width:55%;font-size:15px;
                                        vertical-align:top;
                                    ">

                                        <table style="
                                            width:100%;font-size:15px;
                                            border-collapse:collapse;
                                        ">
  <strong style="color:#1a3a5a;">
                                                        To
                                                    </strong>

                                                   
                                            <tr>

                                                <!-- ORANGE BORDER -->
                                              <td style="
    width:8px;
    padding:0;
    vertical-align:top;
">

    <svg width="8"
         height="130"
         xmlns="http://www.w3.org/2000/svg">

        <defs>

            <!-- VERTICAL ORANGE FADE -->
            <linearGradient id="verticalFade"
                            x1="0%"
                            y1="0%"
                            x2="0%"
                            y2="100%">

                <stop offset="0%"
                      stop-color="#f39223"
                      stop-opacity="1"/>

                <stop offset="100%"
                      stop-color="#f39223"
                      stop-opacity="0"/>

            </linearGradient>

        </defs>

        <rect x="0"
              y="0"
              width="2"
              height="130"
              fill="url(#verticalFade)"/>

    </svg>

</td>
                                                <td style="width:15px;">
                                                </td>

                                                <!-- ADDRESS CONTENT -->
                                                <td style="
                                                    vertical-align:top;
                                                    font-size:15px;
                                                    line-height:1.7;
                                                ">

                                                  

                                                    <strong>
                                                      <span t-esc="o.partner_id.parent_id.name if o.partner_id.parent_id else o.partner_id.name"/>
   
                                                    </strong>

                                                    <br/>

                                                    <span t-esc="o.partner_id.street or ''"/>

                                                    <t t-if="o.partner_id.street2">
                                                        <br/>
                                                        <span t-esc="o.partner_id.street2"/>
                                                    </t>

                                                    <br/>

                                                    <span t-esc="o.partner_id.city or ''"/>

                                                   <!-- <t t-if="o.partner_id.state_id">
                                                         <span t-esc="o.partner_id.state_id.name"/>
                                                    </t>-->

                                                    -

                                                    <span t-esc="o.partner_id.country_id.name or ''"/>

                                                    <br/>

                                                  <t t-if="o.partner_id.vat">
<p  style="margin-top:15px"><strong >    TRN <span t-esc="o.partner_id.vat"/></strong></p>
</t>
   
<!-- ATTN ONLY IF CONTACT PERSON -->
<t t-if="o.partner_id.parent_id">
    <p style="margin-top:5px">

        <strong>Attn</strong>

        <t t-if="o.partner_id.x_studio_salutation">
            <span t-esc="o.partner_id.x_studio_salutation"/>
        </t>

        <span t-esc="o.partner_id.name"/>

    </p>
</t>
                                                </td>

                                            </tr>

                                        </table>

                                    </td>

                                    <!-- META -->
                                    <td style="
                                        width:45%; font-size:15px;
                                        vertical-align:top;
                                        font-size:13px;
                                        padding-left:40px;
                                    ">

                                        <table style="
                                            width:100%;font-size:15px;
                                            border-collapse:collapse;
                                        ">

                                            <tr>

                                                <td style="
                                                    padding:4px 0;
                                                    width:45%;font-size:15px;
                                                    font-weight:bold;
                                                    color:#1a3a5a;
                                                ">
                                                 Delivery Date
                                                </td>

                                                <td style="padding:4px 0;">

                                                    :
                                                    <span t-field="o.scheduled_date"
                                                          t-options='{"format": "dd MMMM yyyy"}'/>

                                                </td>

                                            </tr>

                                                  <tr>

                                                <td style="
                                                    padding:4px 0; font-size:15px;
                                                    font-weight:bold;
                                                    color:#1a3a5a;
                                                ">
                                                     Our Ref
                                                </td>

                                                <td style="padding:4px 0;">

                                                    :
                                                   <span t-esc="o.origin or ''"/>

                                                </td>

                                            </tr>
                                             <t t-if="o.sale_id and o.sale_id.x_studio_project_reference">     <tr>

                                                <td style="
                                                    padding:4px 0; font-size:15px;
                                                    font-weight:bold;
                                                    color:#1a3a5a;
                                                ">
                                                    Your Ref
                                                </td>

                                                <td style="padding:4px 0;">

                                                    :
                                                    <span t-esc="o.sale_id and o.sale_id.x_studio_project_reference or ''"/>

                                                </td>

                                            </tr></t>
  <t t-set="sale_order" t-value="o.sale_id"/>                                     
<t t-if="sale_order and sale_order.x_studio_customer_po_ref">
    <tr>
        <td style="font-weight:bold; font-size:15px;color:#1a3a5a;">
            Customer PO Ref
        </td>
        <td>
            :
            <span t-field="sale_order.x_studio_customer_po_ref"/>
        </td>
    </tr>
</t>

                            </table>
</td>
</tr>
</table>
                         <table style="
                            width:100%;
                            border-collapse:collapse;
                            margin-bottom:20px;
                        ">

                            <thead>

                                <tr style="
                                    background:#4b4b4b;
                                    color:#fff;
                                ">

                                    <th style="
                                        padding:10px;
                                        width:5%;
                                        text-align:center;
                                        border-top-left-radius:10px;
                                        border-bottom-left-radius:10px;
                                    ">
                                        SN
                                    </th>

                                    <th style="
                                        padding:10px;
                                        width:65%;
                                        text-align:center;
                                    ">
                                        Product Specification
                                    </th>
   <th style="
                                        padding:10px;
                                        width:15%;
                                        text-align:center;
                                    ">
                                      HS Code
                                    </th>
                                   <th style="
                                        padding:10px;
                                        width:15%;
                                        text-align:center;
                                        border-top-right-radius:10px;
                                        border-bottom-right-radius:10px;
                                    ">
                                        Qty
                                    </th>

                                  
                                </tr>

                            </thead>


                           <tbody>

<t t-set="sn" t-value="1"/>

<t t-foreach="o.move_ids" t-as="line">

    <tr>

        <td style="
                                           font-size:15px;
                                           padding-top:15px;
                                           text-align:center;
                                           vertical-align:top;
                                        ">
            <span t-esc="sn"/>
        </td>

         <td style="
                                            padding-top:15px;
                                            vertical-align:top;
                                            width:65%;
                                            white-space:normal;
                                            word-break:break-word;
                                        ">

                                            <div style="
                                                font-weight:bold;
                                                margin-bottom:6px;
                                                font-size:15px;
                                                line-height:1.5;
                                                width:100%;
                                            ">
            <span t-esc="line.product_id.name"/></div>
        </td>

          <td style="
                                          padding-top:15px;
                                          font-size:15px;
                                          text-align:center;
                                          vertical-align:top;
                                        ">
            <span t-esc="line.product_id.product_tmpl_id.hs_code or ''"/>
        </td>

        <td style="
                                          padding-top:15px;
                                          font-size:15px;
                                          text-align:center;
                                          vertical-align:top;
                                        ">
             <span t-esc="int(line.quantity)"/>
        </td>

        <td></td>

    </tr>

    <tr>
        <td></td>
           <td  colspan="4" style="
                                          font-weight:bold;
                                          font-size:13px;
                                                    margin-bottom:6px;
                                        ">
          <span>Ordering Code: </span> 
            <span t-esc="line.product_id.product_tmpl_id.x_studio_sku_code or ''"/>
        </td>
    </tr>

    <tr>
        <td></td>
       <td colspan="4" style="
                                          font-weight:bold;
                                          font-size:13px;
                                                    margin-bottom:6px;
                                                    font-size:11px;
                                        ">

    <t t-if="line.move_line_ids.filtered(lambda ml: ml.lot_id)">

        <span>Serial No:</span>

        <t t-foreach="line.move_line_ids" t-as="ml">

            <t t-if="ml.lot_id">
                <small>
                    <span t-esc="ml.lot_id.name"/>
                </small>
            </t>

        </t>

    </t>

</td>
    </tr>

    <tr style="border-bottom:1px solid #d9d9d9;">
        <td></td>
       
                                        <td colspan="4" style="
                                            font-size:12px;
                                            color:#666;
                                            line-height:1.7;
                                            white-space:normal;
                                            word-break:break-word;
                                        ">
            <span t-esc="line.product_id.description or ''"/>
        </td>
    </tr>

    <t t-set="sn" t-value="sn + 1"/>

</t>

</tbody>
                        </table>
                        <!-- NOTES -->
                        <div style="margin-top:60px;padding-left:20px;">

                            <strong style="
                                font-size:14px;
                                border-bottom:1px solid #e58b39;
                                padding-bottom:2px;
                            ">
                                Notes
                            </strong>

                            <div style="
                                margin-top:10px;
                                font-size:14px;
                                color:#555;
                            ">

                                <t t-if="o.note">
                                 <span t-esc="o.note or ''"/>
                                </t>

                                <t t-else="">
                                    Thanks for giving us the opportunity to serve you
                                </t>

                            </div> </div>
     <!-- FOOTER CONTENT -->
                          <!-- FOOTER -->
<div class="fixed-footer">

    <!-- FOOTER TEXT -->
    <div style="
        padding:0 40px;
        font-size:11px;
        color:#555;
    ">

        <div style="
            margin-bottom:5px;
            color:#888;
            font-style:italic;
        ">
            This document is electronically generated and valid without signature or company stamp.
        </div>

        <div style="
            border-top:1px solid #1f3b73;
            padding-top:6px;
            text-align:center;
        ">

            <t t-if="o.company_id.street2">
                <span t-esc="o.company_id.street2"/>
            </t>

            
            <span t-esc="o.company_id.city or ''"/>
            -
            <span t-esc="o.company_id.country_id.name or ''"/>

            <br/>

            CR No:
            <span t-esc="o.company_id.company_registry or 'N/A'"/>

            |

            <span t-esc="o.company_id.email or ''"/>

            |

          <span t-esc="(o.company_id.website or '').replace('http://', '').replace('https://', '')"/>

        </div>

    </div>

    <!-- FULL BLEED BAR -->
   <!-- ABSOLUTE FULL WIDTH BAR -->
                           <!-- FULL WIDTH FOOTER BORDER -->
<div style="
    width:auto;
    height:25px;
    overflow:hidden;
    margin-top:5px;
    margin-left:-40px;
    margin-right:-50px;
">

    <svg width="100%"
         height="25"
         viewBox="0 0 1000 25"
         preserveAspectRatio="none"
         xmlns="http://www.w3.org/2000/svg">

        <!-- BLUE 25% -->
        <polygon points="0,0 260,0 240,25 0,25"
                 fill="#1f3b73"/>

        <!-- ORANGE 75% -->
        <polygon points="260,0 1000,0 1000,25 240,25"
                 fill="#e58b39"/>

    </svg>

</div>
 </div>

                    </div>

                </main>

            </t>

        </t>

    </template>

</odoo>
