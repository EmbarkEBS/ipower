<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ====================================================== -->
    <!-- CUSTOM SALES ORDER REPORT -->
    <!-- ====================================================== -->

    <template id="sale_order_custom_report">

        <t t-call="web.html_container">

            <t t-foreach="docs" t-as="o">

                <style>

                    @page {
                        margin: 0px 40px 0px 40px !important;
                    }

                    .page {
                        padding: 20px 40px;
                        font-family: Helvetica, Arial, sans-serif;
                        position: relative;
                    }

                    .watermark {
                        position: fixed;
                        top: 35%;
                        left: 18%;
                        transform: rotate(-30deg);
                        opacity: 0.12;
                        z-index: -1;
                    }

                    .table {
                        width: 100%;
                        border-collapse: collapse;
                    }

                    .table th {
                        background: #4b4b4b;
                        color: white;
                        padding: 10px;
                    }

                    .table td {
                        padding: 10px;
                        border-bottom: 1px solid #ddd;
                    }

                </style>

                <div class="page">

                    <!-- WATERMARK -->
                    <div class="watermark">

                        <img t-if="o.company_id.logo"
                             t-att-src="image_data_uri(o.company_id.logo)"
                             style="max-width:500px;"/>

                    </div>

                    <!-- HEADER -->

                    <table style="width:100%; margin-bottom:30px;">

                        <tr>

                            <!-- COMPANY -->

                            <td style="width:60%; vertical-align:top;">

                                <img t-if="o.company_id.logo"
                                     t-att-src="image_data_uri(o.company_id.logo)"
                                     style="max-height:80px; margin-bottom:10px;"/>

                                <div style="font-size:13px; line-height:1.7;">

                                    <strong style="font-size:15px; color:#1a3a5a;">

                                        <span t-esc="o.company_id.name"/>

                                    </strong>

                                    <br/>

                                    <span t-esc="o.company_id.street or ''"/>

                                    <br/>

                                    <span t-esc="o.company_id.city or ''"/>

                                    <t t-if="o.company_id.state_id">
                                        ,
                                        <span t-esc="o.company_id.state_id.name"/>
                                    </t>

                                    <br/>

                                    <span t-esc="o.company_id.country_id.name or ''"/>

                                    <br/>

                                    <strong>

                                        TRN
                                        <span t-esc="o.company_id.vat or ''"/>

                                    </strong>

                                </div>

                            </td>

                            <!-- SALES ORDER -->

                            <td style="width:40%; text-align:right;">

                                <h1 style="font-size:28px; margin-top:20px;">

                                    SALES ORDER

                                </h1>

                                <div style="font-size:16px; margin-top:15px;">

                                    <span t-field="o.name"/>

                                </div>

                            </td>

                        </tr>

                    </table>

                    <!-- CUSTOMER SECTION -->

                    <table style="width:100%; margin-bottom:35px;">

                        <tr>

                            <!-- ADDRESS -->

                            <td style="width:55%; vertical-align:top;">

                                <strong style="color:#1a3a5a;">
                                    To
                                </strong>

                                <br/><br/>

                                <strong>

                                    <span t-esc="o.partner_id.parent_id.name if o.partner_id.parent_id else o.partner_id.name"/>

                                </strong>

                                <br/>

                                <span t-esc="o.partner_id.street or ''"/>

                                <t t-if="o.partner_id.street2">
                                    <br/>
                                    <span t-esc="o.partner_id.street2"/>
                                </t>

                                <br/>

                                <span t-esc="o.partner_id.city or ''"/>

                                <t t-if="o.partner_id.state_id">
                                    ,
                                    <span t-esc="o.partner_id.state_id.name"/>
                                </t>

                                <br/>

                                <span t-esc="o.partner_id.country_id.name or ''"/>

                                <br/><br/>

                                <t t-if="o.partner_id.vat">

                                    <strong>
                                        TRN
                                        <span t-esc="o.partner_id.vat"/>
                                    </strong>

                                </t>

                                <!-- ATTN -->

                                <t t-if="o.partner_id.parent_id">

                                    <p style="margin-top:8px;">

                                        <strong>Attn:</strong>

                                        <t t-if="o.partner_id.x_studio_salutation">
                                            <span t-esc="o.partner_id.x_studio_salutation"/>
                                        </t>

                                        <span t-esc="o.partner_id.name"/>

                                    </p>

                                </t>

                            </td>

                            <!-- META -->

                            <td style="width:45%; padding-left:40px; vertical-align:top;">

                                <table style="width:100%; font-size:13px;">

                                    <tr>

                                        <td style="font-weight:bold; color:#1a3a5a;">
                                            Order Date
                                        </td>

                                        <td>
                                            :
                                            <span t-field="o.date_order"
                                                  t-options='{"format": "dd MMMM yyyy"}'/>
                                        </td>

                                    </tr>

                                    <tr>

                                        <td style="font-weight:bold; color:#1a3a5a;">
                                            Payment Terms
                                        </td>

                                        <td>
                                            :
                                            <span t-field="o.payment_term_id"/>
                                        </td>

                                    </tr>

                                    <tr>

                                        <td style="font-weight:bold; color:#1a3a5a;">
                                            Salesperson
                                        </td>

                                        <td>
                                            :
                                            <span t-field="o.user_id"/>
                                        </td>

                                    </tr>

                                </table>

                            </td>

                        </tr>

                    </table>

                    <!-- PRODUCT TABLE -->

                    <table class="table">

                        <thead>

                            <tr>

                                <th style="width:5%;">SN</th>
                                <th style="width:55%;">Description</th>
                                <th style="width:10%;">Qty</th>
                                <th style="width:15%;">Unit Price</th>
                                <th style="width:15%;">Total</th>

                            </tr>

                        </thead>

                        <tbody>

                            <t t-set="sn" t-value="1"/>

                            <t t-foreach="o.order_line" t-as="line">

                                <tr>

                                    <td style="text-align:center;">
                                        <span t-esc="sn"/>
                                    </td>

                                    <td>

                                        <strong>
                                            <span t-field="line.product_id.name"/>
                                        </strong>

                                        <br/>

                                        <span t-esc="line.product_id.description or ''"/>

                                    </td>

                                    <td style="text-align:center;">
                                        <span t-field="line.product_uom_qty"/>
                                    </td>

                                    <td style="text-align:right;">
                                        <span t-field="line.price_unit"/>
                                    </td>

                                    <td style="text-align:right;">
                                        <span t-field="line.price_subtotal"/>
                                    </td>

                                </tr>

                                <t t-set="sn" t-value="sn + 1"/>

                            </t>

                        </tbody>

                    </table>

                    <!-- TOTALS -->

                    <table style="width:100%; margin-top:25px;">

                        <tr>

                            <td style="width:55%;">

                                <strong>

                                    Amount in Words:

                                    <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/>

                                </strong>

                            </td>

                            <td style="width:45%;">

                                <table style="width:100%; text-align:right;">

                                    <tr>

                                        <td>
                                            <strong>Subtotal</strong>
                                        </td>

                                        <td>
                                            <span t-field="o.amount_untaxed"/>
                                        </td>

                                    </tr>

                                    <tr>

                                        <td>
                                            <strong>Tax</strong>
                                        </td>

                                        <td>
                                            <span t-field="o.amount_tax"/>
                                        </td>

                                    </tr>

                                    <tr style="font-size:16px; color:#1a3a5a;">

                                        <td>
                                            <strong>Total</strong>
                                        </td>

                                        <td>
                                            <strong>
                                                <span t-field="o.amount_total"/>
                                            </strong>
                                        </td>

                                    </tr>

                                </table>

                            </td>

                        </tr>

                    </table>

                    <!-- NOTES -->

                    <div style="margin-top:50px;">

                        <strong style="border-bottom:1px solid #e58b39;">
                            Notes
                        </strong>

                        <div style="margin-top:10px; color:#555;">

                            <t t-if="o.note">
                                <span t-field="o.note"/>
                            </t>

                            <t t-else="">
                                Thank you for your business.
                            </t>

                        </div>

                    </div>

                </div>

            </t>

        </t>

    </template>

    <!-- ====================================================== -->
    <!-- REPORT ACTION -->
    <!-- ====================================================== -->

    <record id="action_report_custom_sale_order"
            model="ir.actions.report">

        <field name="name">Custom Sales Order</field>

        <field name="model">sale.order</field>

        <field name="report_type">qweb-pdf</field>

        <field name="report_name">
            custom_sale_report.sale_order_custom_report
        </field>

        <field name="report_file">
            custom_sale_report.sale_order_custom_report
        </field>

        <field name="binding_model_id"
               ref="sale.model_sale_order"/>

        <field name="binding_type">
            report
        </field>

    </record>

</odoo>