<odoo>
    <template id="sale_order_template">

     <t t-call="web.html_container">
<meta charset="UTF-8"/>


    <t t-foreach="docs" t-as="o">

        <t t-set="company" t-value="o.company_id"/>

        <t t-call="custom_sale_report.external_layout_ipower">

<!-- ✅ SAFE CURRENCY SYMBOL -->
<t t-set="cur_symbol"
   t-value="'&#8364;' if o.currency_id.name == 'EUR' else o.currency_id.symbol"/>
                <style>
                   

    html, body {
        margin: 0 !important;
        padding: 0 !important;
    }

    .article {
        margin: 0 !important;
        padding: 0 !important;
    }
.page {
    padding: 0 40px !important;
}
 table,
tr,
td,
th {
    border: none ;
}
table {
    border-collapse: separate !important;
    border-spacing: 0 !important;
}

td, th {
    border: 0 ;
    outline: 0 !important;
}
                </style>

                <div class="page"
                     style="position:relative;
                            color:#333; padding:100px 0 0 0;
                            line-height:1.4;
                            font-family: Helvetica, Arial, sans-serif !important;">
                            <!-- WATERMARK -->
 <div style="
                            position:absolute;
                            top:55%;
                            left:25%;
                            opacity:0.10;
                            transform:translate(-50%, -50%) rotate(-25deg);
                            z-index:0;
                            width:420px;
                            text-align:center;
                        ">

                            <img t-if="o.company_id.logo"
                                 t-att-src="image_data_uri(o.company_id.logo)"
                                 style="width:100%;"/>

                        </div>

     <!-- ===================================================== -->
                            <!-- ADDRESS + META -->
                            <!-- ===================================================== -->

                            <table style="
                                width:100%;
                                font-size:15px;
                                border-collapse:collapse;
                                margin-top:35px;
                                margin-bottom:35px;
                            ">

                                <tr>

                                    <!-- ADDRESS -->
                                    <td style="
                                        width:50%;font-size:15px;
                                        vertical-align:top;
                                    ">

                                        <table style="
                                            width:100%;font-size:15px;
                                            border-collapse:collapse;
                                        ">
  <strong style="color:#1a3a5a;">
                                                        To
                                                    </strong>

                                                   
                                            <tr>

                                                <!-- ORANGE BORDER -->
                                              <td style="
    width:8px;
    padding:0;
    vertical-align:top;
">

    <svg width="8"
         height="130"
         xmlns="http://www.w3.org/2000/svg">

        <defs>

            <!-- VERTICAL ORANGE FADE -->
            <linearGradient id="verticalFade"
                            x1="0%"
                            y1="0%"
                            x2="0%"
                            y2="100%">

                <stop offset="0%"
                      stop-color="#f39223"
                      stop-opacity="1"/>

                <stop offset="100%"
                      stop-color="#f39223"
                      stop-opacity="0"/>

            </linearGradient>

        </defs>

        <rect x="0"
              y="0"
              width="2"
              height="130"
              fill="url(#verticalFade)"/>

    </svg>

</td>
                                                <td style="width:15px;">
                                                </td>

                                                <!-- ADDRESS CONTENT -->
                                                <td style="
                                                    vertical-align:top;
                                                    font-size:15px;
                                                    line-height:1.7;
                                                ">

                                                  

                                                    <strong>
                                                      <span t-esc="o.partner_id.parent_id.name if o.partner_id.parent_id else o.partner_id.name"/>
   
                                                    </strong>

                                                    <br/>

                                                    <span t-esc="o.partner_id.street or ''"/>

                                                    <t t-if="o.partner_id.street2">
                                                        <br/>
                                                        <span t-esc="o.partner_id.street2"/>
                                                    </t>

                                                    <br/>

                                                    <span t-esc="o.partner_id.city or ''"/>

                                                  <!-- <t t-if="o.partner_id.state_id">
                                                         <span t-esc="o.partner_id.state_id.name"/>
                                                    </t>--> 

                                                    -

                                                    <span t-esc="o.partner_id.country_id.name or ''"/>

                                                    <br/>

                                                  <t t-if="o.partner_id.vat">
<p  style="margin-top:15px"><strong >    TRN <span t-esc="o.partner_id.vat"/></strong></p>
</t>
   
<!-- ATTN ONLY IF CONTACT PERSON -->
<t t-if="o.contact_person_id">
    <p>
        <strong>Attn:</strong>

        <t t-if="o.contact_person_id.x_studio_salutation">
            <span t-esc="o.contact_person_id.x_studio_salutation"/>
        </t>

        <span t-esc="o.contact_person_id.name"/>
    </p>
</t>
                                                </td>

                                            </tr>

                                        </table>

                                    </td>

                                    <!-- META -->
                                    <td style="
                                        width:50%; font-size:15px;
                                        vertical-align:top;
                                        
                                        padding-left:40px;
                                    ">

                                        <table style="
                                            width:100%;font-size:15px;
                                            border-collapse:collapse;
                                        ">

                                            <tr>

                                                <td style="
                                                    padding:4px 0;
                                                    width:45%;font-size:15px;
                                                    font-weight:bold;
                                                    color:#1a3a5a;
                                                ">
                                                   <t t-if="o.state in ['draft', 'sent']">
       <span> Quote</span>
    </t>
    <t t-else="">
      <span>Order</span>
    </t> <span>Date</span>
                                                </td>

                                                <td style="padding:4px 0;">

                                                    :
                                                    <span t-field="o.date_order"
                                                          t-options='{"format": "dd MMMM yyyy"}'/>

                                                </td>

                                            </tr>

                                            <tr>

                                                <td style="
                                                    padding:4px 0; font-size:15px;
                                                    font-weight:bold;
                                                    color:#1a3a5a;
                                                ">
                                                    Payment Terms
                                                </td>

                                                <td style="padding:4px 0;">

                                                    :
                                                    <span t-field="o.payment_term_id.name"/>

                                                </td>
                                                </tr>
                                            

                                            <tr>

                                                <td style="
                                                    padding:4px 0; font-size:15px;
                                                    font-weight:bold;
                                                    color:#1a3a5a;
                                                ">
                                               Incoterms
                                                </td>

                                                 <td style="padding:4px 0;text-align:left">
    :
    <span t-field="o.incoterm.code"/><t t-if="o.incoterm_location"> - <span t-field="o.incoterm_location"/></t>
</td>

                                            </tr>

                                       <t t-if="o.x_studio_project_reference">     <tr>

                                                <td style="
                                                    padding:4px 0; font-size:15px;
                                                    font-weight:bold;
                                                    color:#1a3a5a;
                                                ">
                                                   Project Ref
                                                </td>

                                                <td style="padding:4px 0;">

                                                    :
                                                    <span t-esc="o.x_studio_project_reference or ''"/>

                                                </td>

                                            </tr></t>
   <t t-if="o.x_studio_customer_po_ref">     <tr>

                                                <td style="
                                                    padding:4px 0; font-size:15px;
                                                    font-weight:bold;
                                                    color:#1a3a5a;
                                                ">
                                                   Customer PO Ref
                                                </td>

                                                <td style="padding:4px 0;">

                                                    :
                                                    <span t-esc="o.x_studio_customer_po_ref or ''"/>

                                                </td>

                                            </tr></t>
                                               <t t-if="o.state in ['draft', 'sent']">    <tr>

                                                <td style="
                                                    padding:4px 0; font-size:15px;
                                                    font-weight:bold;
                                                    color:#1a3a5a;
                                                ">
                                                    Validity
                                                </td>

                                                <td style="padding:4px 0;">

                                                    :
                                                    <span t-field="o.validity_date" t-options='{"format": "dd MMMM yyyy"}'/>

                                                </td>

                                            </tr></t>
                                            <t t-if="o.picking_type_id.code == 'outgoing'
           and o.sale_id
           and o.sale_id.partner_shipping_id
           and o.sale_id.partner_invoice_id
           and o.sale_id.partner_shipping_id.id != o.sale_id.partner_invoice_id.id">

    <tr>
        <td style="padding:4px 0;font-size:15px;font-weight:bold;color:#1a3a5a;vertical-align:top;">
            Delivery Address
        </td>

        <td style="padding:4px 0;font-size:15px;font-family:Arial,sans-serif;line-height:1.4;">
            :
            <div style="margin-top:-20px;margin-left:6px">
                <strong>
                    <span t-esc="o.sale_id.partner_shipping_id.name"/>
                </strong>

                <t t-if="o.sale_id.partner_shipping_id.street">
                    <br/>
                    <span t-esc="o.sale_id.partner_shipping_id.street"/>
                </t>

                <t t-if="o.sale_id.partner_shipping_id.street2">
                    <br/>
                    <span t-esc="o.sale_id.partner_shipping_id.street2"/>
                </t>

                <br/>
                <span t-esc="o.sale_id.partner_shipping_id.city or ''"/>

                <t t-if="o.sale_id.partner_shipping_id.country_id">
                    <br/>
                    <span t-esc="o.sale_id.partner_shipping_id.country_id.name"/>
                </t>

                <t t-if="o.sale_id.partner_shipping_id.phone">
                    <br/>
                    <span t-esc="o.sale_id.partner_shipping_id.phone"/>
                </t>
            </div>
        </td>
    </tr>

</t>
                <t t-if="o.partner_shipping_id
         and o.partner_invoice_id
         and o.partner_shipping_id.id != o.partner_invoice_id.id">

    <tr>
        <td style="padding:4px 0;font-size:15px;font-weight:bold;color:#1a3a5a;vertical-align:top;">
            Delivery Address
        </td>

        <td style="padding:4px 0;font-size:15px;font-family:Arial,sans-serif;line-height:1.4;">
            :
            <div style="margin-top:-20px;margin-left:6px">

                <strong>
                    <span t-esc="o.partner_shipping_id.name"/>
                </strong>

                <t t-if="o.partner_shipping_id.street">
                    <br/>
                    <span t-esc="o.partner_shipping_id.street"/>
                </t>

                <t t-if="o.partner_shipping_id.street2">
                    <br/>
                    <span t-esc="o.partner_shipping_id.street2"/>
                </t>

                <br/>
                <span t-esc="o.partner_shipping_id.city or ''"/>

                <t t-if="o.partner_shipping_id.country_id">
                    <br/>
                    <span t-esc="o.partner_shipping_id.country_id.name"/>
                </t>

            </div>
        </td>
    </tr>

</t>                        </table>

                                    </td>

                                </tr>

                            </table>
      <!-- ===================================================== -->
                            <!-- PRODUCT TABLE -->
                            <!-- ===================================================== -->

                            <table style="
                                width:100%;
                                border-collapse:collapse;
                                margin-bottom:20px;
                            ">

                                <thead>

                                    <tr style="
                                        background:#4b4b4b;
                                        color:#fff;
                                    ">

                                        <th style="
                                            padding:10px;
                                            width:5%;
                                            text-align:center;
                                            border-top-left-radius:10px;
                                            border-bottom-left-radius:10px;
                                        ">
                                            SN
                                        </th>

                                        <th style="
                                            padding:10px;
                                            width:55%;
                                            text-align:center;
                                        ">
                                            Product Specification
                                        </th>

                                        <th style="
                                            padding:10px;
                                            width:7%;
                                            text-align:center;
                                        ">
                                            Qty
                                        </th>

                                        <th style="
                                            padding:10px;
                                            width:11%;
                                            text-align:right;
                                        ">
                                            Unit Price
                                        </th>

                                        <th style="
                                            padding:10px;
                                            width:12%;
                                            text-align:right;
                                            border-top-right-radius:10px;
                                            border-bottom-right-radius:10px;
                                        ">
                                            Total Price
                                        </th>

                                    </tr>

                                </thead>

                                <tbody>

                                    <t t-set="sn" t-value="1"/>

                                  <t t-foreach="o.order_line" t-as="line">

    <!-- SECTION -->
    <t t-if="line.display_type == 'line_section'">

        <tr>
            <td colspan="5"
                style="
                    padding-top:15px;
                    padding-bottom:10px;padding-left:15px;
                    font-size:15px;
                    font-weight:bold;
                    color:#1a3a5a;
                    border-bottom:1px solid #d9d9d9 !important;
                    background:#f7f7f7;
                ">
                <span t-field="line.name"/>
            </td>
        </tr>

    </t>

    <!-- NOTE -->
    <t t-elif="line.display_type == 'line_note'">

        <tr>
            <td></td>
            <td colspan="4"
                style="
                    padding:10px 0;
                    font-style:italic;
                    color:#666;
                ">
                <span t-field="line.name"/>
            </td>
        </tr>

    </t>

    <!-- NORMAL PRODUCT / DOWN PAYMENT PRODUCT -->
    <t t-else="">

        <tr>

            <!-- SN -->
            <td style="font-size:15px;
                       padding-top:15px;
                       text-align:center;
                       vertical-align:top;">
                <span t-esc="sn"/>
            </td>

            <!-- DESCRIPTION -->
            <td style="
                padding-top:15px;
                vertical-align:top;
                width:55%;
                white-space:normal;
                word-break:break-word;
            ">
                <div style="
                    font-weight:bold;
                    margin-bottom:6px;
                    font-size:15px;
                    line-height:1.5;
                    width:100%;
                ">

                    <!-- For down payment use line.name -->
                    <t t-if="line.is_downpayment">
                        <span t-field="line.name"/>
                    </t>
                    <t t-else="">
                        <span t-field="line.product_id.name"/>
                    </t>

                </div>
            </td>

            <!-- QTY -->
            <td style="
                padding-top:15px;
                font-size:15px;
                text-align:center;
                vertical-align:top;
            ">
                <span t-esc="int(line.product_uom_qty)"/>
            </td>

            <!-- UNIT PRICE -->
            <td style="
                padding-top:15px;
                font-size:15px;
                text-align:center;
                vertical-align:top;
            ">
                <span t-esc="'{:,.2f}'.format(line.price_unit)"/>
            </td>

            <!-- TOTAL -->
            <td style="
                padding-top:15px;
                font-size:15px;
                text-align:center;
                vertical-align:top;
            ">
                <span t-esc="'{:,.2f}'.format(line.price_subtotal)"/>
            </td>

        </tr>

        <!-- EXTRA DETAILS ONLY FOR REAL PRODUCTS -->
        <t t-if="not line.is_downpayment">

            <tr>
                <td></td>
                <td colspan="4" style="font-size:13px;">

                    <div style="margin-top:8px;">

                        <t t-if="line.product_id.type != 'service' and line.x_studio_related_field_8b0_1jmkth7qs">

                            <span style="font-weight:bold;">
                                Ordering Code:
                            </span>

                            <span style="font-weight:bold;"
                                  t-field="line.x_studio_related_field_8b0_1jmkth7qs"/>

                        </t>

                    </div>

                    <div style="margin-top:8px;">

                        <t t-if="line.product_id.type != 'service' and line.x_studio_expected_delivery_2">

                            <span>Expected Delivery Date: </span>
                            <span t-esc="line.x_studio_expected_delivery_2"/>

                        </t>

                    </div>

                    <div style="margin-top:8px;">

                        <t t-if="line.x_studio_p_warranty">

                            <span>Warranty: </span>
                            <span t-esc="line.x_studio_p_warranty"/>

                        </t>

                    </div>

                </td>
            </tr>

            <tr>
    <td style="border-bottom:1px solid #d9d9d9;"></td>

    <td colspan="4"
        style="
            border-bottom:1px solid #d9d9d9;
            padding-bottom:15px;
            font-size:12px;
            color:#666;
            line-height:1.7;
        ">
        <span t-esc="line.product_id.description or ''"/>
    </td>
</tr>

        </t>

        <t t-set="sn" t-value="sn + 1"/>

    </t>


                                    </t>

                                </tbody>

                            </table>

     <!-- TOTAL -->
    <table style="width:100%; margin-top:20px border-collapse:collapse;">
    <tr>

        <!-- LEFT: AMOUNT IN WORDS -->
        <td style="  width:55%;
                                        vertical-align:middle;
                                         font-size:15px;
                                        padding-top:40px;padding-left:20px;text-align:left;">
   
           
                                        <div style="font-size:13px;">

                                            <strong>
         Amount in Words:
                                                <span t-esc="o.currency_id.name"/>
                                                <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/>
                                                only.

                                            </strong>

                                        </div>
        </td>

        <!-- RIGHT: TOTAL BOX -->
        <td style="width:45%; ">

         <table style="
                                            width:100%;
                                            border-collapse:collapse;
                                            text-align:right;padding-right:20px;
                                        ">

                                            <tr>

                                                <td style="
                                                    padding:5px;
                                                    font-weight:bold;
                                                ">
                                                    Sub Total
                                                </td> <td style="padding:5px;">
                    <span t-esc="cur_symbol + ' {:,.2f}'.format(o.amount_untaxed)"/>
                </td>

                                            </tr>

                                            <tr>

                                                <td style="
                                                    padding:5px;
                                                    font-weight:bold;
                                                ">
                                                  <t t-if="o.tax_totals and o.tax_totals.get('subtotals')">

    <t t-foreach="o.tax_totals['subtotals']" t-as="subtotal">

        <t t-foreach="subtotal['tax_groups']" t-as="tax_group">

            <tr>
                <td style="padding:5px;font-weight:bold;">

                    VAT
                   <span>(</span><span t-esc="int(tax_group.get('involved_tax_ids') and env['account.tax'].browse(tax_group['involved_tax_ids'][0]).amount or 0)"/>%<span>)</span>
                  

                </td>

                <td style="padding:5px;text-align:right;">

                    <span t-raw="cur_symbol"/>
                    <span t-esc="'{:,.2f}'.format(tax_group['tax_amount_currency'])"/>

                </td>
            </tr>

        </t>

    </t>

</t>    </td>

                                               
                                            </tr>

                                            <tr style="
                                                font-size:16px;
                                                color:#1a3a5a;
                                            ">

       <td style="
        padding:10px 5px;
        font-weight:bold;
    ">
        Total
    </td>

    <td style="
        padding:10px 5px;
        font-weight:bold;
    ">
                    <span t-esc="cur_symbol + ' {:,.2f}'.format(o.amount_total)"/>
               </td>

                                            </tr>

                                        </table>

                                    </td>

                                </tr>

                            </table>

 <!-- ===================================================== -->
                            <!-- NOTES -->
                            <!-- ===================================================== -->

                            <div style="margin-top:60px;padding-left:20px;">

                                <strong style="
                                    font-size:14px;
                                    border-bottom:1px solid #e58b39 !important;
                                    padding-bottom:2px;
                                ">
                                    Notes
                                </strong>

                                <div style="
                                    margin-top:10px;
                                      font-size:14px;
                                    color:#555;
                                ">

                                    <t t-if="o.note">
                                        <span t-field="o.note"/>
                                    </t>

                                    <t t-else="">
                                        Thanks for giving us the opportunity to serve you
                                    </t>

                                </div>

                            </div>
 
                 

                </div>

            </t>

        </t>
</t>
    </template>
</odoo>
