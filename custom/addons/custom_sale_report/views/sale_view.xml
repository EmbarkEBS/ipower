<?xml version="1.0" encoding="utf-8"?>
<odoo>
<record id="sale_order_form_inherit_custom_print" model="ir.ui.view">
    <field name="name">sale.order.form.custom.print</field>
    <field name="name">sale.order.form.custom.preview</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">

        <xpath expr="//header" position="inside">
  <button name="action_preview_custom_sale_order"
                        type="object"
                        string="Preview"
                        class="btn-secondary"
                        icon="fa-eye"/>
                        
          <button name="action_print_custom_so"
        type="object"
        string="Print"
        class="btn-primary"
        icon="fa-print"/>


        </xpath>
<xpath expr="//field[@name='partner_id']" position="after">

    <field name="contact_person_id"
           domain="[('parent_id', '=', partner_id)]"/>

</xpath>
    </field>
</record>

</odoo>