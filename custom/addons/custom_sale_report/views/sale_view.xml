<record id="sale_order_form_inherit_custom_print" model="ir.ui.view">
    <field name="name">sale.order.form.custom.print</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">

        <xpath expr="//header" position="inside">

            <button name="%(action_report_custom_sale_order)d"
                    string="Print"
                    type="action"
                    class="btn-primary"
                     icon="fa-print"/>

        </xpath>

    </field>
</record>