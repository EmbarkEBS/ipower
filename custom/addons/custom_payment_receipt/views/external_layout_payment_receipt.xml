<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="external_layout_payment_receipt">
<style>
*
{
    font-family: Helvetica, Arial, sans-serif !important;
}

    .page {
        margin: 0 !important;
        padding: 0px 40px 0px 40px !important;
    }
.table {
    width:100%;
    border-collapse:collapse;
}
.footer{
      margin-bottom:-20px;
      position:absolute;
      bottom:0;
                    }
.table th,
.table td {
    border:1px solid #cccccc;
    padding:6px;
}

.table-borderless th,
.table-borderless td {
    border:1px solid #cccccc !important;
}
</style>  <div class="page"
                     style="padding:10px 40px 40px 40px;position:relative;
                            color:#333; margin:0;
                            line-height:1.4;
                            font-family: Helvetica, Arial, sans-serif !important;">
    <!-- HEADER -->
    <div class="header">

        <table style="width:100%; border-collapse:collapse;">
            <tr>

               <td style="width:60%; vertical-align:top;">

   <img t-if="o.company_id.logo"
     t-att-src="image_data_uri(o.company_id.logo)"
     style="max-height:80px; margin-bottom:10px;"/>
</td><td>
<div style="font-size:13px; line-height:1.6;text-align:right;">

    <strong style="font-size:16px;">
        <span t-esc="o.company_id.name"/>
    </strong>

    <br/>

    <t t-if="o.company_id.street">
        <span t-esc="o.company_id.street"/>
        <br/>
    </t>

    <t t-if="o.company_id.city">
        <span t-esc="o.company_id.city"/>
    </t>

    <t t-if="o.company_id.country_id">
       
        <span t-esc="o.company_id.country_id.name"/>
    </t>

    <br/>

    <strong>
        TRN:
        <span t-esc="o.company_id.vat or ''"/>
    </strong>

</div>

</td>

            </tr>
        </table>

    </div>

    <!-- BODY -->
 <!-- BODY -->
<div class="article o_report_layout_boxed o_table_boxed"
     t-att-data-oe-model="o and o._name"
     t-att-data-oe-id="o and o.id">

    <div class="container">
        <t t-out="0"/>
    </div>

</div>
    <!-- FOOTER -->
    <div class="footer">

        <div style="padding:0 40px;font-size:11px;">

            <div style="margin-bottom:5px;color:#888;font-style:italic;">
                This document is electronically generated and valid without signature or company stamp.
            </div>

            <div style="border-top:1px solid #1f3b73;padding-top:6px;text-align:center;">

              <t t-if="o.company_id.street2">
                <span t-esc="o.company_id.street2"/>
            </t>

            
            <span t-esc="o.company_id.city or ''"/>
            -
            <span t-esc="o.company_id.country_id.name or ''"/>


                <br/>

                CR No:
                <span t-esc="o.company_id.company_registry or 'N/A'"/>

                |

                <span t-esc="o.company_id.email or ''"/>

                |

                <span t-esc="(o.company_id.website or '').replace('http://','').replace('https://','')"/>

            </div>

        </div>
  <div style="
                   width:auto;
    height:25px;
    overflow:hidden;
    margin-top:5px;
    margin-left:-40px;
    margin-right:-50px;
                ">

                    <svg width="100%"
                         height="25"
                         viewBox="0 0 1000 25"
                         preserveAspectRatio="none">

                        <polygon points="0,0 260,0 240,25 0,25"
                                 fill="#1f3b73"/>

                        <polygon points="260,0 1000,0 1000,25 240,25"
                                 fill="#e58b39"/>

                    </svg>

                </div>
    </div>
  </div>
</template>


</odoo>
