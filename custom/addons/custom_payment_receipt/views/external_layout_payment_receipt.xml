<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="external_layout_payment_receipt">

    <!-- HEADER -->
    <div class="header">

        <table style="width:100%; border-collapse:collapse;">
            <tr>

               <td style="width:60%; vertical-align:top;">

    <img t-if="company.logo"
         t-att-src="image_data_uri(company.logo)"
         style="max-height:80px; margin-bottom:10px;"/>

    <div style="font-size:13px; line-height:1.6;">

        <strong style="font-size:16px;">
            <span t-esc="company.name"/>
        </strong>

        <br/>

        <t t-if="company.street">
            <span t-esc="company.street"/>
            <br/>
        </t>

        <t t-if="company.city">
            <span t-esc="company.city"/>
        </t>

        <t t-if="company.country_id">
            ,
            <span t-esc="company.country_id.name"/>
        </t>

        <br/>

        <strong>
            TRN:
            <span t-esc="company.vat or ''"/>
        </strong>

    </div>

</td>

            </tr>
        </table>

    </div>

    <!-- BODY -->
    <div class="article"
         t-att-data-oe-model="o and o._name"
         t-att-data-oe-id="o and o.id">

        <t t-out="0"/>

    </div>

    <!-- FOOTER -->
    <div class="footer">

        <div style="padding:0 40px;font-size:11px;">

            <div style="margin-bottom:5px;color:#888;font-style:italic;">
                This document is electronically generated and valid without signature or company stamp.
            </div>

            <div style="border-top:1px solid #1f3b73;padding-top:6px;text-align:center;">

                <span t-esc="o.company_id.city or ''"/>
                -
                <span t-esc="o.company_id.country_id.name or ''"/>

                <br/>

                CR No:
                <span t-esc="o.company_id.company_registry or 'N/A'"/>

                |

                <span t-esc="o.company_id.email or ''"/>

                |

                <span t-esc="(o.company_id.website or '').replace('http://','').replace('https://','')"/>

            </div>

        </div>
  <div style="
                    width:100%;
                    height:25px;
                    margin-top:5px;
                ">

                    <svg width="100%"
                         height="25"
                         viewBox="0 0 1000 25"
                         preserveAspectRatio="none">

                        <polygon points="0,0 260,0 240,25 0,25"
                                 fill="#1f3b73"/>

                        <polygon points="260,0 1000,0 1000,25 240,25"
                                 fill="#e58b39"/>

                    </svg>

                </div>
    </div>

</template>


</odoo>
